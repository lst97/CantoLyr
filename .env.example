# Environment Configuration Example
# Copy this file to .env and update the values as needed

# Application Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
ENABLE_SWAGGER=true
CORS_ENABLED=true
REQUEST_TIMEOUT=60000

# Database Configuration
DATABASE_URL=postgresql://cantolyr:cantolyr@localhost:5432/cantolyr
# For Deno + Prisma Edge, prefer Accelerate (Data Proxy) URL. When set, it takes precedence:
# PRISMA_ACCELERATE_URL=prisma://accelerate.prisma-data.net/?api_key=...
TEST_DATABASE_URL=postgresql://cantolyr:cantolyr@localhost:5432/cantolyr_test
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT=30000
DB_QUERY_TIMEOUT=10000
DB_LOG_QUERIES=true

# LLM Configuration
LLM_PROVIDER=dummy
# For chat/text (not embeddings) via npm:@google/genai:
# GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
LLM_ENABLE_FALLBACK=true

# Cache Configuration
CACHE_TYPE=memory
CACHE_DEFAULT_TTL=300
CACHE_MAX_SIZE=1000
CACHE_ENABLE_STATS=true

# Redis Configuration (for future use)
# REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=cantolyr:

# Development/Testing
# Set to 'gemini' to use real Gemini API (requires GEMINI_API_KEY)
# Set to 'dummy' to use mock LLM responses (default for MVP)

# Vector DB (Chroma)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=cantolyr_lexicon_v1
VECTOR_RESET_ON_BOOTSTRAP=false

# Embeddings
# Preferred: Google GenAI (API key) — strong multilingual/Chinese
GOOGLE_API_KEY=
# Optional: OpenAI (if you use elsewhere)
# OPENAI_API_KEY=
# EMBEDDING_MODEL can be text-embedding-004 (Google),
# or text-embedding-3-small / text-embedding-3-large (OpenAI)
EMBEDDING_MODEL=text-embedding-004
EMBED_DIM=768

# Embedding batching & throttling (tune to reduce requests)
# Max items pertext-embedding-004
EMBED_BATCH_MAX_ITEMS=256
# Approx token ctext-embedding-004 (tokens ~= chars/4)
EMBED_BATCH_MAX_TOKENS=20000
# Requests per minute throttle (free tier Embedding ~100 RPM)
EMBED_RPM_LIMIT=80
# Exponential backoff tuning (ms)
EMBED_BACKOFF_BASE_MS=500
EMBED_BACKOFF_MAX_MS=10000

# Chroma upsert batch size
CHROMA_UPSERT_BATCH=512
