// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
  runtime  = "deno"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryType {
  vocab
  char
}

model Entry {
  id        BigInt      @id @default(autoincrement())
  surface   String      // The actual character/word text
  type      EntryType
  lang      String      // Language code (zh-HK, misc, etc.)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  readings  Reading[]

  // Indexes for optimal query performance
  @@index([type, surface])
  @@index([lang, type])
  @@map("entries")
}

model Reading {
  id           BigInt     @id @default(autoincrement())
  entryId      BigInt
  entry        Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  jyutping      String[]   @default([])
  tone          String
  pronunciation String
  consonants    String[]   @default([])
  rhymes        String[]   @default([])
  syllables     Int
  freq          Float
  pos           String
  register      String
  gloss         String
  source        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  feedback      Feedback[]

  @@index([pronunciation])
  @@index([syllables])
  @@index([freq])
  @@map("readings")
}

model Feedback {
  id        BigInt   @id @default(autoincrement())
  readingId BigInt
  reading   Reading  @relation(fields: [readingId], references: [id], onDelete: Cascade)
  accepted  Boolean  // Whether the user accepted or rejected this reading
  sessionId String?  // Optional session ID to group related selections
  context   Json?    // Optional context about the selection
  createdAt DateTime @default(now())

  // Indexes for analytics and querying
  @@index([readingId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("feedback")
}
