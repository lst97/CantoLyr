// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
  runtime  = "deno"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryType {
  vocab
  char
}

model Entry {
  id        BigInt      @id @default(autoincrement())
  surface   String      // The actual character/word text
  type      EntryType
  lang      String      // Language code (zh-HK, misc, etc.)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  readings  Reading[]

  // Indexes for optimal query performance
  @@index([type, surface])
  @@index([lang, type])
  @@map("entries")
}

model Reading {
  id           BigInt     @id @default(autoincrement())
  entryId      BigInt
  entry        Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  jyutping      String[]   @default([])
  tone          String
  pronunciation String
  consonants    String[]   @default([])
  rhymes        String[]   @default([])
  syllables     Int
  freq          Float
  pos           String
  register      String
  gloss         String
  source        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  feedback      Feedback[]

  @@index([pronunciation])
  @@index([syllables])
  @@index([freq])
  @@map("readings")
}

model Feedback {
  id        BigInt   @id @default(autoincrement())
  readingId BigInt
  reading   Reading  @relation(fields: [readingId], references: [id], onDelete: Cascade)
  accepted  Boolean  // Whether the user accepted or rejected this reading
  sessionId String?  // Optional session ID to group related selections
  context   Json?    // Optional context about the selection
  createdAt DateTime @default(now())

  // Indexes for analytics and querying
  @@index([readingId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("feedback")
}

// ------------------------------
// Lyrics data model
// ------------------------------

model Song {
  id        BigInt        @id @default(autoincrement())
  docId     String        @unique
  title     String
  year      Int?
  lyrics    LyricLine[]
  artists   SongArtist[]
  lyricists SongLyricist[]

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([docId])
  @@map("songs")
}

model Artist {
  id      BigInt       @id @default(autoincrement())
  name    String       @unique
  songs   SongArtist[]
  createdAt DateTime   @default(now())

  @@index([name])
  @@map("artists")
}

model Lyricist {
  id      BigInt         @id @default(autoincrement())
  name    String         @unique
  songs   SongLyricist[]
  createdAt DateTime     @default(now())

  @@index([name])
  @@map("lyricists")
}

model SongArtist {
  songId  BigInt
  artistId BigInt
  song    Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  artist  Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([songId, artistId])
  @@map("song_artists")
}

model SongLyricist {
  songId    BigInt
  lyricistId BigInt
  song      Song      @relation(fields: [songId], references: [id], onDelete: Cascade)
  lyricist  Lyricist  @relation(fields: [lyricistId], references: [id], onDelete: Cascade)

  @@id([songId, lyricistId])
  @@map("song_lyricists")
}

// Each record is one lyric line
model LyricLine {
  id            BigInt   @id @default(autoincrement())
  lyricId       String   @unique
  songId        BigInt
  song          Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  text          String
  lineIndex     Int
  charCount     Int
  paragraphId   String?
  prevLineId    String?
  nextLineId    String?
  sentiment     String?
  syntaxNotes   String?

  syllableCount Int
  tokenCount    Int
  tonePatternText String
  jyutpingCount Int
  normalizationIsValid Boolean  @default(false)
  normalizationOriginalText String?
  normalizationNotes    String?

  themes       LyricTheme[]
  keywords     LyricKeyword[]
  tokens       Token[]
  syllables    Syllable[]
  toneNgrams   ToneNgram[]
  rhymeNgrams  RhymeNgram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([songId])
  @@index([lineIndex])
  @@index([sentiment])
  @@index([normalizationIsValid])
  @@map("lyric_lines")
}

model Theme {
  id     BigInt       @id @default(autoincrement())
  name   String       @unique
  lyrics LyricTheme[]

  @@index([name])
  @@map("themes")
}

model LyricTheme {
  lyricId BigInt
  themeId BigInt
  lyric   LyricLine @relation(fields: [lyricId], references: [id], onDelete: Cascade)
  theme   Theme     @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([lyricId, themeId])
  @@map("lyric_themes")
}

model Keyword {
  id     BigInt         @id @default(autoincrement())
  word   String         @unique
  lyrics LyricKeyword[]

  @@index([word])
  @@map("keywords")
}

model LyricKeyword {
  lyricId   BigInt
  keywordId BigInt
  lyric     LyricLine @relation(fields: [lyricId], references: [id], onDelete: Cascade)
  keyword   Keyword   @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@id([lyricId, keywordId])
  @@map("lyric_keywords")
}

// Per-token (optional for future extension)
model Token {
  id       BigInt     @id @default(autoincrement())
  lyricId  BigInt
  lyric    LyricLine  @relation(fields: [lyricId], references: [id], onDelete: Cascade)
  position Int
  text     String
  pos      String?

  @@index([lyricId, position])
  @@map("tokens")
}

// One syllable per tone digit / jyutping
model Syllable {
  id        BigInt     @id @default(autoincrement())
  lyricId   BigInt
  lyric     LyricLine  @relation(fields: [lyricId], references: [id], onDelete: Cascade)
  position  Int
  jyutping  String
  jyutpingNormalized String?
  consonant String?
  rhyme     String?
  toneRaw   Int?
  toneDigit Int?
  char      String?

  @@index([lyricId, position])
  @@index([rhyme])
  @@index([jyutpingNormalized])
  @@index([toneDigit])
  @@map("syllables")
}

// N-grams of tones (mapped pronunciation for n>=2 bigrams)
model ToneNgram {
  id            BigInt     @id @default(autoincrement())
  lyricId       BigInt
  lyric         LyricLine  @relation(fields: [lyricId], references: [id], onDelete: Cascade)
  n             Int
  value         String
  position      Int
  syllableCount Int
  tokenCount    Int

  @@index([lyricId])
  @@index([n, value])
  @@index([position])
  @@index([syllableCount, tokenCount])
  @@map("tone_ngrams")
}

model RhymeNgram {
  id            BigInt     @id @default(autoincrement())
  lyricId       BigInt
  lyric         LyricLine  @relation(fields: [lyricId], references: [id], onDelete: Cascade)
  n             Int
  value         String
  position      Int
  syllableCount Int
  tokenCount    Int

  @@index([lyricId])
  @@index([n, value])
  @@index([position])
  @@index([syllableCount, tokenCount])
  @@map("rhyme_ngrams")
}
