{"id": "lyr_5Y-25YCp5paH_MzgzMQ_0010", "text": "來年懷念你定會一天天更多", "structure": {"line_index": 10, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 2, 5, 2, 3, 3, 3, 3], "tone_pattern_cantonese_jyutping": ["loi4", "nin4", "waai4", "nim6", "nei5", "ding6", "jat1", "tin1", "tin1", "do1"]}, "nlp": {"tokens": [{"text": "來", "pos": "X"}, {"text": "年", "pos": "X"}, {"text": "懷念", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "定會", "pos": "X"}, {"text": "一天天", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "福氣", "artists": ["葉倩文"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3831", "prev_line_id": "lyr_5Y-25YCp5paH_MzgzMQ_0009", "next_line_id": "lyr_5Y-25YCp5paH_MzgzMQ_0011", "paragraph_id": "para_03"}}
{"id": "lyr_5Y-25YCp5paH_MzgzMQ_0011", "text": "人生的兜轉雖有些奈何", "structure": {"line_index": 11, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 3, 9, 3, 5, 3, 2, 0], "tone_pattern_cantonese_jyutping": ["jan4", "sang1", "dik1", "dau1", "zyun2", "seoi1", "jau5", "se1", "noi6", "ho4"]}, "nlp": {"tokens": [{"text": "人生", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "兜", "pos": "X"}, {"text": "轉", "pos": "X"}, {"text": "雖", "pos": "X"}, {"text": "有些", "pos": "X"}, {"text": "奈何", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "福氣", "artists": ["葉倩文"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3831", "prev_line_id": "lyr_5Y-25YCp5paH_MzgzMQ_0010", "next_line_id": "lyr_5Y-25YCp5paH_MzgzMQ_0012", "paragraph_id": "para_03"}}
