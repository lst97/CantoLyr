{"id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0005", "text": "共你舉杯 微妙人生裏 終於有你 有了生機", "structure": {"line_index": 5, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 9, 3, 0, 2, 0, 3, 5, 3, 3, 5, 5, 5, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["gung6", "nei5", "geoi2", "bui1", "mei4", "miu6", "jan4", "sang1", "leoi5", "zung1", "jyu1", "jau5", "nei5", "jau5", "liu5", "sang1", "gei1"]}, "nlp": {"tokens": [{"text": "共", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "舉杯", "pos": "X"}, {"text": "微妙", "pos": "X"}, {"text": "人生", "pos": "X"}, {"text": "裏", "pos": "X"}, {"text": "終於", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "生機", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "接近", "artists": ["陳慧嫺"], "lyricists": ["張學友", "潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5096", "prev_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0004", "next_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0006", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0006", "text": "我那天經過碰着你 你笑得比這世上美", "structure": {"line_index": 6, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 3, 3, 4, 4, 2, 5, 5, 4, 3, 9, 5, 4, 5], "tone_pattern_cantonese_jyutping": ["ngo5", "naa5", "tin1", "ging1", "gwo3", "pung3", "zoek6", "nei5", "nei5", "siu3", "dak1", "bei2", "ze5", "sai3", "mei5"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "那天", "pos": "X"}, {"text": "經過", "pos": "X"}, {"text": "碰着", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "世上", "pos": "X"}, {"text": "美", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "接近", "artists": ["陳慧嫺"], "lyricists": ["張學友", "潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5096", "prev_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0005", "next_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0007", "text": "叫我不得不追求你", "structure": {"line_index": 7, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 5, 3, 3, 3, 3, 0, 5], "tone_pattern_cantonese_jyutping": ["giu3", "ngo5", "bat1", "dak1", "bat1", "zeoi1", "kau4", "nei5"]}, "nlp": {"tokens": [{"text": "叫", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "不得不", "pos": "X"}, {"text": "追求", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "接近", "artists": ["陳慧嫺"], "lyricists": ["張學友", "潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5096", "prev_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0006", "next_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0008", "paragraph_id": "para_02"}}
