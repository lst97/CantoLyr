{"id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0010", "text": "叫我捨不得不留起 時分秒 來共你一起", "structure": {"line_index": 10, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 5, 9, 3, 3, 3, 0, 9, 0, 3, 5, 0, 2, 5, 3, 9], "tone_pattern_cantonese_jyutping": ["giu3", "ngo5", "se2", "bat1", "dak1", "bat1", "lau4", "hei2", "si4", "fan1", "miu5", "loi4", "gung6", "nei5", "jat1", "hei2"]}, "nlp": {"tokens": [{"text": "叫", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "捨不得", "pos": "X"}, {"text": "不留", "pos": "X"}, {"text": "起", "pos": "X"}, {"text": "時分秒", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "共", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "一起", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "接近", "artists": ["陳慧嫺"], "lyricists": ["張學友", "潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5096", "prev_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0009", "next_line_id": "lyr_6ZmI5oWn5ai0_NTA5Ng_0011", "paragraph_id": "para_02"}}
