{"id": "lyr_V29uZw_MzM2Mw_0003", "text": "我終有一天悉破你的表情", "structure": {"line_index": 3, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 5, 3, 3, 3, 4, 5, 3, 9, 0], "tone_pattern_cantonese_jyutping": ["ngo5", "zung1", "jau5", "jat1", "tin1", "sik1", "po3", "nei5", "dik1", "biu2", "cing4"]}, "nlp": {"tokens": [{"text": "我終", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "一天", "pos": "X"}, {"text": "悉破", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "表情", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "罅隙", "artists": ["Wong"], "lyricists": ["周耀輝"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3363", "prev_line_id": "lyr_V29uZw_MzM2Mw_0002", "next_line_id": "lyr_V29uZw_MzM2Mw_0004", "paragraph_id": "para_01"}}
