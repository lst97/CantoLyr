{"id": "lyr_6ZmI5Yag5biM_MTk3MQ_0003", "text": "過去是一對 沿着各站吻至你半睡", "structure": {"line_index": 3, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 4, 2, 3, 4, 0, 2, 4, 2, 5, 4, 5, 4, 2], "tone_pattern_cantonese_jyutping": ["gwo3", "heoi3", "si6", "jat1", "deoi3", "jyun4", "zoek6", "gok3", "zaam6", "man5", "zi3", "nei5", "bun3", "seoi6"]}, "nlp": {"tokens": [{"text": "過去", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "一對", "pos": "X"}, {"text": "沿着", "pos": "X"}, {"text": "各站", "pos": "X"}, {"text": "吻", "pos": "X"}, {"text": "至", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "半", "pos": "X"}, {"text": "睡", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "流浪車票", "artists": ["陳冠希"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1971", "prev_line_id": "lyr_6ZmI5Yag5biM_MTk3MQ_0002", "next_line_id": "lyr_6ZmI5Yag5biM_MTk3MQ_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5Yag5biM_MTk3MQ_0004", "text": "那裏亦想去 寧願一起車廂中老去", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 2, 9, 4, 0, 2, 3, 9, 3, 3, 3, 5, 4], "tone_pattern_cantonese_jyutping": ["naa5", "leoi5", "jik6", "soeng2", "heoi3", "ning4", "jyun6", "jat1", "hei2", "ce1", "soeng1", "zung1", "lou5", "heoi3"]}, "nlp": {"tokens": [{"text": "那裏", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "寧願", "pos": "X"}, {"text": "一起", "pos": "X"}, {"text": "車廂", "pos": "X"}, {"text": "中老去", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "流浪車票", "artists": ["陳冠希"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1971", "prev_line_id": "lyr_6ZmI5Yag5biM_MTk3MQ_0003", "next_line_id": "lyr_6ZmI5Yag5biM_MTk3MQ_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5Yag5biM_MTk3MQ_0005", "text": "你碰上了我 看上了我 那裏也到過", "structure": {"line_index": 5, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 5, 4, 5, 5, 5, 5, 5, 4, 4], "tone_pattern_cantonese_jyutping": ["nei5", "pung3", "liu5", "ngo5", "hon3", "liu5", "ngo5", "naa5", "leoi5", "jaa5", "dou3", "gwo3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "碰上", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "看上", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "那裏", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "過", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "流浪車票", "artists": ["陳冠希"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1971", "prev_line_id": "lyr_6ZmI5Yag5biM_MTk3MQ_0004", "next_line_id": "lyr_6ZmI5Yag5biM_MTk3MQ_0006", "paragraph_id": "para_02"}}
