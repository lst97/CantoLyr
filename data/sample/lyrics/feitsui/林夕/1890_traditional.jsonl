{"id": "lyr_6ZmI5rSB5Luq_MTg5MA_0005", "text": "無論眉梢 留下你裂痕", "structure": {"line_index": 5, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 0, 3, 0, 2, 5, 2, 0], "tone_pattern_cantonese_jyutping": ["mou4", "leon6", "mei4", "saau1", "lau4", "haa6", "nei5", "lit6", "han4"]}, "nlp": {"tokens": [{"text": "無論", "pos": "X"}, {"text": "眉梢", "pos": "X"}, {"text": "留下", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "裂痕", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "讓我愛下去", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1890", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg5MA_0004", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg5MA_0006", "paragraph_id": "para_02"}}
