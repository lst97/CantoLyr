{"id": "lyr_6ZmI5rSB5Luq_MTg5MA_0008", "text": "寧可天真不因你 亂流淚", "structure": {"line_index": 8, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 3, 3, 3, 3, 5, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["ning4", "ho2", "tin1", "zan1", "bat1", "jan1", "nei5", "lyun6", "lau4", "leoi6"]}, "nlp": {"tokens": [{"text": "寧可", "pos": "X"}, {"text": "天真", "pos": "X"}, {"text": "不因", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "亂", "pos": "X"}, {"text": "流淚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "讓我愛下去", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1890", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg5MA_0007", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg5MA_0009", "paragraph_id": "para_03"}}
