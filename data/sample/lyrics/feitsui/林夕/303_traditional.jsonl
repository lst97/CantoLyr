{"id": "lyr_5L2Z5paH5LmQ_MzAz_0007", "text": "談情說愛就算輕易 如何話別誰又會知", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 4, 4, 2, 4, 3, 2, 0, 0, 2, 2, 0, 2, 3], "tone_pattern_cantonese_jyutping": ["taam4", "cing4", "syut3", "oi3", "zau6", "syun3", "hing1", "ji6", "jyu4", "ho4", "waa6", "bit6", "seoi4", "jau6", "zi1"]}, "nlp": {"tokens": [{"text": "談情說愛", "pos": "X"}, {"text": "就算", "pos": "X"}, {"text": "輕易", "pos": "X"}, {"text": "如何", "pos": "X"}, {"text": "話別", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "又", "pos": "X"}, {"text": "會知", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "還你門匙", "artists": ["余文樂"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_303", "prev_line_id": "lyr_5L2Z5paH5LmQ_MzAz_0006", "next_line_id": "lyr_5L2Z5paH5LmQ_MzAz_0008", "paragraph_id": "para_02"}}
