{"id": "lyr_5a6556WW5YS__MzExOQ_0003", "text": "我也居然變心 不禁要承認我", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 3, 0, 4, 3, 3, 3, 4, 0, 2, 5], "tone_pattern_cantonese_jyutping": ["ngo5", "jaa5", "geoi1", "jin4", "bin3", "sam1", "bat1", "gam1", "jiu3", "sing4", "jing6", "ngo5"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "居然", "pos": "X"}, {"text": "變心", "pos": "X"}, {"text": "不禁", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "承認", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一拍兩散", "artists": ["容祖兒"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3119", "prev_line_id": "lyr_5a6556WW5YS__MzExOQ_0002", "next_line_id": "lyr_5a6556WW5YS__MzExOQ_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5a6556WW5YS__MzExOQ_0004", "text": "像往日我恨透的罪人", "structure": {"line_index": 4, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 2, 5, 2, 4, 3, 2, 0], "tone_pattern_cantonese_jyutping": ["zoeng6", "wong5", "jat6", "ngo5", "han6", "tau3", "dik1", "zeoi6", "jan4"]}, "nlp": {"tokens": [{"text": "像", "pos": "X"}, {"text": "往日", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "恨透", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "罪人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一拍兩散", "artists": ["容祖兒"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3119", "prev_line_id": "lyr_5a6556WW5YS__MzExOQ_0003", "next_line_id": "lyr_5a6556WW5YS__MzExOQ_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5a6556WW5YS__MzExOQ_0005", "text": "當初的我 爲了你 爲瞞着好友", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 5, 5, 5, 0, 2, 9, 5], "tone_pattern_cantonese_jyutping": ["co1", "dik1", "ngo5", "liu5", "nei5", "mun4", "zoek6", "hou2", "jau5"]}, "nlp": {"tokens": [{"text": "當初", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "爲了", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "瞞", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "好友", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一拍兩散", "artists": ["容祖兒"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3119", "prev_line_id": "lyr_5a6556WW5YS__MzExOQ_0004", "next_line_id": "lyr_5a6556WW5YS__MzExOQ_0006", "paragraph_id": "para_02"}}
