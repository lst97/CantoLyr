{"id": "lyr_5qKB5rGJ5paH_Mzc4Nw_0007", "text": "這張偷映他剛剛甦醒", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 9, 3, 3, 3, 3, 9], "tone_pattern_cantonese_jyutping": ["ze5", "zoeng1", "tau1", "jing2", "taa1", "gong1", "gong1", "sou1", "sing2"]}, "nlp": {"tokens": [{"text": "這張", "pos": "X"}, {"text": "偷映", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "剛剛", "pos": "X"}, {"text": "甦醒", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一小時沖印", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3787", "prev_line_id": "lyr_5qKB5rGJ5paH_Mzc4Nw_0006", "next_line_id": "lyr_5qKB5rGJ5paH_Mzc4Nw_0008", "paragraph_id": "para_02"}}
