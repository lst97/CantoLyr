{"id": "lyr_5qKB5rGJ5paH_Mzc4Nw_0009", "text": "你近鏡特寫他眼睛 心底恐怕已經", "structure": {"line_index": 9, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 2, 9, 3, 5, 3, 3, 9, 9, 4, 5, 3], "tone_pattern_cantonese_jyutping": ["nei5", "gan6", "geng3", "dak6", "se2", "taa1", "ngaan5", "zing1", "sam1", "dai2", "hung2", "paa3", "ji5", "ging1"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "近鏡", "pos": "X"}, {"text": "特寫", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "眼睛", "pos": "X"}, {"text": "心底", "pos": "X"}, {"text": "恐怕", "pos": "X"}, {"text": "已經", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一小時沖印", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3787", "prev_line_id": "lyr_5qKB5rGJ5paH_Mzc4Nw_0008", "next_line_id": "lyr_5qKB5rGJ5paH_Mzc4Nw_0010", "paragraph_id": "para_02"}}
