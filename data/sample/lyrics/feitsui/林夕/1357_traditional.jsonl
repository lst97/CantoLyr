{"id": "lyr_6ZmI5aWV6L-F_MTM1Nw_0007", "text": "其實我曾一個闖絲路 比失戀更糟", "structure": {"line_index": 7, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 0, 3, 4, 9, 3, 2, 9, 3, 9, 3], "tone_pattern_cantonese_jyutping": ["kei4", "sat6", "ngo5", "cang4", "jat1", "go3", "cong2", "si1", "lou6", "bei2", "sat1", "lyun2", "zou1"]}, "nlp": {"tokens": [{"text": "其實", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "闖", "pos": "X"}, {"text": "絲路", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "失戀", "pos": "X"}, {"text": "更糟", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一切還好", "artists": ["陳奕迅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1357", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTM1Nw_0006", "next_line_id": "lyr_6ZmI5aWV6L-F_MTM1Nw_0008", "paragraph_id": "para_03"}}
