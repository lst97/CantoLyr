{"id": "lyr_6YOR56eA5paH_MTIwNw_0005", "text": "一個冷漠一個決絕 不多不少不相伯仲 你我再也不拖不欠", "structure": {"line_index": 5, "char_count": 24}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 5, 2, 3, 4, 4, 2, 3, 3, 3, 3, 4, 2, 5, 5, 4, 5, 3, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["jat1", "go3", "laang5", "mok6", "jat1", "go3", "kyut3", "zyut6", "bat1", "do1", "bat1", "bat1", "baak3", "zung6", "nei5", "ngo5", "zoi3", "jaa5", "bat1", "to1", "bat1", "him3"]}, "nlp": {"tokens": [{"text": "一個", "pos": "X"}, {"text": "冷漠", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "決絕", "pos": "X"}, {"text": "不多不少", "pos": "X"}, {"text": "不相", "pos": "X"}, {"text": "伯仲", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "再也", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "拖", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "欠", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "不拖不欠", "artists": ["鄭秀文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1207", "prev_line_id": "lyr_6YOR56eA5paH_MTIwNw_0004", "next_line_id": "lyr_6YOR56eA5paH_MTIwNw_0006", "paragraph_id": "para_02"}}
