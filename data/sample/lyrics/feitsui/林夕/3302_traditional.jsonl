{"id": "lyr_5qKB5rGJ5paH_MzMwMg_0001", "text": "藍褲子很殘 也許它就快爛", "structure": {"line_index": 1, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 4, 9, 9, 0, 5, 9, 3, 2, 4, 2], "tone_pattern_cantonese_jyutping": ["laam4", "fu3", "zi2", "han2", "caan4", "jaa5", "heoi2", "taa1", "zau6", "faai3", "laan6"]}, "nlp": {"tokens": [{"text": "藍", "pos": "X"}, {"text": "褲子", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "殘", "pos": "X"}, {"text": "也許", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "快", "pos": "X"}, {"text": "爛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "501", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3302", "prev_line_id": null, "next_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0002", "paragraph_id": "para_01"}}
