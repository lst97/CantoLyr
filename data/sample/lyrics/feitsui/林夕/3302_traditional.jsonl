{"id": "lyr_5qKB5rGJ5paH_MzMwMg_0003", "text": "從前多得你 給它補上花瓣", "structure": {"line_index": 3, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 3, 5, 3, 3, 9, 3, 2], "tone_pattern_cantonese_jyutping": ["cung4", "cin4", "do1", "dak1", "nei5", "kap1", "taa1", "bou2", "faa1", "faan6"]}, "nlp": {"tokens": [{"text": "從前", "pos": "X"}, {"text": "多得", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "補上", "pos": "X"}, {"text": "花瓣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "501", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3302", "prev_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0002", "next_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5qKB5rGJ5paH_MzMwMg_0004", "text": "但是褲腳並未破爛 愛已經不對辦", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 4, 4, 2, 2, 4, 2, 4, 5, 3, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["daan6", "si6", "fu3", "goek3", "bing6", "mei6", "po3", "laan6", "oi3", "ji5", "ging1", "bat1", "deoi3", "baan6"]}, "nlp": {"tokens": [{"text": "但是", "pos": "X"}, {"text": "褲腳", "pos": "X"}, {"text": "並未", "pos": "X"}, {"text": "破爛", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "已經", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "辦", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "501", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3302", "prev_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0003", "next_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0005", "paragraph_id": "para_01"}}
