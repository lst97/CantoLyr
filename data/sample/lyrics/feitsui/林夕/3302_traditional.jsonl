{"id": "lyr_5qKB5rGJ5paH_MzMwMg_0006", "text": "有一天你若和誰亦是着它 它記得我", "structure": {"line_index": 6, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 5, 2, 0, 0, 2, 2, 2, 3, 3, 4, 3, 5], "tone_pattern_cantonese_jyutping": ["jau5", "jat1", "tin1", "nei5", "joek6", "wo4", "seoi4", "jik6", "si6", "zoek6", "taa1", "taa1", "gei3", "dak1", "ngo5"]}, "nlp": {"tokens": [{"text": "有", "pos": "X"}, {"text": "一天", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "若", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "記得", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "501", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3302", "prev_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0005", "next_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5qKB5rGJ5paH_MzMwMg_0007", "text": "如今你 着什麼 我已不必跟着什麼", "structure": {"line_index": 7, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 5, 2, 2, 3, 5, 5, 3, 3, 3, 2, 2, 3], "tone_pattern_cantonese_jyutping": ["jyu4", "gam1", "nei5", "zoek6", "sam6", "mo1", "ngo5", "ji5", "bat1", "bit1", "gan1", "zoek6", "sam6", "mo1"]}, "nlp": {"tokens": [{"text": "如今", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "什麼", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "已", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "跟着", "pos": "X"}, {"text": "什麼", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "501", "artists": ["梁漢文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3302", "prev_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0006", "next_line_id": "lyr_5qKB5rGJ5paH_MzMwMg_0008", "paragraph_id": "para_02"}}
