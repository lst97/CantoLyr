{"id": "lyr_546L6I-y_MTE3NQ_0001", "text": "別叫我太感激你 藥水色太精美", "structure": {"line_index": 1, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 5, 4, 9, 3, 5, 2, 9, 3, 4, 3, 5], "tone_pattern_cantonese_jyutping": ["bit6", "giu3", "ngo5", "taai3", "gam2", "gik1", "nei5", "joek6", "seoi2", "sik1", "taai3", "zing1", "mei5"]}, "nlp": {"tokens": [{"text": "別", "pos": "X"}, {"text": "叫", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "感激", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "藥水", "pos": "X"}, {"text": "色太", "pos": "X"}, {"text": "精美", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "迷魂記", "artists": ["王菲"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1175", "prev_line_id": null, "next_line_id": "lyr_546L6I-y_MTE3NQ_0002", "paragraph_id": "para_01"}}
{"id": "lyr_546L6I-y_MTE3NQ_0002", "text": "別要我喫出滋味 愉快得 知覺麻痹", "structure": {"line_index": 2, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 5, 4, 3, 3, 2, 0, 4, 3, 3, 4, 0, 4], "tone_pattern_cantonese_jyutping": ["bit6", "jiu3", "ngo5", "hek3", "ceot1", "zi1", "mei6", "jyu4", "faai3", "dak1", "zi1", "gok3", "maa4", "bei3"]}, "nlp": {"tokens": [{"text": "別要", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "喫", "pos": "X"}, {"text": "出", "pos": "X"}, {"text": "滋味", "pos": "X"}, {"text": "愉快", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "知覺", "pos": "X"}, {"text": "麻痹", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "迷魂記", "artists": ["王菲"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1175", "prev_line_id": "lyr_546L6I-y_MTE3NQ_0001", "next_line_id": "lyr_546L6I-y_MTE3NQ_0003", "paragraph_id": "para_01"}}
{"id": "lyr_546L6I-y_MTE3NQ_0003", "text": "爲什麼 呵護我 當我痊癒了 可喫什麼", "structure": {"line_index": 3, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 3, 3, 2, 5, 5, 0, 2, 5, 9, 4, 2, 3], "tone_pattern_cantonese_jyutping": ["sam6", "mo1", "ho1", "wu6", "ngo5", "ngo5", "cyun4", "jyu6", "liu5", "ho2", "hek3", "sam6", "mo1"]}, "nlp": {"tokens": [{"text": "爲什麼", "pos": "X"}, {"text": "呵護", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "當", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "痊癒", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "可", "pos": "X"}, {"text": "喫", "pos": "X"}, {"text": "什麼", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "迷魂記", "artists": ["王菲"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1175", "prev_line_id": "lyr_546L6I-y_MTE3NQ_0002", "next_line_id": "lyr_546L6I-y_MTE3NQ_0004", "paragraph_id": "para_01"}}
