{"id": "lyr_6YOR56eA5paH_MTU5Mg_0005", "text": "但是情無獨鍾 貪心的你偏愛哪一邊", "structure": {"line_index": 5, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 0, 0, 2, 3, 3, 3, 3, 5, 3, 4, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["daan6", "si6", "cing4", "mou4", "duk6", "zung1", "taam1", "sam1", "dik1", "nei5", "pin1", "oi3", "naa5", "jat1", "bin1"]}, "nlp": {"tokens": [{"text": "但是", "pos": "X"}, {"text": "情無", "pos": "X"}, {"text": "獨鍾", "pos": "X"}, {"text": "貪心", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "偏愛", "pos": "X"}, {"text": "哪", "pos": "X"}, {"text": "一邊", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "情無獨鍾", "artists": ["鄭秀文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1592", "prev_line_id": "lyr_6YOR56eA5paH_MTU5Mg_0004", "next_line_id": "lyr_6YOR56eA5paH_MTU5Mg_0006", "paragraph_id": "para_02"}}
