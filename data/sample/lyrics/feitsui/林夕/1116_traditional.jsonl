{"id": "lyr_546L6I-y_MTExNg_0001", "text": "當初 初給他的雙手抱我那一瞬", "structure": {"line_index": 1, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 3, 3, 3, 9, 5, 5, 5, 3, 4], "tone_pattern_cantonese_jyutping": ["co1", "co1", "kap1", "taa1", "dik1", "soeng1", "sau2", "pou5", "ngo5", "naa5", "jat1", "seon3"]}, "nlp": {"tokens": [{"text": "當初", "pos": "X"}, {"text": "初", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "雙手", "pos": "X"}, {"text": "抱", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "那", "pos": "X"}, {"text": "一瞬", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "多得他", "artists": ["王菲"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1116", "prev_line_id": null, "next_line_id": "lyr_546L6I-y_MTExNg_0002", "paragraph_id": "para_01"}}
