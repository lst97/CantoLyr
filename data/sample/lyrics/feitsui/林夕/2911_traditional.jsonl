{"id": "lyr_5Y2r5YWw_MjkxMQ_0015", "text": "叫我揀 寧願決絕 還是受罪也選擇有你", "structure": {"line_index": 15, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 5, 9, 0, 2, 4, 2, 0, 2, 2, 2, 5, 9, 2, 5, 5], "tone_pattern_cantonese_jyutping": ["giu3", "ngo5", "gaan2", "ning4", "jyun6", "kyut3", "zyut6", "waan4", "si6", "sau6", "zeoi6", "jaa5", "syun2", "zaak6", "jau5", "nei5"]}, "nlp": {"tokens": [{"text": "叫", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "揀", "pos": "X"}, {"text": "寧願", "pos": "X"}, {"text": "決絕", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "受罪", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "選擇", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0014", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0016", "paragraph_id": "para_04"}}
