{"id": "lyr_5Y2r5YWw_MjkxMQ_0004", "text": "單身不稱心 相戀傷透心", "structure": {"line_index": 4, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 3, 3, 9, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["daan1", "san1", "bat1", "cing1", "sam1", "lyun2", "soeng1", "tau3", "sam1"]}, "nlp": {"tokens": [{"text": "單身", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "稱心", "pos": "X"}, {"text": "相戀", "pos": "X"}, {"text": "傷透", "pos": "X"}, {"text": "心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0003", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5Y2r5YWw_MjkxMQ_0005", "text": "若最初 錯過你 那個我會 喜愛誰", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 3, 4, 4, 5, 5, 4, 5, 9, 4, 0], "tone_pattern_cantonese_jyutping": ["joek6", "zeoi3", "co1", "co3", "gwo3", "nei5", "naa5", "go3", "ngo5", "hei2", "oi3", "seoi4"]}, "nlp": {"tokens": [{"text": "若", "pos": "X"}, {"text": "最初", "pos": "X"}, {"text": "錯過", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "那個", "pos": "X"}, {"text": "我會", "pos": "X"}, {"text": "喜愛", "pos": "X"}, {"text": "誰", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0004", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2r5YWw_MjkxMQ_0006", "text": "平平靜靜還是比起今天更空虛", "structure": {"line_index": 6, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 2, 0, 2, 9, 9, 3, 3, 3, 3], "tone_pattern_cantonese_jyutping": ["ping4", "ping4", "zing6", "zing6", "waan4", "si6", "bei2", "hei2", "gam1", "tin1", "hung1", "heoi1"]}, "nlp": {"tokens": [{"text": "平平靜靜", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "比起", "pos": "X"}, {"text": "今天", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "空虛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0005", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2r5YWw_MjkxMQ_0007", "text": "甜甜蜜蜜地過活 還是幸運更快失去", "structure": {"line_index": 7, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 2, 2, 4, 2, 0, 2, 2, 2, 4, 3, 4], "tone_pattern_cantonese_jyutping": ["tim4", "tim4", "mat6", "mat6", "dei6", "gwo3", "wut6", "waan4", "si6", "hang6", "wan6", "faai3", "sat1", "heoi3"]}, "nlp": {"tokens": [{"text": "甜甜蜜蜜", "pos": "X"}, {"text": "地", "pos": "X"}, {"text": "過活", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "幸運", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "快", "pos": "X"}, {"text": "失去", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0006", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0008", "paragraph_id": "para_02"}}
