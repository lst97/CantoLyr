{"id": "lyr_5Y2r5YWw_MjkxMQ_0010", "text": "悔恨 亦全沒好處", "structure": {"line_index": 10, "char_count": 7}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 2, 0, 2, 9], "tone_pattern_cantonese_jyutping": ["fui3", "han6", "jik6", "cyun4", "mut6", "hou2"]}, "nlp": {"tokens": [{"text": "悔恨", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "全", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "好處", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0009", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0011", "paragraph_id": "para_03"}}
{"id": "lyr_5Y2r5YWw_MjkxMQ_0011", "text": "要是 全是多餘", "structure": {"line_index": 11, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 0, 2, 3, 0], "tone_pattern_cantonese_jyutping": ["jiu3", "si6", "cyun4", "si6", "do1", "jyu4"]}, "nlp": {"tokens": [{"text": "要是", "pos": "X"}, {"text": "全是", "pos": "X"}, {"text": "多餘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛沒有假如", "artists": ["衛蘭"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2911", "prev_line_id": "lyr_5Y2r5YWw_MjkxMQ_0010", "next_line_id": "lyr_5Y2r5YWw_MjkxMQ_0012", "paragraph_id": "para_03"}}
