{"id": "lyr_6ZmI5pmT5Lic_MTQwMw_0001", "text": "要震撼世界 惟有靠擾攘 孤單老虎 換來熱鬧欣賞", "structure": {"line_index": 1, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 4, 2, 4, 4, 0, 5, 4, 9, 5, 3, 3, 5, 9, 2, 0, 2, 2, 3, 9], "tone_pattern_cantonese_jyutping": ["jiu3", "zan3", "ham6", "sai3", "gaai3", "wai4", "jau5", "kaau3", "jiu2", "joeng5", "gu1", "daan1", "lou5", "fu2", "wun6", "loi4", "jit6", "naau6", "jan1", "soeng2"]}, "nlp": {"tokens": [{"text": "要", "pos": "X"}, {"text": "震撼", "pos": "X"}, {"text": "世界", "pos": "X"}, {"text": "惟有", "pos": "X"}, {"text": "靠", "pos": "X"}, {"text": "擾攘", "pos": "X"}, {"text": "孤單", "pos": "X"}, {"text": "老虎", "pos": "X"}, {"text": "換來", "pos": "X"}, {"text": "熱鬧", "pos": "X"}, {"text": "欣賞", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "娛樂無窮", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1403", "prev_line_id": null, "next_line_id": "lyr_6ZmI5pmT5Lic_MTQwMw_0002", "paragraph_id": "para_01"}}
