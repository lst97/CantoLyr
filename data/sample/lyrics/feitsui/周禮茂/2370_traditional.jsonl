{"id": "lyr_6Zu36aKC5b63_MjM3MA_0005", "text": "你願意體諒嗎 你願意忍耐嗎", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 9, 2, 3, 5, 2, 4, 9, 2, 3], "tone_pattern_cantonese_jyutping": ["nei5", "jyun6", "ji3", "tai2", "loeng6", "maa1", "nei5", "jyun6", "ji3", "jan2", "noi6", "maa1"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "願意", "pos": "X"}, {"text": "體諒", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "願意", "pos": "X"}, {"text": "忍耐", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "放棄世界", "artists": ["雷頌德"], "lyricists": ["周禮茂"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2370", "prev_line_id": "lyr_6Zu36aKC5b63_MjM3MA_0004", "next_line_id": "lyr_6Zu36aKC5b63_MjM3MA_0006", "paragraph_id": "para_02"}}
