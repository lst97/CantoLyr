{"id": "lyr_6YKT5Li95qyj_MjU5Ng_0004", "text": "要指責 或爭吵 也太可怕", "structure": {"line_index": 4, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 9, 4, 2, 3, 9, 5, 4, 9, 4], "tone_pattern_cantonese_jyutping": ["jiu3", "zi2", "zaak3", "waak6", "zang1", "caau2", "jaa5", "taai3", "ho2", "paa3"]}, "nlp": {"tokens": [{"text": "要", "pos": "X"}, {"text": "指責", "pos": "X"}, {"text": "或", "pos": "X"}, {"text": "爭吵", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "可怕", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分手的禮貌", "artists": ["鄧麗欣"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2596", "prev_line_id": "lyr_6YKT5Li95qyj_MjU5Ng_0003", "next_line_id": "lyr_6YKT5Li95qyj_MjU5Ng_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6YKT5Li95qyj_MjU5Ng_0005", "text": "我不需要點破 諾言如泡沫", "structure": {"line_index": 5, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 4, 9, 4, 2, 0, 0, 3, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "bat1", "seoi1", "jiu3", "dim2", "po3", "nok6", "jin4", "jyu4", "paau1", "mut3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "需要", "pos": "X"}, {"text": "點破", "pos": "X"}, {"text": "諾言", "pos": "X"}, {"text": "如", "pos": "X"}, {"text": "泡沫", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分手的禮貌", "artists": ["鄧麗欣"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2596", "prev_line_id": "lyr_6YKT5Li95qyj_MjU5Ng_0004", "next_line_id": "lyr_6YKT5Li95qyj_MjU5Ng_0006", "paragraph_id": "para_02"}}
