{"id": "lyr_6YKT5Li95qyj_MjU5Ng_0007", "text": "當初跟你好過 亦算得到愛護", "structure": {"line_index": 7, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 5, 9, 4, 2, 4, 3, 4, 4, 2], "tone_pattern_cantonese_jyutping": ["co1", "gan1", "nei5", "hou2", "gwo3", "jik6", "syun3", "dak1", "dou3", "oi3", "wu6"]}, "nlp": {"tokens": [{"text": "當初", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "你好", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "算", "pos": "X"}, {"text": "得到", "pos": "X"}, {"text": "愛護", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分手的禮貌", "artists": ["鄧麗欣"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2596", "prev_line_id": "lyr_6YKT5Li95qyj_MjU5Ng_0006", "next_line_id": "lyr_6YKT5Li95qyj_MjU5Ng_0008", "paragraph_id": "para_02"}}
