{"id": "lyr_6ZmI6IuR5reH_MjI3MQ_0007", "text": "然而你獨個先行加快了腳步", "structure": {"line_index": 7, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 5, 2, 4, 3, 0, 3, 4, 5, 4, 2], "tone_pattern_cantonese_jyutping": ["jin4", "ji4", "nei5", "duk6", "go3", "sin1", "hang4", "gaa1", "faai3", "liu5", "goek3", "bou6"]}, "nlp": {"tokens": [{"text": "然而", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "獨個", "pos": "X"}, {"text": "先行", "pos": "X"}, {"text": "加快", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "腳步", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "觸不到的戀人", "artists": ["陳苑淇"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2271", "prev_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0006", "next_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI6IuR5reH_MjI3MQ_0008", "text": "如從沒愛我 卻盼有個人待你好當作過渡", "structure": {"line_index": 8, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 4, 5, 4, 4, 5, 4, 0, 2, 5, 9, 4, 4, 2], "tone_pattern_cantonese_jyutping": ["jyu4", "cung4", "mut6", "oi3", "ngo5", "koek3", "paan3", "jau5", "go3", "jan4", "doi6", "nei5", "hou2", "zok3", "gwo3", "dou6"]}, "nlp": {"tokens": [{"text": "如", "pos": "X"}, {"text": "從沒", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "盼", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "個人", "pos": "X"}, {"text": "待", "pos": "X"}, {"text": "你好", "pos": "X"}, {"text": "當作", "pos": "X"}, {"text": "過渡", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "觸不到的戀人", "artists": ["陳苑淇"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2271", "prev_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0007", "next_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0009", "paragraph_id": "para_02"}}
