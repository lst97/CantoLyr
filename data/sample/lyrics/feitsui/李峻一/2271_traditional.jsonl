{"id": "lyr_6ZmI6IuR5reH_MjI3MQ_0003", "text": "如何苦心編輯短訊講掛念你", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 9, 3, 3, 3, 9, 4, 9, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["jyu4", "ho4", "fu2", "sam1", "pin1", "cap1", "dyun2", "seon3", "gong2", "gwaa3", "nim6", "nei5"]}, "nlp": {"tokens": [{"text": "如何", "pos": "X"}, {"text": "苦心", "pos": "X"}, {"text": "編輯", "pos": "X"}, {"text": "短訊", "pos": "X"}, {"text": "講", "pos": "X"}, {"text": "掛念", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "觸不到的戀人", "artists": ["陳苑淇"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2271", "prev_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0002", "next_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI6IuR5reH_MjI3MQ_0004", "text": "卻知你看一半便已俏俏洗清 總不想儲起", "structure": {"line_index": 4, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 3, 5, 4, 3, 4, 2, 5, 4, 4, 9, 3, 9, 3, 9, 5, 9], "tone_pattern_cantonese_jyutping": ["koek3", "zi1", "nei5", "hon3", "jat1", "bun3", "bin6", "ji5", "ciu3", "ciu3", "sai2", "cing1", "zung2", "bat1", "soeng2", "cyu5", "hei2"]}, "nlp": {"tokens": [{"text": "卻知", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "看", "pos": "X"}, {"text": "一半", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "已", "pos": "X"}, {"text": "俏俏", "pos": "X"}, {"text": "洗清", "pos": "X"}, {"text": "總", "pos": "X"}, {"text": "不想", "pos": "X"}, {"text": "儲起", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "觸不到的戀人", "artists": ["陳苑淇"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2271", "prev_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0003", "next_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI6IuR5reH_MjI3MQ_0005", "text": "望你見天氣漸凍", "structure": {"line_index": 5, "char_count": 7}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 4, 3, 4, 2, 4], "tone_pattern_cantonese_jyutping": ["mong6", "nei5", "gin3", "tin1", "hei3", "zim6", "dung3"]}, "nlp": {"tokens": [{"text": "望", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "見", "pos": "X"}, {"text": "天氣", "pos": "X"}, {"text": "漸凍", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "觸不到的戀人", "artists": ["陳苑淇"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2271", "prev_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0004", "next_line_id": "lyr_6ZmI6IuR5reH_MjI3MQ_0006", "paragraph_id": "para_02"}}
