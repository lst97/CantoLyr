{"id": "lyr_5p2O5bm45YCq_NjY3Nw_0003", "text": "當好友 是情敵 怎麼過", "structure": {"line_index": 3, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 5, 2, 0, 2, 9, 3, 4], "tone_pattern_cantonese_jyutping": ["hou2", "jau5", "si6", "cing4", "dik6", "zam2", "mo1", "gwo3"]}, "nlp": {"tokens": [{"text": "當", "pos": "X"}, {"text": "好友", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "情敵", "pos": "X"}, {"text": "怎麼", "pos": "X"}, {"text": "過", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "好姊妹", "artists": ["李幸倪"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6677", "prev_line_id": "lyr_5p2O5bm45YCq_NjY3Nw_0002", "next_line_id": "lyr_5p2O5bm45YCq_NjY3Nw_0004", "paragraph_id": "para_01"}}
