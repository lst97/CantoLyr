{"id": "lyr_5pa55Yqb55Sz_MzE0Mg_0006", "text": "令我領悟到結果一個 非走不可", "structure": {"line_index": 6, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 5, 2, 4, 4, 9, 3, 4, 3, 9, 3, 9], "tone_pattern_cantonese_jyutping": ["ling6", "ngo5", "ling5", "ng6", "dou3", "git3", "gwo2", "jat1", "go3", "fei1", "zau2", "bat1", "ho2"]}, "nlp": {"tokens": [{"text": "令", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "領悟到", "pos": "X"}, {"text": "結果", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "非走不可", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "教我聽情歌", "artists": ["方力申"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3142", "prev_line_id": "lyr_5pa55Yqb55Sz_MzE0Mg_0005", "next_line_id": "lyr_5pa55Yqb55Sz_MzE0Mg_0007", "paragraph_id": "para_01"}}
{"id": "lyr_5pa55Yqb55Sz_MzE0Mg_0007", "text": "情歌十一分了解我(感動歌最好播)", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 2, 3, 3, 0, 9, 5, 2, 3, 4, 9], "tone_pattern_cantonese_jyutping": ["cing4", "go1", "sap6", "jat1", "fan1", "liu4", "gaai2", "ngo5", "dung6", "go1", "zeoi3", "hou2"]}, "nlp": {"tokens": [{"text": "情歌", "pos": "X"}, {"text": "十一分", "pos": "X"}, {"text": "瞭解", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "(", "pos": "X"}, {"text": "感動", "pos": "X"}, {"text": "歌", "pos": "X"}, {"text": "最好", "pos": "X"}, {"text": "播", "pos": "X"}, {"text": ")", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "教我聽情歌", "artists": ["方力申"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3142", "prev_line_id": "lyr_5pa55Yqb55Sz_MzE0Mg_0006", "next_line_id": "lyr_5pa55Yqb55Sz_MzE0Mg_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5pa55Yqb55Sz_MzE0Mg_0008", "text": "原來比你更加體恤我 捱到要命", "structure": {"line_index": 8, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 9, 5, 3, 9, 3, 5, 0, 4, 4, 2], "tone_pattern_cantonese_jyutping": ["jyun4", "loi4", "bei2", "nei5", "gaa1", "tai2", "seot1", "ngo5", "ngaai4", "dou3", "jiu3", "ming6"]}, "nlp": {"tokens": [{"text": "原來", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "更加", "pos": "X"}, {"text": "體恤", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "捱到", "pos": "X"}, {"text": "要命", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "教我聽情歌", "artists": ["方力申"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3142", "prev_line_id": "lyr_5pa55Yqb55Sz_MzE0Mg_0007", "next_line_id": "lyr_5pa55Yqb55Sz_MzE0Mg_0009", "paragraph_id": "para_02"}}
