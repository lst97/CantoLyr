{"id": "lyr_6K645b-X5a6J_Njg2MQ_0001", "text": "當 木劍跟水槍指着我", "structure": {"line_index": 1, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 3, 9, 3, 9, 2, 5], "tone_pattern_cantonese_jyutping": ["muk6", "gim3", "gan1", "seoi2", "coeng1", "zi2", "zoek6", "ngo5"]}, "nlp": {"tokens": [{"text": "當", "pos": "X"}, {"text": "木劍", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "水槍", "pos": "X"}, {"text": "指着", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": null, "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0002", "paragraph_id": "para_01"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0002", "text": "當天我 還在笑 因爲你未 捉到我", "structure": {"line_index": 2, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 5, 0, 2, 4, 3, 5, 2, 3, 4, 5], "tone_pattern_cantonese_jyutping": ["tin1", "ngo5", "waan4", "zoi6", "siu3", "jan1", "nei5", "mei6", "zuk1", "dou3", "ngo5"]}, "nlp": {"tokens": [{"text": "當天", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "還", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "因爲", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "未", "pos": "X"}, {"text": "捉到", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0001", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0003", "text": "但這天 換了真大炮那同伴不肯言和", "structure": {"line_index": 3, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 3, 2, 5, 3, 2, 4, 5, 0, 2, 3, 9, 0, 0], "tone_pattern_cantonese_jyutping": ["daan6", "ze5", "tin1", "wun6", "liu5", "zan1", "daai6", "paau3", "naa5", "tung4", "bun6", "bat1", "hang2", "jin4", "wo4"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "這天", "pos": "X"}, {"text": "換", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "真", "pos": "X"}, {"text": "大炮", "pos": "X"}, {"text": "那", "pos": "X"}, {"text": "同伴", "pos": "X"}, {"text": "不肯", "pos": "X"}, {"text": "言", "pos": "X"}, {"text": "和", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0002", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0004", "text": "爲何人人大了無人來提示我想玩什麼", "structure": {"line_index": 4, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 2, 5, 0, 0, 0, 0, 2, 5, 9, 9, 2, 3], "tone_pattern_cantonese_jyutping": ["ho4", "jan4", "jan4", "daai6", "liu5", "mou4", "jan4", "loi4", "tai4", "si6", "ngo5", "soeng2", "waan2", "sam6", "mo1"]}, "nlp": {"tokens": [{"text": "爲何", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "人大", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "無人", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "提示", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "玩", "pos": "X"}, {"text": "什麼", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0003", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0005", "text": "當天只有六歲 因此你共我", "structure": {"line_index": 5, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 5, 2, 4, 3, 9, 5, 2, 5], "tone_pattern_cantonese_jyutping": ["tin1", "zi2", "jau5", "luk6", "seoi3", "jan1", "ci2", "nei5", "gung6", "ngo5"]}, "nlp": {"tokens": [{"text": "當天", "pos": "X"}, {"text": "只有", "pos": "X"}, {"text": "六歲", "pos": "X"}, {"text": "因此", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "共", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0004", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0006", "paragraph_id": "para_02"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0006", "text": "愛共誰 遊玩 不必想太多", "structure": {"line_index": 6, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 0, 0, 9, 3, 3, 9, 4, 3], "tone_pattern_cantonese_jyutping": ["oi3", "gung6", "seoi4", "jau4", "waan2", "bat1", "bit1", "soeng2", "taai3", "do1"]}, "nlp": {"tokens": [{"text": "愛共", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "遊玩", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "想太多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0005", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0007", "text": "看現在他 不跟我玩了", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 2, 3, 3, 3, 5, 9, 5], "tone_pattern_cantonese_jyutping": ["hon3", "jin6", "zoi6", "taa1", "bat1", "gan1", "ngo5", "waan2", "liu5"]}, "nlp": {"tokens": [{"text": "看", "pos": "X"}, {"text": "現在", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "玩", "pos": "X"}, {"text": "了", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0006", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0008", "text": "我太悶 還是波子不夠多", "structure": {"line_index": 8, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 2, 0, 2, 3, 9, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "taai3", "mun6", "waan4", "si6", "bo1", "zi2", "bat1", "gau3", "do1"]}, "nlp": {"tokens": [{"text": "我太悶", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "波子", "pos": "X"}, {"text": "不夠", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0007", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0009", "paragraph_id": "para_02"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0009", "text": "我看着大風吹 你在哪裏", "structure": {"line_index": 9, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 2, 2, 3, 3, 5, 2, 5, 5], "tone_pattern_cantonese_jyutping": ["ngo5", "hon3", "zoek6", "daai6", "fung1", "ceoi1", "nei5", "zoi6", "naa5", "leoi5"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "看着", "pos": "X"}, {"text": "大風", "pos": "X"}, {"text": "吹", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "哪裏", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0008", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0010", "paragraph_id": "para_03"}}
{"id": "lyr_6K645b-X5a6J_Njg2MQ_0010", "text": "困於 這變大身軀裏", "structure": {"line_index": 10, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 3, 5, 4, 2, 3, 3, 5], "tone_pattern_cantonese_jyutping": ["kwan3", "jyu1", "ze5", "bin3", "daai6", "san1", "keoi1", "leoi5"]}, "nlp": {"tokens": [{"text": "困於", "pos": "X"}, {"text": "這變", "pos": "X"}, {"text": "大", "pos": "X"}, {"text": "身軀", "pos": "X"}, {"text": "裏", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0009", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0011", "paragraph_id": "para_03"}}
