{"id": "lyr_6K645b-X5a6J_Njg2MQ_0016", "text": "此際我世界尚有誰 有亦太無趣", "structure": {"line_index": 16, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 5, 4, 4, 2, 5, 0, 5, 2, 4, 0, 4], "tone_pattern_cantonese_jyutping": ["ci2", "zai3", "ngo5", "sai3", "gaai3", "soeng6", "jau5", "seoi4", "jau5", "jik6", "taai3", "mou4", "ceoi3"]}, "nlp": {"tokens": [{"text": "此際", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "世界", "pos": "X"}, {"text": "尚有", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "無趣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "大風吹", "artists": ["許志安"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6861", "prev_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0015", "next_line_id": "lyr_6K645b-X5a6J_Njg2MQ_0017", "paragraph_id": "para_04"}}
