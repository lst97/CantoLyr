{"id": "lyr_6bqm5rWa6b6Z_NjY4OQ_0007", "text": "可否想也不想 馬上戀上 不必舉世讚賞", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 9, 5, 3, 9, 5, 9, 3, 3, 9, 4, 4, 9], "tone_pattern_cantonese_jyutping": ["ho2", "fau2", "soeng2", "jaa5", "bat1", "soeng2", "maa5", "lyun2", "bat1", "bit1", "geoi2", "sai3", "zaan3", "soeng2"]}, "nlp": {"tokens": [{"text": "可否", "pos": "X"}, {"text": "想也不想", "pos": "X"}, {"text": "馬上", "pos": "X"}, {"text": "戀上", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "舉世", "pos": "X"}, {"text": "讚賞", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "紙箱國", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6689", "prev_line_id": "lyr_6bqm5rWa6b6Z_NjY4OQ_0006", "next_line_id": "lyr_6bqm5rWa6b6Z_NjY4OQ_0008", "paragraph_id": "para_02"}}
