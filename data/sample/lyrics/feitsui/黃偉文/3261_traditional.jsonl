{"id": "lyr_5Y-k5beo5Z-6_MzI2MQ_0004", "text": "如果不想說話 唱一首歌好嗎", "structure": {"line_index": 4, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 3, 9, 4, 2, 4, 3, 9, 3, 9, 3], "tone_pattern_cantonese_jyutping": ["jyu4", "gwo2", "bat1", "soeng2", "syut3", "waa6", "coeng3", "jat1", "sau2", "go1", "hou2", "maa1"]}, "nlp": {"tokens": [{"text": "如果", "pos": "X"}, {"text": "不想", "pos": "X"}, {"text": "說話", "pos": "X"}, {"text": "唱", "pos": "X"}, {"text": "一首歌", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我對門匙說", "artists": ["古巨基"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3261", "prev_line_id": "lyr_5Y-k5beo5Z-6_MzI2MQ_0003", "next_line_id": "lyr_5Y-k5beo5Z-6_MzI2MQ_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5Y-k5beo5Z-6_MzI2MQ_0005", "text": "來跟我合唱吧 總不太差", "structure": {"line_index": 5, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 5, 2, 4, 2, 9, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["loi4", "gan1", "ngo5", "hap6", "coeng3", "baa6", "zung2", "bat1", "taai3", "caa1"]}, "nlp": {"tokens": [{"text": "來", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "合唱", "pos": "X"}, {"text": "吧", "pos": "X"}, {"text": "總不太差", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我對門匙說", "artists": ["古巨基"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3261", "prev_line_id": "lyr_5Y-k5beo5Z-6_MzI2MQ_0004", "next_line_id": "lyr_5Y-k5beo5Z-6_MzI2MQ_0006", "paragraph_id": "para_01"}}
