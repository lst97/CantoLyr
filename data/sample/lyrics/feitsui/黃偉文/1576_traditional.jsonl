{"id": "lyr_6YOR56eA5paH_MTU3Ng_0006", "text": "很簡單的故事但我唱不厭 也跳不完", "structure": {"line_index": 6, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 3, 3, 4, 2, 2, 5, 4, 3, 4, 5, 4, 3, 0], "tone_pattern_cantonese_jyutping": ["han2", "gaan2", "daan1", "dik1", "gu3", "si6", "daan6", "ngo5", "coeng3", "bat1", "jim3", "jaa5", "tiu3", "bat1", "jyun4"]}, "nlp": {"tokens": [{"text": "很", "pos": "X"}, {"text": "簡單", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "故事", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "唱", "pos": "X"}, {"text": "不厭", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "跳", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "完", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "仙樂都", "artists": ["鄭秀文"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1576", "prev_line_id": "lyr_6YOR56eA5paH_MTU3Ng_0005", "next_line_id": "lyr_6YOR56eA5paH_MTU3Ng_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6YOR56eA5paH_MTU3Ng_0007", "text": "我找到 我的仙樂都 古董當寶", "structure": {"line_index": 7, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 4, 5, 3, 3, 2, 3, 9, 9, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "zaau2", "dou3", "ngo5", "dik1", "sin1", "lok6", "dou1", "gu2", "dung2", "bou2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "找到", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "仙樂", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "古董", "pos": "X"}, {"text": "當寶", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "仙樂都", "artists": ["鄭秀文"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1576", "prev_line_id": "lyr_6YOR56eA5paH_MTU3Ng_0006", "next_line_id": "lyr_6YOR56eA5paH_MTU3Ng_0008", "paragraph_id": "para_03"}}
