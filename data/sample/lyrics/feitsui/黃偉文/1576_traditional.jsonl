{"id": "lyr_6YOR56eA5paH_MTU3Ng_0009", "text": "煩什麼 總有歌舞代勞 浮誇都美好", "structure": {"line_index": 9, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 3, 9, 5, 3, 5, 2, 0, 0, 3, 3, 5, 9], "tone_pattern_cantonese_jyutping": ["faan4", "sam6", "mo1", "zung2", "jau5", "go1", "mou5", "doi6", "lou4", "fau4", "kwaa1", "dou1", "mei5", "hou2"]}, "nlp": {"tokens": [{"text": "煩", "pos": "X"}, {"text": "什麼", "pos": "X"}, {"text": "總有", "pos": "X"}, {"text": "歌舞", "pos": "X"}, {"text": "代勞", "pos": "X"}, {"text": "浮誇", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "美好", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "仙樂都", "artists": ["鄭秀文"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1576", "prev_line_id": "lyr_6YOR56eA5paH_MTU3Ng_0008", "next_line_id": "lyr_6YOR56eA5paH_MTU3Ng_0010", "paragraph_id": "para_04"}}
