{"id": "lyr_SG8_MjE3_0007", "text": "分開簡單 抹去往事極難 幾多溫馨 燭光晚餐", "structure": {"line_index": 7, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 9, 3, 4, 4, 5, 2, 2, 0, 9, 3, 3, 3, 3, 3, 5, 3], "tone_pattern_cantonese_jyutping": ["fan1", "hoi1", "gaan2", "daan1", "mut3", "heoi3", "wong5", "si6", "gik6", "naan4", "gei2", "do1", "wan1", "hing1", "zuk1", "gwong1", "maan5", "caan1"]}, "nlp": {"tokens": [{"text": "分開", "pos": "X"}, {"text": "簡單", "pos": "X"}, {"text": "抹", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "往事", "pos": "X"}, {"text": "極難", "pos": "X"}, {"text": "幾多", "pos": "X"}, {"text": "溫馨", "pos": "X"}, {"text": "燭光", "pos": "X"}, {"text": "晚餐", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "木紋", "artists": ["Ho"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_217", "prev_line_id": "lyr_SG8_MjE3_0006", "next_line_id": "lyr_SG8_MjE3_0008", "paragraph_id": "para_03"}}
