{"id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0026", "text": "再踏前 要是難避免 看見了牛頭馬面", "structure": {"line_index": 26, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 0, 4, 2, 0, 2, 5, 4, 4, 5, 0, 0, 5, 2], "tone_pattern_cantonese_jyutping": ["zoi3", "daap6", "cin4", "jiu3", "si6", "naan4", "bei6", "min5", "hon3", "gin3", "liu5", "ngau4", "tau4", "maa5", "min6"]}, "nlp": {"tokens": [{"text": "再踏前", "pos": "X"}, {"text": "要是", "pos": "X"}, {"text": "難", "pos": "X"}, {"text": "避免", "pos": "X"}, {"text": "看見", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "牛頭馬面", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "濛", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3490", "prev_line_id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0025", "next_line_id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0027", "paragraph_id": "para_06"}}
