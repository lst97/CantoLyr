{"id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0023", "text": "平凡人亦可輕易被神化", "structure": {"line_index": 23, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 2, 9, 3, 2, 2, 0, 4], "tone_pattern_cantonese_jyutping": ["ping4", "faan4", "jan4", "jik6", "ho2", "hing1", "ji6", "bei6", "san4", "faa3"]}, "nlp": {"tokens": [{"text": "平凡人", "pos": "X"}, {"text": "亦可", "pos": "X"}, {"text": "輕易", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "神化", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "濛", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3490", "prev_line_id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0022", "next_line_id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0024", "paragraph_id": "para_05"}}
{"id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0024", "text": "情願靠幻覺 捏造幸福之戀 真的穿了再算", "structure": {"line_index": 24, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 2, 4, 2, 2, 2, 3, 3, 9, 3, 3, 3, 5, 4, 4], "tone_pattern_cantonese_jyutping": ["cing4", "jyun6", "kaau3", "waan6", "gok3", "nip6", "zou6", "hang6", "fuk1", "zi1", "lyun2", "zan1", "dik1", "cyun1", "liu5", "zoi3", "syun3"]}, "nlp": {"tokens": [{"text": "情願", "pos": "X"}, {"text": "靠", "pos": "X"}, {"text": "幻覺", "pos": "X"}, {"text": "捏造", "pos": "X"}, {"text": "幸福", "pos": "X"}, {"text": "之戀", "pos": "X"}, {"text": "真的", "pos": "X"}, {"text": "穿", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "算", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "濛", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3490", "prev_line_id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0023", "next_line_id": "lyr_6bqm5rWa6b6Z_MzQ5MA_0025", "paragraph_id": "para_06"}}
