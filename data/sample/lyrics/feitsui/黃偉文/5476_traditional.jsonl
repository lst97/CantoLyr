{"id": "lyr_6YOR5qyj5a6c_NTQ3Ng_0019", "text": "往事濃縮於三分鐘 若不會亂碼", "structure": {"line_index": 19, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 3, 3, 3, 3, 3, 2, 3, 2, 5], "tone_pattern_cantonese_jyutping": ["wong5", "si6", "nung4", "suk1", "jyu1", "saam1", "fan1", "zung1", "joek6", "bat1", "lyun6", "maa5"]}, "nlp": {"tokens": [{"text": "往事", "pos": "X"}, {"text": "濃縮", "pos": "X"}, {"text": "於", "pos": "X"}, {"text": "三分鐘", "pos": "X"}, {"text": "若", "pos": "X"}, {"text": "不會", "pos": "X"}, {"text": "亂碼", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "懶人包", "artists": ["鄭欣宜"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5476", "prev_line_id": "lyr_6YOR5qyj5a6c_NTQ3Ng_0018", "next_line_id": "lyr_6YOR5qyj5a6c_NTQ3Ng_0020", "paragraph_id": "para_06"}}
