{"id": "lyr_6YOR5qyj5a6c_NTQ3Ng_0005", "text": "太熱時乾一杯啤酒 便很快樂嗎", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 0, 3, 3, 3, 3, 9, 2, 9, 4, 2, 3], "tone_pattern_cantonese_jyutping": ["taai3", "jit6", "si4", "gon1", "jat1", "bui1", "be1", "zau2", "bin6", "han2", "faai3", "lok6", "maa1"]}, "nlp": {"tokens": [{"text": "太熱時", "pos": "X"}, {"text": "幹", "pos": "X"}, {"text": "一杯", "pos": "X"}, {"text": "啤酒", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "快樂", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "懶人包", "artists": ["鄭欣宜"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5476", "prev_line_id": "lyr_6YOR5qyj5a6c_NTQ3Ng_0004", "next_line_id": "lyr_6YOR5qyj5a6c_NTQ3Ng_0006", "paragraph_id": "para_02"}}
