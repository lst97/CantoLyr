{"id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0019", "text": "過去的春季 無謂昐 昐天使爲我下凡", "structure": {"line_index": 19, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 4, 3, 3, 4, 0, 2, 9, 5, 2, 0], "tone_pattern_cantonese_jyutping": ["gwo3", "heoi3", "dik1", "ceon1", "gwai3", "mou4", "wai6", "si2", "ngo5", "haa6", "faan4"]}, "nlp": {"tokens": [{"text": "過去", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "春季", "pos": "X"}, {"text": "無謂", "pos": "X"}, {"text": "昐", "pos": "X"}, {"text": "昐", "pos": "X"}, {"text": "天使", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "下凡", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "命犯桃花", "artists": ["盧巧音"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1547", "prev_line_id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0018", "next_line_id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0020", "paragraph_id": "para_04"}}
{"id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0020", "text": "延長能盛開的時間 多芬芳 半個夜晚", "structure": {"line_index": 20, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 3, 3, 0, 3, 3, 3, 4, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["jin4", "coeng4", "nang4", "sing4", "hoi1", "dik1", "si4", "do1", "fan1", "fong1", "bun3", "go3", "je6", "maan5"]}, "nlp": {"tokens": [{"text": "延長", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "盛開", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "時間", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "芬芳", "pos": "X"}, {"text": "半個", "pos": "X"}, {"text": "夜晚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "命犯桃花", "artists": ["盧巧音"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1547", "prev_line_id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0019", "next_line_id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0021", "paragraph_id": "para_04"}}
{"id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0021", "text": "脆弱像蘭花 快謝像曇花", "structure": {"line_index": 21, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 2, 0, 3, 4, 2, 2, 0, 3], "tone_pattern_cantonese_jyutping": ["ceoi3", "joek6", "zoeng6", "laan4", "faa1", "faai3", "ze6", "zoeng6", "taam4", "faa1"]}, "nlp": {"tokens": [{"text": "脆弱", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "蘭花", "pos": "X"}, {"text": "快謝", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "曇花", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "命犯桃花", "artists": ["盧巧音"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1547", "prev_line_id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0020", "next_line_id": "lyr_5Y2i5ben6Z-z_MTU0Nw_0022", "paragraph_id": "para_05"}}
