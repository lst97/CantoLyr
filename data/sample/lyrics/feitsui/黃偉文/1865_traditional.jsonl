{"id": "lyr_SG8_MTg2NQ_0023", "text": "就算他 在這刻拉走我 抱憾也不多", "structure": {"line_index": 23, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 3, 2, 5, 3, 3, 9, 5, 5, 2, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["zau6", "syun3", "taa1", "zoi6", "ze5", "hak1", "laai1", "zau2", "ngo5", "pou5", "ham6", "jaa5", "bat1", "do1"]}, "nlp": {"tokens": [{"text": "就算", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "這刻", "pos": "X"}, {"text": "拉走", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "抱憾", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "夜半敲門", "artists": ["Ho"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1865", "prev_line_id": "lyr_SG8_MTg2NQ_0022", "next_line_id": "lyr_SG8_MTg2NQ_0024", "paragraph_id": "para_05"}}
