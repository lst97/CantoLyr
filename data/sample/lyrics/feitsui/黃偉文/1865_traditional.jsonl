{"id": "lyr_SG8_MTg2NQ_0026", "text": "難逃過這一關 仍然未覺孤單", "structure": {"line_index": 26, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 4, 5, 3, 3, 0, 0, 2, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["naan4", "tou4", "gwo3", "ze5", "jat1", "gwaan1", "jing4", "jin4", "mei6", "gok3", "gu1", "daan1"]}, "nlp": {"tokens": [{"text": "難逃", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "這一關", "pos": "X"}, {"text": "仍然", "pos": "X"}, {"text": "未覺", "pos": "X"}, {"text": "孤單", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "夜半敲門", "artists": ["Ho"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1865", "prev_line_id": "lyr_SG8_MTg2NQ_0025", "next_line_id": "lyr_SG8_MTg2NQ_0027", "paragraph_id": "para_06"}}
{"id": "lyr_SG8_MTg2NQ_0027", "text": "因爲我 就算 沒時間", "structure": {"line_index": 27, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 5, 2, 4, 2, 0], "tone_pattern_cantonese_jyutping": ["jan1", "ngo5", "zau6", "syun3", "mut6", "si4"]}, "nlp": {"tokens": [{"text": "因爲", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "就算", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "時間", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "夜半敲門", "artists": ["Ho"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1865", "prev_line_id": "lyr_SG8_MTg2NQ_0026", "next_line_id": "lyr_SG8_MTg2NQ_0028", "paragraph_id": "para_06"}}
