{"id": "lyr_6buO5piO_MjI0MA_0001", "text": "你大概猜錯 我也許喜歡戀愛卻未曾 有許多個", "structure": {"line_index": 1, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 3, 4, 5, 5, 9, 9, 3, 9, 4, 4, 2, 0, 5, 9, 3, 4], "tone_pattern_cantonese_jyutping": ["nei5", "daai6", "koi3", "caai1", "co3", "ngo5", "jaa5", "heoi2", "hei2", "fun1", "lyun2", "oi3", "koek3", "mei6", "cang4", "jau5", "heoi2", "do1", "go3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "大概", "pos": "X"}, {"text": "猜錯", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "也許", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "戀愛", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "未曾", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "許多", "pos": "X"}, {"text": "個", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": null, "next_line_id": "lyr_6buO5piO_MjI0MA_0002", "paragraph_id": "para_01"}}
{"id": "lyr_6buO5piO_MjI0MA_0002", "text": "若愛人百個 像你們看我 誰敢喜歡我", "structure": {"line_index": 2, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 0, 4, 4, 2, 5, 0, 4, 5, 0, 9, 9, 3, 5], "tone_pattern_cantonese_jyutping": ["joek6", "oi3", "jan4", "baak3", "go3", "zoeng6", "nei5", "mun4", "hon3", "ngo5", "seoi4", "gam2", "hei2", "fun1", "ngo5"]}, "nlp": {"tokens": [{"text": "若", "pos": "X"}, {"text": "愛人", "pos": "X"}, {"text": "百個", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "你們", "pos": "X"}, {"text": "看", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "敢", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0001", "next_line_id": "lyr_6buO5piO_MjI0MA_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6buO5piO_MjI0MA_0003", "text": "遇上的 就算多 停下過 未算多", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 3, 2, 4, 3, 0, 2, 4, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["jyu6", "dik1", "zau6", "syun3", "do1", "ting4", "haa6", "gwo3", "mei6", "syun3", "do1"]}, "nlp": {"tokens": [{"text": "遇上", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "就算", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "停下", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "未算", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0002", "next_line_id": "lyr_6buO5piO_MjI0MA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6buO5piO_MjI0MA_0004", "text": "要是誰來 都想愛愛 統統亦是未夠愛", "structure": {"line_index": 4, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 0, 0, 3, 9, 4, 4, 9, 9, 2, 2, 2, 4, 4], "tone_pattern_cantonese_jyutping": ["jiu3", "si6", "seoi4", "loi4", "dou1", "soeng2", "oi3", "oi3", "tung2", "tung2", "jik6", "si6", "mei6", "gau3", "oi3"]}, "nlp": {"tokens": [{"text": "要是", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "統統", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "未夠", "pos": "X"}, {"text": "愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0003", "next_line_id": "lyr_6buO5piO_MjI0MA_0005", "paragraph_id": "para_02"}}
{"id": "lyr_6buO5piO_MjI0MA_0005", "text": "我大門長年不開 只想一開前面有將來", "structure": {"line_index": 5, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 0, 0, 3, 3, 9, 9, 3, 3, 0, 2, 5, 3, 0], "tone_pattern_cantonese_jyutping": ["ngo5", "daai6", "mun4", "coeng4", "nin4", "bat1", "hoi1", "zi2", "soeng2", "jat1", "hoi1", "cin4", "min6", "jau5", "zoeng1", "loi4"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "大門", "pos": "X"}, {"text": "長年", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "開", "pos": "X"}, {"text": "只想", "pos": "X"}, {"text": "一開", "pos": "X"}, {"text": "前面", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "將來", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0004", "next_line_id": "lyr_6buO5piO_MjI0MA_0006", "paragraph_id": "para_02"}}
{"id": "lyr_6buO5piO_MjI0MA_0006", "text": "情人不算多 但都深愛過 志在投入 並非貪滿座", "structure": {"line_index": 6, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 4, 3, 2, 3, 3, 4, 4, 4, 2, 0, 2, 2, 3, 3, 5, 2], "tone_pattern_cantonese_jyutping": ["cing4", "jan4", "bat1", "syun3", "do1", "daan6", "dou1", "sam1", "oi3", "gwo3", "zi3", "zoi6", "tau4", "jap6", "bing6", "fei1", "taam1", "mun5", "zo6"]}, "nlp": {"tokens": [{"text": "情人", "pos": "X"}, {"text": "不算", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "深愛", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "志在", "pos": "X"}, {"text": "投入", "pos": "X"}, {"text": "並非", "pos": "X"}, {"text": "貪", "pos": "X"}, {"text": "滿座", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0005", "next_line_id": "lyr_6buO5piO_MjI0MA_0007", "paragraph_id": "para_03"}}
{"id": "lyr_6buO5piO_MjI0MA_0007", "text": "看 世上最好幾個 亦曾爲我閃亮過花火", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 4, 4, 9, 9, 4, 2, 0, 5, 9, 2, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["hon3", "sai3", "zeoi3", "hou2", "gei2", "go3", "jik6", "cang4", "ngo5", "sim2", "loeng6", "gwo3", "faa1", "fo2"]}, "nlp": {"tokens": [{"text": "看", "pos": "X"}, {"text": "世上", "pos": "X"}, {"text": "最", "pos": "X"}, {"text": "好幾個", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "閃亮", "pos": "X"}, {"text": "過花火", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0006", "next_line_id": "lyr_6buO5piO_MjI0MA_0008", "paragraph_id": "para_03"}}
{"id": "lyr_6buO5piO_MjI0MA_0008", "text": "情人不要多 但畢竟每個 厚度濃度 值得畢生慶賀", "structure": {"line_index": 8, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 4, 3, 2, 3, 9, 5, 4, 5, 2, 0, 2, 2, 3, 3, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["cing4", "jan4", "bat1", "jiu3", "do1", "daan6", "bat1", "ging2", "mui5", "go3", "hau5", "dou6", "nung4", "dou6", "zik6", "dak1", "bat1", "sang1", "hing3", "ho6"]}, "nlp": {"tokens": [{"text": "情人", "pos": "X"}, {"text": "不要", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "畢竟", "pos": "X"}, {"text": "每個", "pos": "X"}, {"text": "厚度", "pos": "X"}, {"text": "濃度", "pos": "X"}, {"text": "值得", "pos": "X"}, {"text": "畢生", "pos": "X"}, {"text": "慶賀", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0007", "next_line_id": "lyr_6buO5piO_MjI0MA_0009", "paragraph_id": "para_03"}}
{"id": "lyr_6buO5piO_MjI0MA_0009", "text": "名字太少 就是從未耀眼似星河 仍然有精彩地發生過", "structure": {"line_index": 9, "char_count": 22}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 2, 2, 0, 2, 2, 5, 5, 3, 0, 0, 0, 5, 3, 9, 2, 4, 3, 4], "tone_pattern_cantonese_jyutping": ["ming4", "zi6", "taai3", "zau6", "si6", "cung4", "mei6", "jiu6", "ngaan5", "ci5", "sing1", "ho4", "jing4", "jin4", "jau5", "zing1", "coi2", "dei6", "faat3", "sang1", "gwo3"]}, "nlp": {"tokens": [{"text": "名字", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "少", "pos": "X"}, {"text": "就是", "pos": "X"}, {"text": "從未", "pos": "X"}, {"text": "耀眼", "pos": "X"}, {"text": "似", "pos": "X"}, {"text": "星河", "pos": "X"}, {"text": "仍然", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "精彩", "pos": "X"}, {"text": "地", "pos": "X"}, {"text": "發生", "pos": "X"}, {"text": "過", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0008", "next_line_id": "lyr_6buO5piO_MjI0MA_0010", "paragraph_id": "para_03"}}
{"id": "lyr_6buO5piO_MjI0MA_0010", "text": "難怪我 被世人笑過 情深偏搞錯", "structure": {"line_index": 10, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 4, 5, 2, 4, 0, 4, 4, 0, 3, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["naan4", "gwaai3", "ngo5", "bei6", "sai3", "jan4", "siu3", "gwo3", "cing4", "sam1", "pin1", "gaau2", "co3"]}, "nlp": {"tokens": [{"text": "難怪", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "世人", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "情深", "pos": "X"}, {"text": "偏", "pos": "X"}, {"text": "搞錯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0009", "next_line_id": "lyr_6buO5piO_MjI0MA_0011", "paragraph_id": "para_04"}}
{"id": "lyr_6buO5piO_MjI0MA_0011", "text": "爲最好 而留座 容易會 沒結果", "structure": {"line_index": 11, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 9, 0, 0, 2, 0, 2, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["zeoi3", "hou2", "ji4", "lau4", "zo6", "jung4", "ji6", "mut6", "git3", "gwo2"]}, "nlp": {"tokens": [{"text": "爲", "pos": "X"}, {"text": "最好", "pos": "X"}, {"text": "而", "pos": "X"}, {"text": "留座", "pos": "X"}, {"text": "容易", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "結果", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0010", "next_line_id": "lyr_6buO5piO_MjI0MA_0012", "paragraph_id": "para_04"}}
{"id": "lyr_6buO5piO_MjI0MA_0012", "text": "與舊情人 狠狠愛過 怎可寂寞就胡亂拍拖", "structure": {"line_index": 12, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 0, 9, 9, 4, 4, 9, 9, 2, 2, 2, 0, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["jyu5", "gau6", "cing4", "jan4", "han2", "han2", "oi3", "gwo3", "zam2", "ho2", "zik6", "mok6", "zau6", "wu4", "lyun6", "paak3", "to1"]}, "nlp": {"tokens": [{"text": "與", "pos": "X"}, {"text": "舊情", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "狠狠", "pos": "X"}, {"text": "愛過", "pos": "X"}, {"text": "怎可", "pos": "X"}, {"text": "寂寞", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "胡亂", "pos": "X"}, {"text": "拍拖", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0011", "next_line_id": "lyr_6buO5piO_MjI0MA_0013", "paragraph_id": "para_05"}}
{"id": "lyr_6buO5piO_MjI0MA_0013", "text": "往後前途仍坎坷 都不忍心隨便愛一個", "structure": {"line_index": 13, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 0, 0, 9, 9, 3, 3, 9, 3, 0, 2, 4, 3, 4], "tone_pattern_cantonese_jyutping": ["wong5", "hau6", "cin4", "tou4", "jing4", "ham2", "ho2", "dou1", "bat1", "jan2", "sam1", "ceoi4", "bin6", "oi3", "jat1", "go3"]}, "nlp": {"tokens": [{"text": "往後", "pos": "X"}, {"text": "前途", "pos": "X"}, {"text": "仍", "pos": "X"}, {"text": "坎坷", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "不忍心", "pos": "X"}, {"text": "隨便", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "一個", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "少數", "artists": ["黎明"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2240", "prev_line_id": "lyr_6buO5piO_MjI0MA_0012", "next_line_id": "lyr_6buO5piO_MjI0MA_0014", "paragraph_id": "para_05"}}
