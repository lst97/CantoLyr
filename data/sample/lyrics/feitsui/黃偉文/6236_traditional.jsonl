{"id": "lyr_5Y2r5YWw_NjIzNg_0003", "text": "跟她 需要比嗎", "structure": {"line_index": 3, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 4, 9, 3], "tone_pattern_cantonese_jyutping": ["gan1", "taa1", "seoi1", "jiu3", "bei2", "maa1"]}, "nlp": {"tokens": [{"text": "跟", "pos": "X"}, {"text": "她", "pos": "X"}, {"text": "需要", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0002", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0004", "text": "懸殊層次 誰人還要爭霸", "structure": {"line_index": 4, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 4, 0, 0, 0, 4, 3, 4], "tone_pattern_cantonese_jyutping": ["jyun4", "syu4", "cang4", "ci3", "seoi4", "jan4", "waan4", "jiu3", "zang1", "baa3"]}, "nlp": {"tokens": [{"text": "懸殊", "pos": "X"}, {"text": "層次", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "還要", "pos": "X"}, {"text": "爭霸", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0003", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0005", "text": "我笑我 曾爲她 失控淚流", "structure": {"line_index": 5, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 0, 3, 3, 4, 2, 0], "tone_pattern_cantonese_jyutping": ["ngo5", "siu3", "ngo5", "cang4", "taa1", "sat1", "hung3", "leoi6", "lau4"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "她", "pos": "X"}, {"text": "失控", "pos": "X"}, {"text": "淚流", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0004", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0006", "text": "我笑我 曾爲你 冷靜如殺手", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 0, 5, 5, 2, 0, 4, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "siu3", "ngo5", "cang4", "nei5", "laang5", "zing6", "jyu4", "saat3", "sau2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "冷靜", "pos": "X"}, {"text": "如", "pos": "X"}, {"text": "殺手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0005", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0007", "text": "我笑我 還在鬥", "structure": {"line_index": 7, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 0, 2, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "siu3", "ngo5", "waan4", "zoi6", "dau3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "還", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "鬥", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0006", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0008", "text": "和無名 情敵去 比可愛 比不怕醜", "structure": {"line_index": 8, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 2, 4, 9, 9, 4, 9, 3, 4, 9], "tone_pattern_cantonese_jyutping": ["wo4", "mou4", "ming4", "cing4", "dik6", "heoi3", "bei2", "ho2", "oi3", "bei2", "bat1", "paa3", "cau2"]}, "nlp": {"tokens": [{"text": "和", "pos": "X"}, {"text": "無名", "pos": "X"}, {"text": "情敵", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "可愛", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "不怕", "pos": "X"}, {"text": "醜", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0007", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0009", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0009", "text": "如果輸 想輸給 些厲害對手", "structure": {"line_index": 9, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 3, 9, 3, 3, 3, 2, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["jyu4", "gwo2", "syu1", "soeng2", "syu1", "kap1", "se1", "lai6", "hoi6", "deoi3", "sau2"]}, "nlp": {"tokens": [{"text": "如果", "pos": "X"}, {"text": "輸", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "輸給", "pos": "X"}, {"text": "些", "pos": "X"}, {"text": "厲害", "pos": "X"}, {"text": "對手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0008", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0010", "paragraph_id": "para_03"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0010", "text": "打輸 也試過 有連場劇鬥", "structure": {"line_index": 10, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 5, 4, 4, 5, 0, 0, 2, 4], "tone_pattern_cantonese_jyutping": ["daa2", "syu1", "jaa5", "si3", "gwo3", "jau5", "lin4", "coeng4", "kek6", "dau3"]}, "nlp": {"tokens": [{"text": "打輸", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "試過", "pos": "X"}, {"text": "有連場", "pos": "X"}, {"text": "劇鬥", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0009", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0011", "paragraph_id": "para_03"}}
