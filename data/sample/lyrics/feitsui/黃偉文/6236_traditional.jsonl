{"id": "lyr_5Y2r5YWw_NjIzNg_0030", "text": "曾爲愛 淪陷過 今生先夠 完美吧", "structure": {"line_index": 30, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 4, 0, 2, 4, 3, 3, 3, 4, 0, 5, 2], "tone_pattern_cantonese_jyutping": ["cang4", "oi3", "leon4", "haam6", "gwo3", "gam1", "sang1", "sin1", "gau3", "jyun4", "mei5", "baa6"]}, "nlp": {"tokens": [{"text": "曾", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "淪陷", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "今生", "pos": "X"}, {"text": "先夠", "pos": "X"}, {"text": "完美", "pos": "X"}, {"text": "吧", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0029", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0031", "paragraph_id": "para_07"}}
