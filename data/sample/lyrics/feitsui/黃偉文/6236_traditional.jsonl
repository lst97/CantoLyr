{"id": "lyr_5Y2r5YWw_NjIzNg_0032", "text": "天降下大敵 猶勝密友", "structure": {"line_index": 32, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 2, 2, 2, 0, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["tin1", "gong3", "haa6", "daai6", "dik6", "jau4", "sing3", "mat6", "jau5"]}, "nlp": {"tokens": [{"text": "天", "pos": "X"}, {"text": "降下", "pos": "X"}, {"text": "大敵", "pos": "X"}, {"text": "猶勝", "pos": "X"}, {"text": "密友", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0031", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0033", "paragraph_id": "para_07"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0033", "text": "未可 鍛鍊我的 或寧願棄守", "structure": {"line_index": 33, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 9, 4, 2, 5, 3, 2, 0, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["mei6", "ho2", "dyun3", "lin6", "ngo5", "dik1", "waak6", "ning4", "jyun6", "hei3", "sau2"]}, "nlp": {"tokens": [{"text": "未", "pos": "X"}, {"text": "可", "pos": "X"}, {"text": "鍛鍊", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "或", "pos": "X"}, {"text": "寧願", "pos": "X"}, {"text": "棄守", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0032", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0034", "paragraph_id": "para_07"}}
