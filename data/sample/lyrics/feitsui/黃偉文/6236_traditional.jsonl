{"id": "lyr_5Y2r5YWw_NjIzNg_0028", "text": "你現任能夠 讓舊人 更顯優厚", "structure": {"line_index": 28, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 2, 0, 4, 2, 2, 0, 9, 3, 5], "tone_pattern_cantonese_jyutping": ["nei5", "jin6", "jam6", "nang4", "gau3", "joeng6", "gau6", "jan4", "hin2", "jau1", "hau5"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "現任", "pos": "X"}, {"text": "能夠", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "舊人", "pos": "X"}, {"text": "更顯", "pos": "X"}, {"text": "優厚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0027", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0029", "paragraph_id": "para_06"}}
