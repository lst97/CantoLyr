{"id": "lyr_5Y2r5YWw_NjIzNg_0022", "text": "和無名 情敵去 比心計 比撐最久", "structure": {"line_index": 22, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 2, 4, 9, 3, 4, 9, 3, 4, 9], "tone_pattern_cantonese_jyutping": ["wo4", "mou4", "ming4", "cing4", "dik6", "heoi3", "bei2", "sam1", "gai3", "bei2", "caang1", "zeoi3", "gau2"]}, "nlp": {"tokens": [{"text": "和", "pos": "X"}, {"text": "無名", "pos": "X"}, {"text": "情敵", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "心計", "pos": "X"}, {"text": "比撐", "pos": "X"}, {"text": "最久", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0021", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0023", "paragraph_id": "para_05"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0023", "text": "如果輸 想輸給 些厲害對手", "structure": {"line_index": 23, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 3, 9, 3, 3, 3, 2, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["jyu4", "gwo2", "syu1", "soeng2", "syu1", "kap1", "se1", "lai6", "hoi6", "deoi3", "sau2"]}, "nlp": {"tokens": [{"text": "如果", "pos": "X"}, {"text": "輸", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "輸給", "pos": "X"}, {"text": "些", "pos": "X"}, {"text": "厲害", "pos": "X"}, {"text": "對手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0022", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0024", "paragraph_id": "para_06"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0024", "text": "打輸 也試過 有連場劇鬥", "structure": {"line_index": 24, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 5, 4, 4, 5, 0, 0, 2, 4], "tone_pattern_cantonese_jyutping": ["daa2", "syu1", "jaa5", "si3", "gwo3", "jau5", "lin4", "coeng4", "kek6", "dau3"]}, "nlp": {"tokens": [{"text": "打輸", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "試過", "pos": "X"}, {"text": "有連場", "pos": "X"}, {"text": "劇鬥", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0023", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0025", "paragraph_id": "para_06"}}
{"id": "lyr_5Y2r5YWw_NjIzNg_0025", "text": "算吧 舊男友 這低價情敵 難接受", "structure": {"line_index": 25, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 2, 0, 5, 5, 3, 4, 0, 2, 0, 4, 2], "tone_pattern_cantonese_jyutping": ["syun3", "baa6", "gau6", "naam4", "jau5", "ze5", "dai1", "gaa3", "cing4", "dik6", "naan4", "zip3", "sau6"]}, "nlp": {"tokens": [{"text": "算", "pos": "X"}, {"text": "吧", "pos": "X"}, {"text": "舊", "pos": "X"}, {"text": "男友", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "低價", "pos": "X"}, {"text": "情敵", "pos": "X"}, {"text": "難", "pos": "X"}, {"text": "接受", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "天敵", "artists": ["衛蘭"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6236", "prev_line_id": "lyr_5Y2r5YWw_NjIzNg_0024", "next_line_id": "lyr_5Y2r5YWw_NjIzNg_0026", "paragraph_id": "para_06"}}
