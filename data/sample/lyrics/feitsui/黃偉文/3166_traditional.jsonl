{"id": "lyr_6ZmI5aWV6L-F_MzE2Ng_0020", "text": "我話好鬼燥 你又真系唔驚", "structure": {"line_index": 20, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 9, 9, 4, 5, 2, 3, 2, 0, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "waa6", "hou2", "gwai2", "cou3", "nei5", "jau6", "zan1", "hai6", "m4", "geng1"]}, "nlp": {"tokens": [{"text": "我話", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "鬼燥", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "又", "pos": "X"}, {"text": "真系", "pos": "X"}, {"text": "唔", "pos": "X"}, {"text": "驚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "兩名男子街頭相遇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3166", "prev_line_id": "lyr_6ZmI5aWV6L-F_MzE2Ng_0019", "next_line_id": "lyr_6ZmI5aWV6L-F_MzE2Ng_0021", "paragraph_id": "para_04"}}
