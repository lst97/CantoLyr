{"id": "lyr_6ZmI5aWV6L-F_Mg_0003", "text": "你最尾等到 只有這枯枝", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 9, 4, 9, 5, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["nei5", "zeoi3", "mei5", "dang2", "dou3", "zi2", "jau5", "ze5", "fu1", "zi1"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "最尾", "pos": "X"}, {"text": "等到", "pos": "X"}, {"text": "只有", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "枯枝", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "葡萄成熟時", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mg_0002", "next_line_id": "lyr_6ZmI5aWV6L-F_Mg_0004", "paragraph_id": "para_01"}}
