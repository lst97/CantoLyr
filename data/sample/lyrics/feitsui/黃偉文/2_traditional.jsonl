{"id": "lyr_6ZmI5aWV6L-F_Mg_0009", "text": "你要靜候 再靜候", "structure": {"line_index": 9, "char_count": 7}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 2, 2, 4, 2, 2], "tone_pattern_cantonese_jyutping": ["nei5", "jiu3", "zing6", "hau6", "zoi3", "zing6", "hau6"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "靜候", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "靜候", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "葡萄成熟時", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mg_0008", "next_line_id": "lyr_6ZmI5aWV6L-F_Mg_0010", "paragraph_id": "para_03"}}
