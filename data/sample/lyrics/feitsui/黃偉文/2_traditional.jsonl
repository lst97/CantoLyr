{"id": "lyr_6ZmI5aWV6L-F_Mg_0006", "text": "這一次 你真的很介意", "structure": {"line_index": 6, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 4, 5, 3, 3, 9, 4, 4], "tone_pattern_cantonese_jyutping": ["ze5", "jat1", "ci3", "nei5", "zan1", "dik1", "han2", "gaai3", "ji3"]}, "nlp": {"tokens": [{"text": "這", "pos": "X"}, {"text": "一次", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "真的", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "介意", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "葡萄成熟時", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mg_0005", "next_line_id": "lyr_6ZmI5aWV6L-F_Mg_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5aWV6L-F_Mg_0007", "text": "但見旁人談情何引誘", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 0, 0, 0, 0, 0, 5, 5], "tone_pattern_cantonese_jyutping": ["daan6", "gin3", "pong4", "jan4", "taam4", "cing4", "ho4", "jan5", "jau5"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "見", "pos": "X"}, {"text": "旁人", "pos": "X"}, {"text": "談情", "pos": "X"}, {"text": "何", "pos": "X"}, {"text": "引誘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "葡萄成熟時", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mg_0006", "next_line_id": "lyr_6ZmI5aWV6L-F_Mg_0008", "paragraph_id": "para_03"}}
