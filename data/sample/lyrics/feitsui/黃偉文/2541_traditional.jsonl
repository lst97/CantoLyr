{"id": "lyr_6IuP5rC45bq3_MjU0MQ_0007", "text": "從蝴蝶結 腰封細紋 到袖翼長度", "structure": {"line_index": 7, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 4, 3, 3, 4, 0, 4, 2, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["cung4", "wu4", "dip6", "git3", "jiu1", "fung1", "sai3", "man4", "dou3", "zau6", "jik6", "coeng4", "dou6"]}, "nlp": {"tokens": [{"text": "從", "pos": "X"}, {"text": "蝴蝶結", "pos": "X"}, {"text": "腰封", "pos": "X"}, {"text": "細紋", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "袖翼", "pos": "X"}, {"text": "長度", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "黑色禮服", "artists": ["蘇永康"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2541", "prev_line_id": "lyr_6IuP5rC45bq3_MjU0MQ_0006", "next_line_id": "lyr_6IuP5rC45bq3_MjU0MQ_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6IuP5rC45bq3_MjU0MQ_0008", "text": "皮鞋微亮 穿起外套 笑踏面前路", "structure": {"line_index": 8, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 2, 3, 9, 2, 4, 4, 2, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["pei4", "haai4", "mei4", "loeng6", "cyun1", "hei2", "ngoi6", "tou3", "siu3", "daap6", "min6", "cin4", "lou6"]}, "nlp": {"tokens": [{"text": "皮鞋", "pos": "X"}, {"text": "微亮", "pos": "X"}, {"text": "穿", "pos": "X"}, {"text": "起", "pos": "X"}, {"text": "外套", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "踏", "pos": "X"}, {"text": "面前", "pos": "X"}, {"text": "路", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "黑色禮服", "artists": ["蘇永康"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2541", "prev_line_id": "lyr_6IuP5rC45bq3_MjU0MQ_0007", "next_line_id": "lyr_6IuP5rC45bq3_MjU0MQ_0009", "paragraph_id": "para_02"}}
