{"id": "lyr_6IuP5rC45bq3_MjU0MQ_0012", "text": "唯有 儘量做到不失優雅就好", "structure": {"line_index": 12, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 9, 0, 2, 4, 3, 3, 3, 5, 2, 9], "tone_pattern_cantonese_jyutping": ["wai4", "jau5", "zeon2", "loeng4", "zou6", "dou3", "bat1", "sat1", "jau1", "ngaa5", "zau6", "hou2"]}, "nlp": {"tokens": [{"text": "唯有", "pos": "X"}, {"text": "儘量", "pos": "X"}, {"text": "做到", "pos": "X"}, {"text": "不失", "pos": "X"}, {"text": "優雅", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "好", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "黑色禮服", "artists": ["蘇永康"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2541", "prev_line_id": "lyr_6IuP5rC45bq3_MjU0MQ_0011", "next_line_id": "lyr_6IuP5rC45bq3_MjU0MQ_0013", "paragraph_id": "para_03"}}
