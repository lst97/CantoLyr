{"id": "lyr_5Y-k5beo5Z-6_MzI5Mw_0007", "text": "你不肯愛我 也不肯放我", "structure": {"line_index": 7, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 9, 4, 5, 5, 3, 9, 4, 5], "tone_pattern_cantonese_jyutping": ["nei5", "bat1", "hang2", "oi3", "ngo5", "jaa5", "bat1", "hang2", "fong3", "ngo5"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "不肯", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "不肯", "pos": "X"}, {"text": "放", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "跳飛機", "artists": ["古巨基"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3293", "prev_line_id": "lyr_5Y-k5beo5Z-6_MzI5Mw_0006", "next_line_id": "lyr_5Y-k5beo5Z-6_MzI5Mw_0008", "paragraph_id": "para_01"}}
