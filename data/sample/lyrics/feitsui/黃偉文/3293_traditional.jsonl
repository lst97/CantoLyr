{"id": "lyr_5Y-k5beo5Z-6_MzI5Mw_0009", "text": "就算 遺忘如何去飛 都必須掙開你", "structure": {"line_index": 9, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 0, 0, 0, 0, 4, 3, 3, 3, 3, 2, 3, 5], "tone_pattern_cantonese_jyutping": ["zau6", "syun3", "wai4", "mong4", "jyu4", "ho4", "heoi3", "fei1", "dou1", "bit1", "seoi1", "zaang6", "hoi1", "nei5"]}, "nlp": {"tokens": [{"text": "就算", "pos": "X"}, {"text": "遺忘", "pos": "X"}, {"text": "如何", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "飛", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "必須", "pos": "X"}, {"text": "掙開", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "跳飛機", "artists": ["古巨基"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3293", "prev_line_id": "lyr_5Y-k5beo5Z-6_MzI5Mw_0008", "next_line_id": "lyr_5Y-k5beo5Z-6_MzI5Mw_0010", "paragraph_id": "para_02"}}
