{"id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0018", "text": "假使間 這惡行 你試過 我試過 人人同爲人渣", "structure": {"line_index": 18, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 5, 4, 0, 5, 4, 4, 5, 4, 4, 0, 0, 0, 0, 3], "tone_pattern_cantonese_jyutping": ["gaa2", "si2", "ze5", "ok3", "hang4", "nei5", "si3", "gwo3", "ngo5", "si3", "gwo3", "jan4", "jan4", "tung4", "jan4", "zaa1"]}, "nlp": {"tokens": [{"text": "假使", "pos": "X"}, {"text": "間", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "惡行", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "試過", "pos": "X"}, {"text": "我試", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "人人", "pos": "X"}, {"text": "同", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "人渣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "人渣", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6209", "prev_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0017", "next_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0019", "paragraph_id": "para_05"}}
{"id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0019", "text": "你不體諒我嗎 難道我想 愛得精彩 亦算可怕", "structure": {"line_index": 19, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 9, 2, 5, 3, 0, 2, 5, 9, 4, 3, 3, 9, 2, 4, 9, 4], "tone_pattern_cantonese_jyutping": ["nei5", "bat1", "tai2", "loeng6", "ngo5", "maa1", "naan4", "dou6", "ngo5", "soeng2", "oi3", "dak1", "zing1", "coi2", "jik6", "syun3", "ho2", "paa3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "體諒", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "難道", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "愛得", "pos": "X"}, {"text": "精彩", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "算", "pos": "X"}, {"text": "可怕", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "人渣", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6209", "prev_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0018", "next_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0020", "paragraph_id": "para_05"}}
{"id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0020", "text": "摧毀 大地上萬朵鮮花 爲遇着命中的她", "structure": {"line_index": 20, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 2, 2, 2, 9, 3, 3, 2, 2, 2, 3, 3, 3], "tone_pattern_cantonese_jyutping": ["ceoi1", "wai2", "daai6", "dei6", "maan6", "do2", "sin1", "faa1", "jyu6", "zoek6", "ming6", "zung1", "dik1", "taa1"]}, "nlp": {"tokens": [{"text": "摧毀", "pos": "X"}, {"text": "大", "pos": "X"}, {"text": "地上", "pos": "X"}, {"text": "萬朵", "pos": "X"}, {"text": "鮮花", "pos": "X"}, {"text": "爲遇", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "命中", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "她", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "人渣", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6209", "prev_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0019", "next_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0021", "paragraph_id": "para_06"}}
