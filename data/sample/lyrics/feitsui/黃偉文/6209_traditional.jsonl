{"id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0014", "text": "如果似我就是 人類最差", "structure": {"line_index": 14, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 5, 5, 2, 2, 0, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["jyu4", "gwo2", "ci5", "ngo5", "zau6", "si6", "jan4", "leoi6", "zeoi3", "caa1"]}, "nlp": {"tokens": [{"text": "如果", "pos": "X"}, {"text": "似", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "就是", "pos": "X"}, {"text": "人類", "pos": "X"}, {"text": "最差", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "人渣", "artists": ["麥浚龍"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6209", "prev_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0013", "next_line_id": "lyr_6bqm5rWa6b6Z_NjIwOQ_0015", "paragraph_id": "para_04"}}
