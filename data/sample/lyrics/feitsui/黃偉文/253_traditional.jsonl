{"id": "lyr_6ZmI5aWV6L-F_MjUz_0005", "text": "沒寄望叮噹 給我各樣小道具", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 2, 3, 3, 3, 5, 4, 2, 9, 2, 2], "tone_pattern_cantonese_jyutping": ["mut6", "gei3", "mong6", "ding1", "dong1", "kap1", "ngo5", "gok3", "joeng6", "siu2", "dou6", "geoi6"]}, "nlp": {"tokens": [{"text": "沒", "pos": "X"}, {"text": "寄望", "pos": "X"}, {"text": "叮噹", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "各樣", "pos": "X"}, {"text": "小", "pos": "X"}, {"text": "道具", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "隨意門", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_253", "prev_line_id": "lyr_6ZmI5aWV6L-F_MjUz_0004", "next_line_id": "lyr_6ZmI5aWV6L-F_MjUz_0006", "paragraph_id": "para_02"}}
