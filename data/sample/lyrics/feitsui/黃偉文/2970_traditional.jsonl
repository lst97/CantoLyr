{"id": "lyr_5YWz5pm65paM_Mjk3MA_0012", "text": "奔奔波波經已全年無休", "structure": {"line_index": 12, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 3, 3, 5, 0, 0, 0, 3], "tone_pattern_cantonese_jyutping": ["ban1", "ban1", "bo1", "bo1", "ging1", "ji5", "cyun4", "nin4", "mou4", "jau1"]}, "nlp": {"tokens": [{"text": "奔", "pos": "X"}, {"text": "奔波", "pos": "X"}, {"text": "波經", "pos": "X"}, {"text": "已", "pos": "X"}, {"text": "全年", "pos": "X"}, {"text": "無休", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "代表作", "artists": ["關智斌"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2970", "prev_line_id": "lyr_5YWz5pm65paM_Mjk3MA_0011", "next_line_id": "lyr_5YWz5pm65paM_Mjk3MA_0013", "paragraph_id": "para_03"}}
