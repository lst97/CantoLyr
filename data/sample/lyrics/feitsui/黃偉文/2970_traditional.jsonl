{"id": "lyr_5YWz5pm65paM_Mjk3MA_0003", "text": "眼看着我努力砌的沙丘", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 2, 5, 5, 2, 4, 3, 3, 3], "tone_pattern_cantonese_jyutping": ["ngaan5", "hon3", "zoek6", "ngo5", "nou5", "lik6", "cai3", "dik1", "saa1", "jau1"]}, "nlp": {"tokens": [{"text": "眼看", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "努力", "pos": "X"}, {"text": "砌", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "沙丘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "代表作", "artists": ["關智斌"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2970", "prev_line_id": "lyr_5YWz5pm65paM_Mjk3MA_0002", "next_line_id": "lyr_5YWz5pm65paM_Mjk3MA_0004", "paragraph_id": "para_01"}}
