{"id": "lyr_6ZmI5aWV6L-F_MTY2Mw_0005", "text": "我 笨且拙 從來大意善忘", "structure": {"line_index": 5, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 9, 4, 0, 0, 2, 4, 2, 0], "tone_pattern_cantonese_jyutping": ["ngo5", "ban6", "ce2", "zyut3", "cung4", "loi4", "daai6", "ji3", "sin6", "mong4"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "笨且", "pos": "X"}, {"text": "拙", "pos": "X"}, {"text": "從來", "pos": "X"}, {"text": "大意", "pos": "X"}, {"text": "善忘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "那一夜有沒有雪", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1663", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTY2Mw_0004", "next_line_id": "lyr_6ZmI5aWV6L-F_MTY2Mw_0006", "paragraph_id": "para_02"}}
