{"id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0004", "text": "都仲未爆 仲居然有空位剩 吹口哨", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 2, 2, 4, 2, 3, 0, 5, 3, 2, 2, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["dou1", "zung6", "mei6", "baau3", "zung6", "geoi1", "jin4", "jau5", "hung1", "wai6", "sing6", "ceoi1", "hau2", "saau3"]}, "nlp": {"tokens": [{"text": "都", "pos": "X"}, {"text": "仲未", "pos": "X"}, {"text": "爆", "pos": "X"}, {"text": "仲", "pos": "X"}, {"text": "居然", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "空位", "pos": "X"}, {"text": "剩", "pos": "X"}, {"text": "吹口哨", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "非常口", "artists": ["軟硬天師"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1958", "prev_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0003", "next_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0005", "text": "阿口 我鐘意系你個度整野出黎", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 9, 5, 3, 4, 2, 5, 4, 2, 9, 5, 3, 0], "tone_pattern_cantonese_jyutping": ["aa3", "hau2", "ngo5", "zung1", "ji3", "hai6", "nei5", "go3", "dou6", "zing2", "je5", "ceot1", "lai4"]}, "nlp": {"tokens": [{"text": "阿口", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "鐘意", "pos": "X"}, {"text": "系", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "個度", "pos": "X"}, {"text": "整野", "pos": "X"}, {"text": "出黎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "非常口", "artists": ["軟硬天師"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1958", "prev_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0004", "next_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0006", "paragraph_id": "para_01"}}
{"id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0006", "text": "但求自已快慰 劈大個嘴仔就黎刺", "structure": {"line_index": 6, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 2, 5, 4, 4, 4, 2, 4, 9, 9, 2, 0, 4], "tone_pattern_cantonese_jyutping": ["daan6", "kau4", "zi6", "ji5", "faai3", "wai3", "pek3", "daai6", "go3", "zeoi2", "zai2", "zau6", "lai4", "ci3"]}, "nlp": {"tokens": [{"text": "但求", "pos": "X"}, {"text": "自已", "pos": "X"}, {"text": "快慰", "pos": "X"}, {"text": "劈大個", "pos": "X"}, {"text": "嘴", "pos": "X"}, {"text": "仔", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "黎刺", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "非常口", "artists": ["軟硬天師"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1958", "prev_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0005", "next_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0007", "paragraph_id": "para_01"}}
{"id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0007", "text": "講笑談心 呃大話 慰問孃親不含真心", "structure": {"line_index": 7, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 0, 3, 3, 2, 2, 4, 2, 0, 3, 3, 0, 3, 3], "tone_pattern_cantonese_jyutping": ["gong2", "siu3", "taam4", "sam1", "ak1", "daai6", "waa6", "wai3", "man6", "noeng4", "can1", "bat1", "ham4", "zan1", "sam1"]}, "nlp": {"tokens": [{"text": "講笑", "pos": "X"}, {"text": "談心", "pos": "X"}, {"text": "呃", "pos": "X"}, {"text": "大話", "pos": "X"}, {"text": "慰問", "pos": "X"}, {"text": "孃親", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "含", "pos": "X"}, {"text": "真心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "非常口", "artists": ["軟硬天師"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1958", "prev_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0006", "next_line_id": "lyr_6L2v56Gs5aSp5biI_MTk1OA_0008", "paragraph_id": "para_01"}}
