{"id": "lyr_6ZmI5aWV6L-F_MTA3OA_0022", "text": "大概只是 我不好愛", "structure": {"line_index": 22, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 9, 2, 5, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["daai6", "koi3", "zi2", "si6", "ngo5", "bat1", "hou2", "oi3"]}, "nlp": {"tokens": [{"text": "大概", "pos": "X"}, {"text": "只是", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "不好", "pos": "X"}, {"text": "愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我不好愛", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1078", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0021", "next_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0023", "paragraph_id": "para_05"}}
{"id": "lyr_6ZmI5aWV6L-F_MTA3OA_0023", "text": "我 又憤怒 又脆弱 愛都不敢愛", "structure": {"line_index": 23, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 5, 2, 2, 4, 2, 4, 3, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "jau6", "fan5", "nou6", "jau6", "ceoi3", "joek6", "oi3", "dou1", "bat1", "gam2", "oi3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "又", "pos": "X"}, {"text": "憤怒", "pos": "X"}, {"text": "又", "pos": "X"}, {"text": "脆弱", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "不敢", "pos": "X"}, {"text": "愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我不好愛", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1078", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0022", "next_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0024", "paragraph_id": "para_06"}}
{"id": "lyr_6ZmI5aWV6L-F_MTA3OA_0024", "text": "怕 被冷落 卻不肯接待", "structure": {"line_index": 24, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 5, 2, 4, 3, 9, 4, 2], "tone_pattern_cantonese_jyutping": ["paa3", "bei6", "laang5", "lok6", "koek3", "bat1", "hang2", "zip3", "doi6"]}, "nlp": {"tokens": [{"text": "怕", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "冷落", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "不肯", "pos": "X"}, {"text": "接待", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我不好愛", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1078", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0023", "next_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0025", "paragraph_id": "para_06"}}
{"id": "lyr_6ZmI5aWV6L-F_MTA3OA_0025", "text": "當 你跟我 有一個 那麼不易愛", "structure": {"line_index": 25, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 5, 5, 3, 4, 5, 3, 3, 2, 4], "tone_pattern_cantonese_jyutping": ["nei5", "gan1", "ngo5", "jau5", "jat1", "go3", "naa5", "mo1", "bat1", "ji6", "oi3"]}, "nlp": {"tokens": [{"text": "當", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "那麼", "pos": "X"}, {"text": "不易", "pos": "X"}, {"text": "愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我不好愛", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1078", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0024", "next_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0026", "paragraph_id": "para_06"}}
