{"id": "lyr_6ZmI5aWV6L-F_MTA3OA_0020", "text": "我 被厚待 亦相當意外", "structure": {"line_index": 20, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 5, 2, 2, 4, 2], "tone_pattern_cantonese_jyutping": ["ngo5", "bei6", "hau5", "doi6", "jik6", "ji3", "ngoi6"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "厚待", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "相當", "pos": "X"}, {"text": "意外", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我不好愛", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1078", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0019", "next_line_id": "lyr_6ZmI5aWV6L-F_MTA3OA_0021", "paragraph_id": "para_05"}}
