{"id": "lyr_5a6556WW5YS__MTA1Mg_0009", "text": "何時若覺不安 都清楚燈塔會於哪方", "structure": {"line_index": 9, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 4, 3, 3, 3, 3, 9, 3, 4, 3, 5, 3], "tone_pattern_cantonese_jyutping": ["ho4", "si4", "joek6", "gok3", "bat1", "on1", "dou1", "cing1", "co2", "dang1", "taap3", "jyu1", "naa5", "fong1"]}, "nlp": {"tokens": [{"text": "何時", "pos": "X"}, {"text": "若覺", "pos": "X"}, {"text": "不安", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "清楚", "pos": "X"}, {"text": "燈塔", "pos": "X"}, {"text": "會於", "pos": "X"}, {"text": "哪方", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "空港", "artists": ["容祖兒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1052", "prev_line_id": "lyr_5a6556WW5YS__MTA1Mg_0008", "next_line_id": "lyr_5a6556WW5YS__MTA1Mg_0010", "paragraph_id": "para_02"}}
