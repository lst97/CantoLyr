{"id": "lyr_SG8_MjYy_0001", "text": "等 終於到夜深", "structure": {"line_index": 1, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 3, 4, 2, 3], "tone_pattern_cantonese_jyutping": ["dang2", "zung1", "jyu1", "dou3", "je6", "sam1"]}, "nlp": {"tokens": [{"text": "等", "pos": "X"}, {"text": "終於", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "夜深", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "明目張膽", "artists": ["Ho"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_262", "prev_line_id": null, "next_line_id": "lyr_SG8_MjYy_0002", "paragraph_id": "para_01"}}
