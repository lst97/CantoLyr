{"id": "lyr_5ZGo5p-P6LGq_NjY4Mg_0008", "text": "容許我 變一個 最絕情男人", "structure": {"line_index": 8, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 5, 4, 3, 4, 4, 2, 0, 0, 0], "tone_pattern_cantonese_jyutping": ["jung4", "heoi2", "ngo5", "bin3", "jat1", "go3", "zeoi3", "zyut6", "cing4", "naam4", "jan4"]}, "nlp": {"tokens": [{"text": "容許", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "變", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "最", "pos": "X"}, {"text": "絕情", "pos": "X"}, {"text": "男人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "讓愛高飛", "artists": ["周柏豪"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6682", "prev_line_id": "lyr_5ZGo5p-P6LGq_NjY4Mg_0007", "next_line_id": "lyr_5ZGo5p-P6LGq_NjY4Mg_0009", "paragraph_id": "para_02"}}
