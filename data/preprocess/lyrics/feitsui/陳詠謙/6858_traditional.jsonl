{"id":"lyr_5YiY5rWp6b6Z_Njg1OA_0036","text":"若件件大事亦會被懷疑","structure":{"line_index":36,"char_count":10},"semantics":{"themes":["懷疑","挑戰","堅持"],"sentiment":"NEGATIVE","keywords":["大事","懷疑"]},"prosody":{"tone_pattern":[2,2,2,2,2,2,2,0,0],"tone_pattern_cantonese_jyutping":["joek6","gin6","gin6","daai6","si6","jik6","bei6","waai4","ji4"]},"nlp":{"tokens":[{"text":"若件件","pos":"DET"},{"text":"大事","pos":"NOUN"},{"text":"亦","pos":"ADV"},{"text":"會","pos":"AUX"},{"text":"被","pos":"ADP"},{"text":"懷疑","pos":"VERB"}],"syntax_notes":"重複提出即使是「大事」也可能被懷疑，語氣帶有憂慮。"},"source":{"title":"我信的故事","artists":["劉浩龍"],"lyricists":["陳詠謙"],"year":0,"genre":["Pop","Cantopop"]},"context_links":{"doc_id":"feitsui_6858","prev_line_id":"lyr_5YiY5rWp6b6Z_Njg1OA_0035","next_line_id":"lyr_5YiY5rWp6b6Z_Njg1OA_0037","paragraph_id":"para_08"}}
