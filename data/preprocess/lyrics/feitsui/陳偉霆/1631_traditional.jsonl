{"id":"lyr_5rOz5YS__MTYzMQ_0022","text":"逼得我 也怕自己 放棄自己","structure":{"line_index":22,"char_count":11},"semantics":{"themes":["放棄","自我解脫","痛苦"],"sentiment":"VERY_NEGATIVE","keywords":["逼得","怕自己","放棄自己"]},"prosody":{"tone_pattern":[3,3,5,5,4,2,9,4,4,2,9],"tone_pattern_cantonese_jyutping":["bik1","dak1","ngo5","jaa5","paa3","zi6","gei2","fong3","hei3","zi6","gei2"]},"nlp":{"tokens":[{"text":"逼得","pos":"VERB"},{"text":"我","pos":"PRON"},{"text":"也","pos":"ADV"},{"text":"怕","pos":"VERB"},{"text":"自己","pos":"PRON"},{"text":"放棄","pos":"VERB"},{"text":"自己","pos":"PRON"}],"syntax_notes":"表達因無法承受而選擇放棄自己，語氣帶有解脫的同時也充滿痛苦。"},"source":{"title":"我是誰","artists":["泳兒"],"lyricists":["陳偉霆","林日曦"],"year":0,"genre":["Pop","Ballad"]},"context_links":{"doc_id":"feitsui_1631","prev_line_id":"lyr_5rOz5YS__MTYzMQ_0021","next_line_id":"lyr_5rOz5YS__MTYzMQ_0023","paragraph_id":"para_06"}}
