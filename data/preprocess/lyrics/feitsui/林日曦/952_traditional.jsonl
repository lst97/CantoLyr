{"id":"lyr_5p6X5bOw_OTUy_0023","text":"那同林年代 有沒有拿來回味","structure":{"line_index":23,"char_count":12},"semantics":{"themes":["懷舊","反思"],"sentiment":"NEUTRAL","keywords":["同林","年代","回味"]},"prosody":{"tone_pattern":[5,0,0,0,2,5,2,5,0,0,0,2],"tone_pattern_cantonese_jyutping":["naa5","tung4","lam4","nin4","doi6","jau5","mut6","jau5","naa4","loi4","wui4","mei6"]},"nlp":{"tokens":[{"text":"那同林","pos":"NOUN"},{"text":"年代","pos":"NOUN"},{"text":"有沒有","pos":"ADV"},{"text":"拿來","pos":"VERB"},{"text":"回味","pos":"VERB"}],"syntax_notes":"對過去「同林」的年代提出疑問，是否值得回味，語氣轉為反思。"},"source":{"title":"同林","artists":["林峯"],"lyricists":["林日曦"],"year":0,"genre":["Pop","Cantopop"]},"context_links":{"doc_id":"feitsui_952","prev_line_id":"lyr_5p6X5bOw_OTUy_0022","next_line_id":"lyr_5p6X5bOw_OTUy_0024","paragraph_id":"para_07"}}
