{"id":"lyr_6ZmI5oWn55Cz_NjA0Ng_0006","text":"情慾是最毒那可救藥","structure":{"line_index":6,"char_count":9},"semantics":{"themes":["愛情","毒性","無法自拔"],"sentiment":"VERY_NEGATIVE","keywords":["情慾","最毒","救藥"]},"prosody":{"tone_pattern":[0,2,2,4,2,5,9,4,2],"tone_pattern_cantonese_jyutping":["cing4","juk6","si6","zeoi3","duk6","naa5","ho2","gau3","joek6"]},"nlp":{"tokens":[{"text":"情慾","pos":"NOUN"},{"text":"是","pos":"AUX"},{"text":"最毒","pos":"ADJ"},{"text":"那","pos":"DET"},{"text":"可","pos":"AUX"},{"text":"救藥","pos":"NOUN"}],"syntax_notes":"直接點明「情慾」是劇毒，且無藥可救，加強了中毒的嚴重性。"},"source":{"title":"情毒","artists":["陳慧琳"],"lyricists":["李峻一"],"year":0,"genre":["Pop","Cantopop"]},"context_links":{"doc_id":"feitsui_6046","prev_line_id":"lyr_6ZmI5oWn55Cz_NjA0Ng_0005","next_line_id":"lyr_6ZmI5oWn55Cz_NjA0Ng_0007","paragraph_id":"para_02"}}
