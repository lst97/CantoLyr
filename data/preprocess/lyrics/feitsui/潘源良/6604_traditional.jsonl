{"id":"lyr_6ZmI5oWn5ai0_NjYwNA_0015","text":"誰還可以再次地啞忍","structure":{"line_index":15,"char_count":9},"semantics":{"themes":["忍耐的極限","無法再承受","無助"],"sentiment":"VERY_NEGATIVE","keywords":["啞忍"]},"prosody":{"tone_pattern":[0,0,9,5,4,4,2,9,9],"tone_pattern_cantonese_jyutping":["seoi4","waan4","ho2","ji5","zoi3","ci3","dei6","aa2","jan2"]},"nlp":{"tokens":[{"text":"誰","pos":"PRON"},{"text":"還","pos":"ADV"},{"text":"可以","pos":"AUX"},{"text":"再次","pos":"ADV"},{"text":"地啞","pos":"ADV"},{"text":"忍","pos":"VERB"}],"syntax_notes":"質疑自己還能忍耐多久，表達忍耐已到極限的無助感。"},"source":{"title":"變心","artists":["陳慧嫺"],"lyricists":["潘源良"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_6604","prev_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0014","next_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0016","paragraph_id":"para_01"}}
