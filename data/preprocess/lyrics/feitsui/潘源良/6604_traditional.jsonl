{"id":"lyr_6ZmI5oWn5ai0_NjYwNA_0006","text":"你 當初那瀟灑 今天已消失 談話似一個俗人","structure":{"line_index":6,"char_count":18},"semantics":{"themes":["伴侶的改變","失去魅力","變得平凡"],"sentiment":"NEGATIVE","keywords":["瀟灑","消失","俗人"]},"prosody":{"tone_pattern":[5,3,5,3,9,3,3,5,3,3,0,2,5,3,4,2,0],"tone_pattern_cantonese_jyutping":["nei5","co1","naa5","siu1","saa2","gam1","tin1","ji5","siu1","sat1","taam4","waa6","ci5","jat1","go3","zuk6","jan4"]},"nlp":{"tokens":[{"text":"你","pos":"PRON"},{"text":"當初","pos":"NOUN"},{"text":"那","pos":"DET"},{"text":"瀟灑","pos":"ADJ"},{"text":"今天","pos":"NOUN"},{"text":"已","pos":"ADV"},{"text":"消失","pos":"VERB"},{"text":"談話","pos":"VERB"},{"text":"似","pos":"VERB"},{"text":"一個","pos":"DET"},{"text":"俗人","pos":"NOUN"}],"syntax_notes":"直接描述伴侶的改變，從瀟灑變得像個俗人，語氣帶有失望。"},"source":{"title":"變心","artists":["陳慧嫺"],"lyricists":["潘源良"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_6604","prev_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0005","next_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0007","paragraph_id":"para_01"}}
