{"id":"lyr_6ZmI5oWn5ai0_NjYwNA_0004","text":"曾信任同訂三生 緣份","structure":{"line_index":4,"char_count":9},"semantics":{"themes":["愛情的回憶","永恆的承諾","緣份"],"sentiment":"POSITIVE","keywords":["信任","訂三生","緣份"]},"prosody":{"tone_pattern":[0,4,2,0,4,3,3,0,2],"tone_pattern_cantonese_jyutping":["cang4","seon3","jam6","tung4","ding3","saam1","sang1","jyun4","fan6"]},"nlp":{"tokens":[{"text":"曾","pos":"ADV"},{"text":"信任","pos":"VERB"},{"text":"同訂","pos":"VERB"},{"text":"三生","pos":"NUM"},{"text":"緣份","pos":"NOUN"}],"syntax_notes":"描述過去對愛情的信任與對永恆的期盼。"},"source":{"title":"變心","artists":["陳慧嫺"],"lyricists":["潘源良"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_6604","prev_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0003","next_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0005","paragraph_id":"para_01"}}
