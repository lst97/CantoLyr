{"id":"lyr_6ZmI5oWn5ai0_NjYwNA_0011","text":"仍然一次兩次地苦忍","structure":{"line_index":11,"char_count":9},"semantics":{"themes":["忍耐","痛苦","無奈"],"sentiment":"VERY_NEGATIVE","keywords":["苦忍"]},"prosody":{"tone_pattern":[0,0,3,4,5,4,2,9,9],"tone_pattern_cantonese_jyutping":["jing4","jin4","jat1","ci3","loeng5","ci3","dei6","fu2","jan2"]},"nlp":{"tokens":[{"text":"仍然","pos":"ADV"},{"text":"一次","pos":"NUM"},{"text":"兩次","pos":"NUM"},{"text":"地苦忍","pos":"VERB"}],"syntax_notes":"描述一次又一次的苦苦忍耐，語氣充滿無奈與痛苦。"},"source":{"title":"變心","artists":["陳慧嫺"],"lyricists":["潘源良"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_6604","prev_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0010","next_line_id":"lyr_6ZmI5oWn5ai0_NjYwNA_0012","paragraph_id":"para_01"}}
