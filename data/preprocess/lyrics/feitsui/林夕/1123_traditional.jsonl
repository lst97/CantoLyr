{"id":"lyr_5Y-k5beo5Z-6_MTEyMw_0034","text":"我要你 沒白白叫心血流逝","structure":{"line_index":34,"char_count":11},"semantics":{"themes":["珍惜","付出","不浪費"],"sentiment":"POSITIVE","keywords":["心血","流逝"]},"prosody":{"tone_pattern":[5,4,5,2,2,2,4,3,4,0,2],"tone_pattern_cantonese_jyutping":["ngo5","jiu3","nei5","mut6","baak6","baak6","giu3","sam1","hyut3","lau4","sai6"]},"nlp":{"tokens":[{"text":"我要","pos":"VERB"},{"text":"你","pos":"PRON"},{"text":"沒","pos":"ADV"},{"text":"白白","pos":"ADV"},{"text":"叫","pos":"VERB"},{"text":"心血","pos":"NOUN"},{"text":"流逝","pos":"VERB"}],"syntax_notes":"「沒白白叫...流逝」的句式，強調不希望對方的付出白費。"},"source":{"title":"以你爲榮","artists":["古巨基"],"lyricists":["林夕"],"year":0,"genre":["Pop"]},"context_links":{"doc_id":"feitsui_1123","prev_line_id":"lyr_5Y-k5beo5Z-6_MTEyMw_0033","next_line_id":"lyr_5Y-k5beo5Z-6_MTEyMw_0035","paragraph_id":"para_09"}}
