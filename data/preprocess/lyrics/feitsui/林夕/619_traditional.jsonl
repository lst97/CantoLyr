{"id":"lyr_6ZmI5aWV6L-F_NjE5_0011","text":"喂喂 我不敢委屈你","structure":{"line_index":11,"char_count":8},"semantics":{"themes":["情感","克制","委屈"],"sentiment":"NEGATIVE","keywords":["不敢","委屈"]},"prosody":{"tone_pattern":[4,4,5,3,9,3,3,5],"tone_pattern_cantonese_jyutping":["wai3","wai3","ngo5","bat1","gam2","wai1","wat1","nei5"]},"nlp":{"tokens":[{"text":"喂喂","pos":"INTJ"},{"text":"我","pos":"PRON"},{"text":"不敢","pos":"VERB"},{"text":"委屈","pos":"VERB"},{"text":"你","pos":"PRON"}],"syntax_notes":"「不敢委屈你」表達了對對方的顧慮和不想讓對方受到傷害的心情。"},"source":{"title":"冤氣","artists":["陳奕迅"],"lyricists":["林夕"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_619","prev_line_id":"lyr_6ZmI5aWV6L-F_NjE5_0010","next_line_id":"lyr_6ZmI5aWV6L-F_NjE5_0012","paragraph_id":"para_04"}}
