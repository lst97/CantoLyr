{"id":"lyr_V29uZw_NTg2Mg_0019","text":"寸步若是難動 爲何仍然愚忠","structure":{"line_index":19,"char_count":12},"semantics":{"themes":["困境","愚忠","質疑"],"sentiment":"NEGATIVE","keywords":["寸步難動","愚忠","爲何"]},"prosody":{"tone_pattern":[4,2,2,2,0,2,0,0,0,0,3],"tone_pattern_cantonese_jyutping":["cyun3","bou6","joek6","si6","naan4","dung6","ho4","jing4","jin4","jyu4","zung1"]},"nlp":{"tokens":[{"text":"寸步","pos":"NOUN"},{"text":"若","pos":"CONJ"},{"text":"是","pos":"VERB"},{"text":"難動","pos":"ADJ"},{"text":"爲何","pos":"ADV"},{"text":"仍然","pos":"ADV"},{"text":"愚忠","pos":"ADJ"}],"syntax_notes":"以反問句質疑在極度受限的情況下，為何還要堅持愚忠，語氣帶有不解和質疑。"},"source":{"title":"四大皆空","artists":["Wong"],"lyricists":["林夕"],"year":0,"genre":["Cantopop","Philosophical","Ballad"]},"context_links":{"doc_id":"feitsui_5862","prev_line_id":"lyr_V29uZw_NTg2Mg_0018","next_line_id":"lyr_V29uZw_NTg2Mg_0020","paragraph_id":"para_06"}}
