{"id":"lyr_6K645b-X5a6J_NDYzMg_0011","text":"好 緊張刺激不錯 隨現實奔波","structure":{"line_index":11,"char_count":12},"semantics":{"themes":["生活節奏","隨波逐流"],"sentiment":"NEUTRAL","keywords":["緊張","刺激","奔波","現實"]},"prosody":{"tone_pattern":[9,9,3,4,3,3,4,0,2,2,3,3],"tone_pattern_cantonese_jyutping":["hou2","gan2","zoeng1","ci3","gik1","bat1","co3","ceoi4","jin6","sat6","ban1","bo1"]},"nlp":{"tokens":[{"text":"好","pos":"INTJ"},{"text":"緊張","pos":"ADJ"},{"text":"刺激","pos":"ADJ"},{"text":"不錯","pos":"ADJ"},{"text":"隨","pos":"ADP"},{"text":"現實","pos":"NOUN"},{"text":"奔波","pos":"VERB"}],"syntax_notes":"形容生活「緊張刺激」，但「隨現實奔波」的狀態，帶有被動參與的意味。"},"source":{"title":"陳大文","artists":["許志安"],"lyricists":["林夕"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_4632","prev_line_id":"lyr_6K645b-X5a6J_NDYzMg_0010","next_line_id":"lyr_6K645b-X5a6J_NDYzMg_0012","paragraph_id":"para_02"}}
