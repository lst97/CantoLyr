{"id":"lyr_6IuP5rC45bq3_MzkwOQ_0017","text":"終於懂得欣賞普洱這種濃情","structure":{"line_index":17,"char_count":12},"semantics":{"themes":["成長","理解","親情"],"sentiment":"POSITIVE","keywords":["懂得","欣賞","普洱","濃情"]},"prosody":{"tone_pattern":[3,3,9,3,3,9,9,5,5,9,0,0],"tone_pattern_cantonese_jyutping":["zung1","jyu1","dung2","dak1","jan1","soeng2","pou2","ji5","ze5","zung2","nung4","cing4"]},"nlp":{"tokens":[{"text":"終於","pos":"ADV"},{"text":"懂得","pos":"VERB"},{"text":"欣賞","pos":"VERB"},{"text":"普洱","pos":"NOUN"},{"text":"這種","pos":"DET"},{"text":"濃情","pos":"NOUN"}],"syntax_notes":"「終於懂得」表示領悟的轉折，將「普洱」比喻為父母的「濃情」，語氣帶有頓悟和感激。"},"source":{"title":"普洱茶","artists":["蘇永康"],"lyricists":["林夕"],"year":0,"genre":["Pop","Cantopop"]},"context_links":{"doc_id":"feitsui_3909","prev_line_id":"lyr_6IuP5rC45bq3_MzkwOQ_0016","next_line_id":"lyr_6IuP5rC45bq3_MzkwOQ_0018","paragraph_id":"para_05"}}
