{"id":"lyr_5Y-k5beo5Z-6_MTI0Nw_0004","text":"但可惜那時你都不相信","structure":{"line_index":4,"char_count":10},"semantics":{"themes":["愛情","遺憾","不信任"],"sentiment":"NEGATIVE","keywords":["可惜","不相信"]},"prosody":{"tone_pattern":[2,9,3,5,0,5,3,3,4],"tone_pattern_cantonese_jyutping":["daan6","ho2","sik1","naa5","si4","nei5","dou1","bat1","seon3"]},"nlp":{"tokens":[{"text":"但","pos":"CONJ"},{"text":"可惜","pos":"ADJ"},{"text":"那時","pos":"NOUN"},{"text":"你","pos":"PRON"},{"text":"都","pos":"ADV"},{"text":"不","pos":"ADV"},{"text":"相信","pos":"VERB"}],"syntax_notes":"表達對過去時光無法挽回的可惜，以及對方當時的不信任。"},"source":{"title":"必殺技","artists":["古巨基"],"lyricists":["林夕"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_1247","prev_line_id":"lyr_5Y-k5beo5Z-6_MTI0Nw_0003","next_line_id":"lyr_5Y-k5beo5Z-6_MTI0Nw_0005","paragraph_id":"para_01"}}
