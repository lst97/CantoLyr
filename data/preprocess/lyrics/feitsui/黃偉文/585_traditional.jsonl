{"id":"lyr_5a6Y5oGp5aic_NTg1_0011","text":"明天 似乎是個雨天","structure":{"line_index":11,"char_count":8},"semantics":{"themes":["預期","挑戰","應對"],"sentiment":"NEUTRAL","keywords":["明天","雨天"]},"prosody":{"tone_pattern":[0,3,5,0,2,4,5,3],"tone_pattern_cantonese_jyutping":["ming4","tin1","ci5","fu4","si6","go3","jyu5","tin1"]},"nlp":{"tokens":[{"text":"明天","pos":"NOUN"},{"text":"似乎","pos":"ADV"},{"text":"是","pos":"VERB"},{"text":"個","pos":"PART"},{"text":"雨天","pos":"NOUN"}],"syntax_notes":"『明天似乎是個雨天』，預示著可能遇到的困難或不順遂。"},"source":{"title":"地平線","artists":["官恩娜"],"lyricists":["黃偉文"],"year":0,"genre":["Pop","Cantopop"]},"context_links":{"doc_id":"feitsui_585","prev_line_id":"lyr_5a6Y5oGp5aic_NTg1_0010","next_line_id":"lyr_5a6Y5oGp5aic_NTg1_0012","paragraph_id":"para_03"}}
