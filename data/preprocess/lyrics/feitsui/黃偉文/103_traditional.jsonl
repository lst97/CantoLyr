{"id":"lyr_6ZmI5aWV6L-F_MTAz_0030","text":"但是我清醒","structure":{"line_index":30,"char_count":5},"semantics":{"themes":["清醒","現實"],"sentiment":"NEUTRAL","keywords":["清醒","但是"]},"prosody":{"tone_pattern":[2,2,5,3,9],"tone_pattern_cantonese_jyutping":["daan6","si6","ngo5","cing1","sing2"]},"nlp":{"tokens":[{"text":"但是","pos":"CONJ"},{"text":"我","pos":"PRON"},{"text":"清醒","pos":"ADJ"}],"syntax_notes":"使用轉折詞「但是」，將美好的幻想拉回現實，強調理智的清醒。"},"source":{"title":"無人之境","artists":["陳奕迅"],"lyricists":["黃偉文"],"year":0,"genre":["Cantopop","Pop","Ballad"]},"context_links":{"doc_id":"feitsui_103","prev_line_id":"lyr_6ZmI5aWV6L-F_MTAz_0029","next_line_id":"lyr_6ZmI5aWV6L-F_MTAz_0031","paragraph_id":"para_07"}}
