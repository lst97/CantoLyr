{"id":"lyr_6buO5piO_MjI0MA_0017","text":"名字太少 就是從未耀眼似星河 仍然有溫馨地發生過","structure":{"line_index":17,"char_count":22},"semantics":{"themes":["個人價值","經歷的溫馨"],"sentiment":"POSITIVE","keywords":["名字","耀眼","星河","溫馨","發生"]},"prosody":{"tone_pattern":[0,2,4,2,2,0,2,2,5,5,3,0,0,0,5,3,3,2,4,3,4],"tone_pattern_cantonese_jyutping":["ming4","zi6","taai3","zau6","si6","cung4","mei6","jiu6","ngaan5","ci5","sing1","ho4","jing4","jin4","jau5","wan1","hing1","dei6","faat3","sang1","gwo3"]},"nlp":{"tokens":[{"text":"名字","pos":"NOUN"},{"text":"太","pos":"ADV"},{"text":"少","pos":"ADJ"},{"text":"就是","pos":"CONJ"},{"text":"從未","pos":"ADV"},{"text":"耀眼","pos":"VERB"},{"text":"似","pos":"ADP"},{"text":"星河","pos":"NOUN"},{"text":"仍然","pos":"ADV"},{"text":"有","pos":"VERB"},{"text":"溫馨","pos":"ADJ"},{"text":"地","pos":"PART"},{"text":"發生","pos":"VERB"},{"text":"過","pos":"PART"}],"syntax_notes":"與第9行呼應，即使名字不響亮，經歷依然充滿溫馨和意義。"},"source":{"title":"少數","artists":["黎明"],"lyricists":["黃偉文"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_2240","prev_line_id":"lyr_6buO5piO_MjI0MA_0016","next_line_id":"lyr_6buO5piO_MjI0MA_0018","paragraph_id":"para_06"}}
