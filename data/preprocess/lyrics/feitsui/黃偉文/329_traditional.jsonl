{"id":"lyr_5p2O5YWL5Yuk_MzI5_0037","text":"愛到頭來 能強積 或無人 能累積","structure":{"line_index":37,"char_count":13},"semantics":{"themes":["愛情的本質","現實考驗"],"sentiment":"NEGATIVE","keywords":["愛情","強積","累積"]},"prosody":{"tone_pattern":[4,4,0,0,0,0,3,2,0,0,0,5,3],"tone_pattern_cantonese_jyutping":["oi3","dou3","tau4","loi4","nang4","koeng4","zik1","waak6","mou4","jan4","nang4","leoi5","zik1"]},"nlp":{"tokens":[{"text":"愛","pos":"NOUN"},{"text":"到頭來","pos":"ADV"},{"text":"能","pos":"AUX"},{"text":"強積","pos":"VERB"},{"text":"或","pos":"CONJ"},{"text":"無人","pos":"PRON"},{"text":"能","pos":"AUX"},{"text":"累積","pos":"VERB"}],"syntax_notes":"質疑愛情的本質，是能累積還是會消散。"},"source":{"title":"紙婚","artists":["李克勤"],"lyricists":["黃偉文"],"year":0,"genre":["流行"]},"context_links":{"doc_id":"feitsui_329","prev_line_id":"lyr_5p2O5YWL5Yuk_MzI5_0036","next_line_id":"lyr_5p2O5YWL5Yuk_MzI5_0038","paragraph_id":"para_08"}}
