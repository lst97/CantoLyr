{"id":"lyr_5a6556WW5YS__NjIzOQ_0038","text":"還是會再次等你","structure":{"line_index":38,"char_count":7},"semantics":{"themes":["等待","愛情","承諾"],"sentiment":"POSITIVE","keywords":["還是","再次","等你"]},"prosody":{"tone_pattern":[0,2,4,4,9,5],"tone_pattern_cantonese_jyutping":["waan4","si6","zoi3","ci3","dang2","nei5"]},"nlp":{"tokens":[{"text":"還是","pos":"CONJ"},{"text":"會","pos":"AUX"},{"text":"再次","pos":"ADV"},{"text":"等","pos":"VERB"},{"text":"你","pos":"PRON"}],"syntax_notes":"重複強調會繼續等待，即使「今生」不可一起，也「還是會再次等你」。"},"source":{"title":"還未","artists":["容祖兒"],"lyricists":["黃偉文"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_6239","prev_line_id":"lyr_5a6556WW5YS__NjIzOQ_0037","next_line_id":"lyr_5a6556WW5YS__NjIzOQ_0039","paragraph_id":"para_06"}}
