{"id":"lyr_5bCP6Zuq_MjMzMA_0023","text":"舊日或是願與你合葬","structure":{"line_index":23,"char_count":9},"semantics":{"themes":["過去的執念","死亡"],"sentiment":"NEGATIVE","keywords":["合葬","願"]},"prosody":{"tone_pattern":[2,2,2,2,2,5,5,2,4],"tone_pattern_cantonese_jyutping":["gau6","jat6","waak6","si6","jyun6","jyu5","nei5","hap6","zong3"]},"nlp":{"tokens":[{"text":"舊日","pos":"NOUN"},{"text":"或是","pos":"CONJ"},{"text":"願","pos":"VERB"},{"text":"與","pos":"ADP"},{"text":"你","pos":"PRON"},{"text":"合葬","pos":"VERB"}],"syntax_notes":"回顧過去的極端想法（與對方合葬），與現在的轉變形成對比。"},"source":{"title":"菩薩","artists":["小雪"],"lyricists":["黃偉文"],"year":0,"genre":["Pop","Cantopop"]},"context_links":{"doc_id":"feitsui_2330","prev_line_id":"lyr_5bCP6Zuq_MjMzMA_0022","next_line_id":"lyr_5bCP6Zuq_MjMzMA_0024","paragraph_id":"para_04"}}
