{"id":"lyr_6Jab5Yev55Cq_MjAwOA_0021","text":"得到 我與你命運一早 我與你奇妙一種","structure":{"line_index":21,"char_count":16},"semantics":{"themes":["命運","獨特","連結"],"sentiment":"POSITIVE","keywords":["得到","命運","奇妙","一種"]},"prosody":{"tone_pattern":[3,4,5,5,5,2,2,3,9,5,5,5,0,2,3,9],"tone_pattern_cantonese_jyutping":["dak1","dou3","ngo5","jyu5","nei5","ming6","wan6","jat1","zou2","ngo5","jyu5","nei5","kei4","miu6","jat1","zung2"]},"nlp":{"tokens":[{"text":"得到","pos":"VERB"},{"text":"我","pos":"PRON"},{"text":"與","pos":"ADP"},{"text":"你","pos":"PRON"},{"text":"命運","pos":"NOUN"},{"text":"一早","pos":"ADV"},{"text":"我","pos":"PRON"},{"text":"與","pos":"ADP"},{"text":"你","pos":"PRON"},{"text":"奇妙","pos":"ADJ"},{"text":"一種","pos":"NUM"}],"syntax_notes":"「得到」開頭，強調「我與你」的命運早已註定，並且是一種「奇妙」的連結，表達一種宿命感和獨特性。"},"source":{"title":"劍龍在草地散步","artists":["薛凱琪"],"lyricists":["周耀輝"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_2008","prev_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0020","next_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0022","paragraph_id":"para_06"}}
{"id":"lyr_6Jab5Yev55Cq_MjAwOA_0022","text":"與你那個世界人類去得到","structure":{"line_index":22,"char_count":11},"semantics":{"themes":["世界","人類","獲得"],"sentiment":"POSITIVE","keywords":["世界","人類","得到"]},"prosody":{"tone_pattern":[5,5,5,4,4,4,0,2,4,3,4],"tone_pattern_cantonese_jyutping":["jyu5","nei5","naa5","go3","sai3","gaai3","jan4","leoi6","heoi3","dak1","dou3"]},"nlp":{"tokens":[{"text":"與","pos":"ADP"},{"text":"你","pos":"PRON"},{"text":"那個","pos":"DET"},{"text":"世界","pos":"NOUN"},{"text":"人類","pos":"NOUN"},{"text":"去","pos":"VERB"},{"text":"得到","pos":"VERB"}],"syntax_notes":"描述與「你」那個世界相關的人類，去「得到」某種東西，可能指愛情或幸福。"},"source":{"title":"劍龍在草地散步","artists":["薛凱琪"],"lyricists":["周耀輝"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_2008","prev_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0021","next_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0023","paragraph_id":"para_06"}}
