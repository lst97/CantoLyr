{"id":"lyr_6Jab5Yev55Cq_MjAwOA_0015","text":"偏偏覺愛天都覺得猜不到","structure":{"line_index":15,"char_count":11},"semantics":{"themes":["愛情","不可思議","猜測"],"sentiment":"POSITIVE","keywords":["愛","猜不到","天"]},"prosody":{"tone_pattern":[3,3,4,4,3,3,4,3,3,3,4],"tone_pattern_cantonese_jyutping":["pin1","pin1","gok3","oi3","tin1","dou1","gok3","dak1","caai1","bat1","dou3"]},"nlp":{"tokens":[{"text":"偏偏","pos":"ADV"},{"text":"覺愛天","pos":"VERB"},{"text":"都","pos":"ADV"},{"text":"覺得","pos":"VERB"},{"text":"猜","pos":"VERB"},{"text":"不到","pos":"PART"}],"syntax_notes":"重複第三行的結構，再次強調愛情的不可思議，連老天爺都猜不到，加深主題。"},"source":{"title":"劍龍在草地散步","artists":["薛凱琪"],"lyricists":["周耀輝"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_2008","prev_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0014","next_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0016","paragraph_id":"para_04"}}
