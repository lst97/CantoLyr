{"id":"lyr_6Jab5Yev55Cq_MjAwOA_0025","text":"與你那套愛法人類怕知道","structure":{"line_index":25,"char_count":11},"semantics":{"themes":["愛情","秘密","恐懼"],"sentiment":"NEGATIVE","keywords":["愛法","人類","怕","知道"]},"prosody":{"tone_pattern":[5,5,5,4,4,4,0,2,4,3,2],"tone_pattern_cantonese_jyutping":["jyu5","nei5","naa5","tou3","oi3","faat3","jan4","leoi6","paa3","zi1","dou6"]},"nlp":{"tokens":[{"text":"與","pos":"ADP"},{"text":"你","pos":"PRON"},{"text":"那套","pos":"DET"},{"text":"愛法","pos":"NOUN"},{"text":"人類","pos":"NOUN"},{"text":"怕","pos":"VERB"},{"text":"知道","pos":"VERB"}],"syntax_notes":"重複第十一行的結構，再次強調「你」的愛法是人類害怕知道的，加深了這種愛情的獨特性和神秘感。"},"source":{"title":"劍龍在草地散步","artists":["薛凱琪"],"lyricists":["周耀輝"],"year":0,"genre":["Cantopop"]},"context_links":{"doc_id":"feitsui_2008","prev_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0024","next_line_id":"lyr_6Jab5Yev55Cq_MjAwOA_0026","paragraph_id":"para_07"}}
