{"id":"lyr_5p6X5bOw_NDkzMQ_0003","text":"但落在我便恰似雪中海","structure":{"line_index":3,"char_count":10},"semantics":{"themes":["對比","失落","悲傷"],"sentiment":"NEGATIVE","keywords":["落","雪","海"]},"prosody":{"tone_pattern":[2,2,2,5,2,3,5,4,3,9],"tone_pattern_cantonese_jyutping":["daan6","lok6","zoi6","ngo5","bin6","hap1","ci5","syut3","zung1","hoi2"]},"nlp":{"tokens":[{"text":"但落","pos":"VERB"},{"text":"在","pos":"ADP"},{"text":"我","pos":"PRON"},{"text":"便","pos":"ADV"},{"text":"恰似","pos":"VERB"},{"text":"雪","pos":"NOUN"},{"text":"中海","pos":"NOUN"}],"syntax_notes":"將自己的命運比作「雪中海」，營造出孤寂、寒冷、無助的意境，與上一行的「花開」形成強烈對比。"},"source":{"title":"潑墨桃花","artists":["林峯"],"lyricists":["周耀輝"],"year":0,"genre":["Mandopop","Cantopop"]},"context_links":{"doc_id":"feitsui_4931","prev_line_id":"lyr_5p6X5bOw_NDkzMQ_0002","next_line_id":"lyr_5p6X5bOw_NDkzMQ_0004","paragraph_id":"para_01"}}
