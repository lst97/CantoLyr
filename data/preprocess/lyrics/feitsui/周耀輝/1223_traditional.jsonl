{"id":"lyr_5Y2i5ben6Z-z_MTIyMw_0011","text":"我在跟你爭執那時狂得可以逆插起一束玫瑰","structure":{"line_index":11,"char_count":19},"semantics":{"themes":["愛情的衝動","對愛情的反叛"],"sentiment":"NEGATIVE","keywords":["爭執","逆插","玫瑰"]},"prosody":{"tone_pattern":[5,2,3,5,3,3,5,0,0,3,9,5,2,4,9,3,3,0,3],"tone_pattern_cantonese_jyutping":["ngo5","zoi6","gan1","nei5","zang1","zap1","naa5","si4","kwong4","dak1","ho2","ji5","jik6","caap3","hei2","jat1","cuk1","mui4","gwai1"]},"nlp":{"tokens":[{"text":"我","pos":"PRON"},{"text":"在","pos":"ADP"},{"text":"跟","pos":"ADP"},{"text":"你","pos":"PRON"},{"text":"爭執","pos":"VERB"},{"text":"那時","pos":"NOUN"},{"text":"狂得","pos":"ADJ"},{"text":"可以","pos":"AUX"},{"text":"逆","pos":"VERB"},{"text":"插","pos":"VERB"},{"text":"起","pos":"PART"},{"text":"一束","pos":"NUM"},{"text":"玫瑰","pos":"NOUN"}],"syntax_notes":"「逆插起一束玫瑰」是歌曲的標題意象，象徵一種衝動、反叛的愛情行為。"},"source":{"title":"逆插玫瑰","artists":["盧巧音"],"lyricists":["周耀輝"],"year":0,"genre":["Cantopop","Art Pop"]},"context_links":{"doc_id":"feitsui_1223","prev_line_id":"lyr_5Y2i5ben6Z-z_MTIyMw_0010","next_line_id":"lyr_5Y2i5ben6Z-z_MTIyMw_0012","paragraph_id":"para_03"}}
