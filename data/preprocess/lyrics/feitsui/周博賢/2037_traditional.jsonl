{"id":"lyr_6LCi5a6J55Cq_MjAzNw_0021","text":"不可思異 看看本週的雜誌","structure":{"line_index":21,"char_count":11},"semantics":{"themes":["社會現象","審美標準"],"sentiment":"NEGATIVE","keywords":["雜誌","看看"]},"prosody":{"tone_pattern":[3,9,3,2,4,4,9,3,3,2,4],"tone_pattern_cantonese_jyutping":["bat1","ho2","si1","ji6","hon3","hon3","bun2","zau1","dik1","zaap6","zi3"]},"nlp":{"tokens":[{"text":"不可","pos":"ADV"},{"text":"思異","pos":"ADJ"},{"text":"看看","pos":"VERB"},{"text":"本週","pos":"NOUN"},{"text":"的","pos":"PART"},{"text":"雜誌","pos":"NOUN"}],"syntax_notes":"再次以「不可思議」表達對社會審美標準的驚訝，並以「雜誌」作為傳播這些標準的媒介。"},"source":{"title":"姿色份子","artists":["謝安琪"],"lyricists":["周博賢"],"year":0,"genre":["Cantopop","Social Commentary"]},"context_links":{"doc_id":"feitsui_2037","prev_line_id":"lyr_6LCi5a6J55Cq_MjAzNw_0020","next_line_id":"lyr_6LCi5a6J55Cq_MjAzNw_0022","paragraph_id":"para_07"}}
