{"id":"lyr_6I2J6Jyi_MTIyNw_0013","text":"感激你蕩來 而令人生簡樸但可愛","structure":{"line_index":13,"char_count":14},"semantics":{"themes":["感激","愛情的影響","生活的簡樸與美好"],"sentiment":"VERY_POSITIVE","keywords":["感激","令人","生","簡樸","可愛"]},"prosody":{"tone_pattern":[9,3,5,2,0,0,2,0,3,9,4,2,9,4],"tone_pattern_cantonese_jyutping":["gam2","gik1","nei5","dong6","loi4","ji4","ling6","jan4","sang1","gaan2","pok3","daan6","ho2","oi3"]},"nlp":{"tokens":[{"text":"感激","pos":"VERB"},{"text":"你蕩來","pos":"VERB"},{"text":"而","pos":"CONJ"},{"text":"令人","pos":"VERB"},{"text":"生","pos":"VERB"},{"text":"簡樸","pos":"ADJ"},{"text":"但","pos":"CONJ"},{"text":"可愛","pos":"ADJ"}],"syntax_notes":"再次表達感激，說明「你」的出現讓生活變得簡樸卻充滿可愛之處。"},"source":{"title":"ABC","artists":["草蜢"],"lyricists":["林振強"],"year":0,"genre":["Pop"]},"context_links":{"doc_id":"feitsui_1227","prev_line_id":"lyr_6I2J6Jyi_MTIyNw_0012","next_line_id":"lyr_6I2J6Jyi_MTIyNw_0014","paragraph_id":"para_03"}}
