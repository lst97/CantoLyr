{"id":"lyr_6I2J6Jyi_MTIyNw_0001","text":"簡單說你知","structure":{"line_index":1,"char_count":5},"semantics":{"themes":["簡潔說明"],"sentiment":"NEUTRAL","keywords":["簡單","說","你","知"]},"prosody":{"tone_pattern":[9,3,4,5,3],"tone_pattern_cantonese_jyutping":["gaan2","daan1","syut3","nei5","zi1"]},"nlp":{"tokens":[{"text":"簡單","pos":"ADJ"},{"text":"說","pos":"VERB"},{"text":"你","pos":"PRON"},{"text":"知","pos":"VERB"}],"syntax_notes":"以簡單直接的語氣開頭，引導聽眾進入歌曲的情境。"},"source":{"title":"ABC","artists":["草蜢"],"lyricists":["林振強"],"year":0,"genre":["Pop"]},"context_links":{"doc_id":"feitsui_1227","prev_line_id":null,"next_line_id":"lyr_6I2J6Jyi_MTIyNw_0002","paragraph_id":"para_01"}}
