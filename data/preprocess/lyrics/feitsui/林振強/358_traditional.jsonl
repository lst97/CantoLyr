{"id":"lyr_6ZmI5aWV6L-F_MzU4_0008","text":"每望向將來 都找到你","structure":{"line_index":8,"char_count":9},"semantics":{"themes":["未來中的伴侶","尋找慰藉"],"sentiment":"POSITIVE","keywords":["望","將來","找到"]},"prosody":{"tone_pattern":[5,2,4,3,0,3,9,4,5],"tone_pattern_cantonese_jyutping":["mui5","mong6","hoeng3","zoeng1","loi4","dou1","zaau2","dou3","nei5"]},"nlp":{"tokens":[{"text":"每望","pos":"VERB"},{"text":"向","pos":"ADP"},{"text":"將來","pos":"NOUN"},{"text":"都","pos":"ADV"},{"text":"找到","pos":"VERB"},{"text":"你","pos":"PRON"}],"syntax_notes":"簡單直接的陳述，表達對未來的展望總是與對方聯繫在一起。"},"source":{"title":"每一個明天","artists":["陳奕迅"],"lyricists":["林振強"],"year":0,"genre":["Cantopop","Love Song","Inspirational"]},"context_links":{"doc_id":"feitsui_358","prev_line_id":"lyr_6ZmI5aWV6L-F_MzU4_0007","next_line_id":"lyr_6ZmI5aWV6L-F_MzU4_0009","paragraph_id":"para_03"}}
