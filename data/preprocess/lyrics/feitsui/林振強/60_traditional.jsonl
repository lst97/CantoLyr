{"id":"lyr_5byg5a2m5Y-L_NjA_0012","text":"冷冷雨 沒焦點因找不到你","structure":{"line_index":12,"char_count":11},"semantics":{"themes":["失落","孤獨","雨"],"sentiment":"VERY_NEGATIVE","keywords":["冷冷雨","沒焦點","找不到你"]},"prosody":{"tone_pattern":[5,5,5,2,3,9,3,9,3,4,5],"tone_pattern_cantonese_jyutping":["laang5","laang5","jyu5","mut6","ziu1","dim2","jan1","zaau2","bat1","dou3","nei5"]},"nlp":{"tokens":[{"text":"冷冷","pos":"ADJ"},{"text":"雨","pos":"NOUN"},{"text":"沒","pos":"VERB"},{"text":"焦點","pos":"NOUN"},{"text":"因找","pos":"VERB"},{"text":"不到","pos":"VERB"},{"text":"你","pos":"PRON"}],"syntax_notes":"將冷雨比喻為失去焦點，因找不到愛人而感到失落。"},"source":{"title":"藍雨","artists":["張學友"],"lyricists":["林振強"],"year":0,"genre":["Cantopop","Ballad"]},"context_links":{"doc_id":"feitsui_60","prev_line_id":"lyr_5byg5a2m5Y-L_NjA_0011","next_line_id":"lyr_5byg5a2m5Y-L_NjA_0013","paragraph_id":"para_03"}}
