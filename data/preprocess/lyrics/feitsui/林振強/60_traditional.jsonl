{"id":"lyr_5byg5a2m5Y-L_NjA_0007","text":"曾很喜歡 陰陰天","structure":{"line_index":7,"char_count":7},"semantics":{"themes":["回憶","情感","天氣"],"sentiment":"POSITIVE","keywords":["喜歡","陰陰天"]},"prosody":{"tone_pattern":[0,9,9,3,3,3,3],"tone_pattern_cantonese_jyutping":["cang4","han2","hei2","fun1","jam1","jam1","tin1"]},"nlp":{"tokens":[{"text":"曾","pos":"ADV"},{"text":"很","pos":"ADV"},{"text":"喜歡","pos":"VERB"},{"text":"陰陰","pos":"ADJ"},{"text":"天","pos":"NOUN"}],"syntax_notes":"回憶過去對陰天的喜愛，與現在的情感形成對比。"},"source":{"title":"藍雨","artists":["張學友"],"lyricists":["林振強"],"year":0,"genre":["Cantopop","Ballad"]},"context_links":{"doc_id":"feitsui_60","prev_line_id":"lyr_5byg5a2m5Y-L_NjA_0006","next_line_id":"lyr_5byg5a2m5Y-L_NjA_0008","paragraph_id":"para_02"}}
