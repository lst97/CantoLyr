{"id":"lyr_5byg5a2m5Y-L_NjA_0009","text":"在微涼風中灑向你輕吻你面","structure":{"line_index":9,"char_count":12},"semantics":{"themes":["回憶","情感","親密"],"sentiment":"POSITIVE","keywords":["灑向","輕吻","你面"]},"prosody":{"tone_pattern":[2,0,0,3,3,9,4,5,3,5,5,2],"tone_pattern_cantonese_jyutping":["zoi6","mei4","loeng4","fung1","zung1","saa2","hoeng3","nei5","hing1","man5","nei5","min6"]},"nlp":{"tokens":[{"text":"在","pos":"ADP"},{"text":"微","pos":"ADJ"},{"text":"涼風","pos":"NOUN"},{"text":"中","pos":"NOUN"},{"text":"灑向","pos":"VERB"},{"text":"你","pos":"PRON"},{"text":"輕吻","pos":"VERB"},{"text":"你面","pos":"NOUN"}],"syntax_notes":"描繪雨點灑在臉上如同親吻，充滿愛意和溫馨的回憶。"},"source":{"title":"藍雨","artists":["張學友"],"lyricists":["林振強"],"year":0,"genre":["Cantopop","Ballad"]},"context_links":{"doc_id":"feitsui_60","prev_line_id":"lyr_5byg5a2m5Y-L_NjA_0008","next_line_id":"lyr_5byg5a2m5Y-L_NjA_0010","paragraph_id":"para_02"}}
