{"id":"lyr_5p2o5Y2D5ayF_MjI2MA_0020","text":"你撤退 跟他好一對愛侶 我走開你沒負累","structure":{"line_index":20,"char_count":17},"semantics":{"themes":["離開","解脫","關係結束"],"sentiment":"POSITIVE","keywords":["撤退","愛侶","負累"]},"prosody":{"tone_pattern":[5,4,4,3,3,9,3,4,4,5,5,9,3,5,2,2,5],"tone_pattern_cantonese_jyutping":["nei5","cit3","teoi3","gan1","taa1","hou2","jat1","deoi3","oi3","leoi5","ngo5","zau2","hoi1","nei5","mut6","fu6","leoi5"]},"nlp":{"tokens":[{"text":"你","pos":"PRON"},{"text":"撤退","pos":"VERB"},{"text":"跟","pos":"ADP"},{"text":"他","pos":"PRON"},{"text":"好","pos":"ADJ"},{"text":"一對","pos":"NUM"},{"text":"愛侶","pos":"NOUN"},{"text":"我","pos":"PRON"},{"text":"走開","pos":"VERB"},{"text":"你","pos":"PRON"},{"text":"沒","pos":"VERB"},{"text":"負累","pos":"NOUN"}],"syntax_notes":"描述「你」的離開，以及「我」因此獲得解脫，不再有負擔。"},"source":{"title":"滾","artists":["楊千嬅"],"lyricists":["梁漢文","林夕"],"year":0,"genre":["Cantopop","Pop"]},"context_links":{"doc_id":"feitsui_2260","prev_line_id":"lyr_5p2o5Y2D5ayF_MjI2MA_0019","next_line_id":"lyr_5p2o5Y2D5ayF_MjI2MA_0021","paragraph_id":"para_05"}}
{"id":"lyr_5p2o5Y2D5ayF_MjI2MA_0021","text":"請你滾 滾出去","structure":{"line_index":21,"char_count":6},"semantics":{"themes":["驅逐","結束"],"sentiment":"VERY_NEGATIVE","keywords":["滾","滾出去"]},"prosody":{"tone_pattern":[9,5,9,9,3,4],"tone_pattern_cantonese_jyutping":["cing2","nei5","gwan2","gwan2","ceot1","heoi3"]},"nlp":{"tokens":[{"text":"請","pos":"INTJ"},{"text":"你","pos":"PRON"},{"text":"滾","pos":"VERB"},{"text":"滾出去","pos":"VERB"}],"syntax_notes":"直接且強烈地要求「你」離開，語氣非常決絕。"},"source":{"title":"滾","artists":["楊千嬅"],"lyricists":["梁漢文","林夕"],"year":0,"genre":["Cantopop","Pop"]},"context_links":{"doc_id":"feitsui_2260","prev_line_id":"lyr_5p2o5Y2D5ayF_MjI2MA_0020","next_line_id":"lyr_5p2o5Y2D5ayF_MjI2MA_0022","paragraph_id":"para_06"}}
