{"id":"lyr_5Y-k5beo5Z-6_MzUwNA_0007","text":"幸運響聲 能提醒你","structure":{"line_index":7,"char_count":8},"semantics":{"themes":["提醒","存在","連結"],"sentiment":"POSITIVE","keywords":["幸運","響聲","提醒"]},"prosody":{"tone_pattern":[2,2,9,3,0,0,9,5],"tone_pattern_cantonese_jyutping":["hang6","wan6","hoeng2","sing1","nang4","tai4","sing2","nei5"]},"nlp":{"tokens":[{"text":"幸運","pos":"ADJ"},{"text":"響聲","pos":"NOUN"},{"text":"能","pos":"AUX"},{"text":"提醒","pos":"VERB"},{"text":"你","pos":"PRON"}],"syntax_notes":"「幸運響聲」點出鈴聲的意義，「能提醒你」直接表達其功能。"},"source":{"title":"幸運鈴聲","artists":["古巨基"],"lyricists":["陳少琪"],"year":0,"genre":["Pop","Ballad"]},"context_links":{"doc_id":"feitsui_3504","prev_line_id":"lyr_5Y-k5beo5Z-6_MzUwNA_0006","next_line_id":"lyr_5Y-k5beo5Z-6_MzUwNA_0008","paragraph_id":"para_02"}}
