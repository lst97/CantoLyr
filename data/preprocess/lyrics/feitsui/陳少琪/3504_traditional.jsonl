{"id":"lyr_5Y-k5beo5Z-6_MzUwNA_0013","text":"這個作者歡笑過","structure":{"line_index":13,"char_count":7},"semantics":{"themes":["回憶","創作","情感"],"sentiment":"POSITIVE","keywords":["作者","歡笑"]},"prosody":{"tone_pattern":[5,4,4,9,3,4,4],"tone_pattern_cantonese_jyutping":["ze5","go3","zok3","ze2","fun1","siu3","gwo3"]},"nlp":{"tokens":[{"text":"這個","pos":"DET"},{"text":"作者","pos":"NOUN"},{"text":"歡笑","pos":"VERB"},{"text":"過","pos":"PART"}],"syntax_notes":"「這個作者歡笑過」是對過去創作時美好心情的回顧，與上一句的離別預示形成對比。"},"source":{"title":"幸運鈴聲","artists":["古巨基"],"lyricists":["陳少琪"],"year":0,"genre":["Pop","Ballad"]},"context_links":{"doc_id":"feitsui_3504","prev_line_id":"lyr_5Y-k5beo5Z-6_MzUwNA_0012","next_line_id":"lyr_5Y-k5beo5Z-6_MzUwNA_0014","paragraph_id":"para_02"}}
