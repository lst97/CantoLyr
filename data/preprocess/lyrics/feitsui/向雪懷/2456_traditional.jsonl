{"id":"lyr_5byg5L-h5ZOy_MjQ1Ng_0005","text":"一些悲傷都交給我","structure":{"line_index":5,"char_count":8},"semantics":{"themes":["承擔悲傷","犧牲"],"sentiment":"NEGATIVE","keywords":["悲傷","交給"]},"prosody":{"tone_pattern":[3,3,3,3,3,3,3,5],"tone_pattern_cantonese_jyutping":["jat1","se1","bei1","soeng1","dou1","gaau1","kap1","ngo5"]},"nlp":{"tokens":[{"text":"一些","pos":"DET"},{"text":"悲傷","pos":"NOUN"},{"text":"都","pos":"ADV"},{"text":"交給","pos":"VERB"},{"text":"我","pos":"PRON"}],"syntax_notes":"「都交給我」表明了敘述者願意承擔所有的悲傷，帶有犧牲的意味。"},"source":{"title":"不必多說話","artists":["張信哲"],"lyricists":["向雪懷"],"year":0,"genre":["Mandopop","Cantopop"]},"context_links":{"doc_id":"feitsui_2456","prev_line_id":"lyr_5byg5L-h5ZOy_MjQ1Ng_0004","next_line_id":"lyr_5byg5L-h5ZOy_MjQ1Ng_0006","paragraph_id":"para_01"}}
