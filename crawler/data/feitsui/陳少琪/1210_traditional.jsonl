{"id": "lyr_5qKB5ZKP55Cq_MTIxMA_0022", "text": "它太善良吧 它的眼淚留下", "structure": {"line_index": 22, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 2, 0, 2, 3, 3, 5, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["taa1", "taai3", "sin6", "loeng4", "baa6", "taa1", "dik1", "ngaan5", "leoi6", "lau4", "haa6"]}, "nlp": {"tokens": [{"text": "它", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "善良", "pos": "X"}, {"text": "吧", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "眼淚", "pos": "X"}, {"text": "留下", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "傷心尋回犬", "artists": ["梁詠琪"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1210", "prev_line_id": "lyr_5qKB5ZKP55Cq_MTIxMA_0021", "next_line_id": "lyr_5qKB5ZKP55Cq_MTIxMA_0023", "paragraph_id": "para_04"}}
{"id": "lyr_5qKB5ZKP55Cq_MTIxMA_0023", "text": "像習慣每天躺下來讓我檢查 很想留在這家", "structure": {"line_index": 23, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 4, 5, 3, 9, 2, 0, 2, 5, 9, 0, 9, 9, 0, 2, 5, 3], "tone_pattern_cantonese_jyutping": ["zoeng6", "zaap6", "gwaan3", "mui5", "tin1", "tong2", "haa6", "loi4", "joeng6", "ngo5", "gim2", "caa4", "han2", "soeng2", "lau4", "zoi6", "ze5", "gaa1"]}, "nlp": {"tokens": [{"text": "像", "pos": "X"}, {"text": "習慣", "pos": "X"}, {"text": "每天", "pos": "X"}, {"text": "躺下來", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "檢查", "pos": "X"}, {"text": "很想", "pos": "X"}, {"text": "留在", "pos": "X"}, {"text": "這家", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "傷心尋回犬", "artists": ["梁詠琪"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1210", "prev_line_id": "lyr_5qKB5ZKP55Cq_MTIxMA_0022", "next_line_id": "lyr_5qKB5ZKP55Cq_MTIxMA_0024", "paragraph_id": "para_04"}}
