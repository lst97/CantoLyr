{"id": "lyr_5qKF6Imz6Iqz_NjY1OA_0005", "text": "從前模糊地愛過 從來無問是對錯", "structure": {"line_index": 5, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 2, 4, 4, 0, 0, 0, 2, 2, 4, 4], "tone_pattern_cantonese_jyutping": ["cung4", "cin4", "mou4", "wu4", "dei6", "oi3", "gwo3", "cung4", "loi4", "mou4", "man6", "si6", "deoi3", "co3"]}, "nlp": {"tokens": [{"text": "從前", "pos": "X"}, {"text": "模糊地", "pos": "X"}, {"text": "愛過", "pos": "X"}, {"text": "從來", "pos": "X"}, {"text": "無問", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "對錯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "無人願愛我", "artists": ["梅豔芳"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6658", "prev_line_id": "lyr_5qKF6Imz6Iqz_NjY1OA_0004", "next_line_id": "lyr_5qKF6Imz6Iqz_NjY1OA_0006", "paragraph_id": "para_02"}}
