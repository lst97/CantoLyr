{"id": "lyr_546L6I-y_MTE5NA_0008", "text": "縱獨自飛走 完全不想悔疚", "structure": {"line_index": 8, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 2, 3, 9, 0, 0, 3, 9, 4, 4], "tone_pattern_cantonese_jyutping": ["zung3", "duk6", "zi6", "fei1", "zau2", "jyun4", "cyun4", "bat1", "soeng2", "fui3", "gau3"]}, "nlp": {"tokens": [{"text": "縱", "pos": "X"}, {"text": "獨自", "pos": "X"}, {"text": "飛走", "pos": "X"}, {"text": "完全", "pos": "X"}, {"text": "不想", "pos": "X"}, {"text": "悔疚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "執迷不悔", "artists": ["王菲"], "lyricists": ["陳少琪"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1194", "prev_line_id": "lyr_546L6I-y_MTE5NA_0007", "next_line_id": "lyr_546L6I-y_MTE5NA_0009", "paragraph_id": "para_02"}}
