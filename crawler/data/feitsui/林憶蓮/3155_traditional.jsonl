{"id": "lyr_5byg5Zu96I2j_MzE1NQ_0018", "text": "偷偷感激你(多麼感激你) 能讓我再試這滋味", "structure": {"line_index": 18, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 9, 3, 5, 3, 9, 3, 0, 2, 5, 4, 4, 5, 3, 2], "tone_pattern_cantonese_jyutping": ["tau1", "tau1", "gam2", "gik1", "nei5", "mo1", "gam2", "gik1", "nang4", "joeng6", "ngo5", "zoi3", "si3", "ze5", "zi1", "mei6"]}, "nlp": {"tokens": [{"text": "偷偷", "pos": "X"}, {"text": "感激", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "(", "pos": "X"}, {"text": "多麼", "pos": "X"}, {"text": "感激", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": ")", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "再試", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "滋味", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "赤裸的祕密", "artists": ["張國榮"], "lyricists": ["林憶蓮", "潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3155", "prev_line_id": "lyr_5byg5Zu96I2j_MzE1NQ_0017", "next_line_id": "lyr_5byg5Zu96I2j_MzE1NQ_0019", "paragraph_id": "para_04"}}
{"id": "lyr_5byg5Zu96I2j_MzE1NQ_0019", "text": "無奈我卻怕愛比刀鋒更利 更癡戀也是要捨棄", "structure": {"line_index": 19, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 4, 4, 4, 9, 3, 3, 2, 3, 9, 5, 2, 4, 9, 4], "tone_pattern_cantonese_jyutping": ["mou4", "noi6", "ngo5", "koek3", "paa3", "oi3", "bei2", "dou1", "fung1", "lei6", "ci1", "lyun2", "jaa5", "si6", "jiu3", "se2", "hei3"]}, "nlp": {"tokens": [{"text": "無奈", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "怕", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "刀鋒", "pos": "X"}, {"text": "更利", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "癡戀", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "捨棄", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "赤裸的祕密", "artists": ["張國榮"], "lyricists": ["林憶蓮", "潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3155", "prev_line_id": "lyr_5byg5Zu96I2j_MzE1NQ_0018", "next_line_id": "lyr_5byg5Zu96I2j_MzE1NQ_0020", "paragraph_id": "para_04"}}
