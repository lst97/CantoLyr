{"id": "lyr_6K645Yag5p2w_NjM1NQ_0004", "text": "問天賜幾許佳偶 離合悲歡定必有", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 3, 4, 9, 9, 3, 5, 0, 2, 3, 3, 2, 3, 5], "tone_pattern_cantonese_jyutping": ["man6", "tin1", "ci3", "gei2", "heoi2", "gaai1", "ngau5", "lei4", "hap6", "bei1", "fun1", "ding6", "bit1", "jau5"]}, "nlp": {"tokens": [{"text": "問", "pos": "X"}, {"text": "天賜", "pos": "X"}, {"text": "幾許", "pos": "X"}, {"text": "佳偶", "pos": "X"}, {"text": "離合悲歡", "pos": "X"}, {"text": "定必", "pos": "X"}, {"text": "有", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "杯酒當歌", "artists": ["許冠傑"], "lyricists": ["黎彼得"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6355", "prev_line_id": "lyr_6K645Yag5p2w_NjM1NQ_0003", "next_line_id": "lyr_6K645Yag5p2w_NjM1NQ_0005", "paragraph_id": "para_02"}}
