{"id": "lyr_5byg5Zu96I2j_NjE2OQ_0006", "text": "別讓淚水 沾溼此眼睛", "structure": {"line_index": 6, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 9, 3, 3, 9, 5, 3], "tone_pattern_cantonese_jyutping": ["bit6", "joeng6", "leoi6", "seoi2", "zim1", "sap1", "ci2", "ngaan5", "zing1"]}, "nlp": {"tokens": [{"text": "別", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "淚水", "pos": "X"}, {"text": "沾溼", "pos": "X"}, {"text": "此", "pos": "X"}, {"text": "眼睛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "燒燬我眼睛", "artists": ["張國榮"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6169", "prev_line_id": "lyr_5byg5Zu96I2j_NjE2OQ_0005", "next_line_id": "lyr_5byg5Zu96I2j_NjE2OQ_0007", "paragraph_id": "para_02"}}
