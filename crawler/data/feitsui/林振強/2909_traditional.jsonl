{"id": "lyr_5qKF6Imz6Iqz_MjkwOQ_0011", "text": "或有天她都可叫座 她也許有天不再餓", "structure": {"line_index": 11, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 3, 3, 3, 9, 4, 2, 3, 5, 9, 5, 3, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["waak6", "jau5", "tin1", "taa1", "dou1", "ho2", "giu3", "zo6", "taa1", "jaa5", "heoi2", "jau5", "tin1", "bat1", "zoi3", "ngo6"]}, "nlp": {"tokens": [{"text": "或", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "天", "pos": "X"}, {"text": "她", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "可", "pos": "X"}, {"text": "叫座", "pos": "X"}, {"text": "她", "pos": "X"}, {"text": "也許", "pos": "X"}, {"text": "有天", "pos": "X"}, {"text": "不再", "pos": "X"}, {"text": "餓", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "歌之女", "artists": ["梅豔芳"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2909", "prev_line_id": "lyr_5qKF6Imz6Iqz_MjkwOQ_0010", "next_line_id": "lyr_5qKF6Imz6Iqz_MjkwOQ_0012", "paragraph_id": "para_03"}}
