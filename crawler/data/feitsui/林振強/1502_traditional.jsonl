{"id": "lyr_5p6X5b-G6I6y_MTUwMg_0003", "text": "你對我說 好嗎 一切好嗎 曾找到真愛吧", "structure": {"line_index": 3, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 4, 9, 3, 3, 4, 9, 3], "tone_pattern_cantonese_jyutping": ["nei5", "deoi3", "ngo5", "syut3", "hou2", "maa1", "jat1", "cai3", "hou2", "maa1"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "一切", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "找到", "pos": "X"}, {"text": "真愛", "pos": "X"}, {"text": "吧", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "依然", "artists": ["林憶蓮"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1502", "prev_line_id": "lyr_5p6X5b-G6I6y_MTUwMg_0002", "next_line_id": "lyr_5p6X5b-G6I6y_MTUwMg_0004", "paragraph_id": "para_01"}}
