{"id": "lyr_5p6X5b-G6I6y_MTUwMg_0005", "text": "知否你的聲音 仍令這靜止的心 翻滾", "structure": {"line_index": 5, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 5, 3, 3, 3, 0, 2, 5, 2, 9, 3, 3, 3, 9], "tone_pattern_cantonese_jyutping": ["zi1", "fau2", "nei5", "dik1", "sing1", "jam1", "jing4", "ling6", "ze5", "zing6", "zi2", "dik1", "sam1", "faan1", "gwan2"]}, "nlp": {"tokens": [{"text": "知否", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "聲音", "pos": "X"}, {"text": "仍令", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "靜止", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心", "pos": "X"}, {"text": "翻滾", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "依然", "artists": ["林憶蓮"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1502", "prev_line_id": "lyr_5p6X5b-G6I6y_MTUwMg_0004", "next_line_id": "lyr_5p6X5b-G6I6y_MTUwMg_0006", "paragraph_id": "para_01"}}
{"id": "lyr_5p6X5b-G6I6y_MTUwMg_0006", "text": "我倆有過凌晨 一起看過夜深", "structure": {"line_index": 6, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 5, 4, 0, 0, 3, 9, 4, 4, 2, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "loeng5", "jau5", "gwo3", "ling4", "san4", "jat1", "hei2", "hon3", "gwo3", "je6", "sam1"]}, "nlp": {"tokens": [{"text": "我倆", "pos": "X"}, {"text": "有過", "pos": "X"}, {"text": "凌晨", "pos": "X"}, {"text": "一起", "pos": "X"}, {"text": "看過", "pos": "X"}, {"text": "夜深", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "依然", "artists": ["林憶蓮"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1502", "prev_line_id": "lyr_5p6X5b-G6I6y_MTUwMg_0005", "next_line_id": "lyr_5p6X5b-G6I6y_MTUwMg_0007", "paragraph_id": "para_01"}}
