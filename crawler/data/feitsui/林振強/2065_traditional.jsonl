{"id": "lyr_5byg5a2m5Y-L_MjA2NQ_0006", "text": "當見他吻着你 夢和脈搏爆開", "structure": {"line_index": 6, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 3, 5, 2, 5, 2, 0, 2, 4, 4, 3], "tone_pattern_cantonese_jyutping": ["gin3", "taa1", "man5", "zoek6", "nei5", "mung6", "wo4", "mak6", "bok3", "baau3", "hoi1"]}, "nlp": {"tokens": [{"text": "當見", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "吻", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "夢", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "脈搏", "pos": "X"}, {"text": "爆開", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "狂", "artists": ["張學友"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2065", "prev_line_id": "lyr_5byg5a2m5Y-L_MjA2NQ_0005", "next_line_id": "lyr_5byg5a2m5Y-L_MjA2NQ_0007", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5a2m5Y-L_MjA2NQ_0007", "text": "但自卑的心窩痛死 明白是我高攀不起你", "structure": {"line_index": 7, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 3, 3, 3, 3, 4, 9, 0, 2, 2, 5, 3, 3, 3, 9, 5], "tone_pattern_cantonese_jyutping": ["daan6", "zi6", "bei1", "dik1", "sam1", "wo1", "tung3", "sei2", "ming4", "baak6", "si6", "ngo5", "gou1", "paan1", "bat1", "hei2", "nei5"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "自卑", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心窩", "pos": "X"}, {"text": "痛死", "pos": "X"}, {"text": "明白", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "高攀不起", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "狂", "artists": ["張學友"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2065", "prev_line_id": "lyr_5byg5a2m5Y-L_MjA2NQ_0006", "next_line_id": "lyr_5byg5a2m5Y-L_MjA2NQ_0008", "paragraph_id": "para_01"}}
