{"id": "lyr_5byg5a2m5Y-L_MjA2NQ_0002", "text": "你令我像頭被囚狼 在發瘋 碰撞", "structure": {"line_index": 2, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 5, 2, 0, 2, 0, 0, 2, 4, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["nei5", "ling6", "ngo5", "zoeng6", "tau4", "bei6", "cau4", "long4", "zoi6", "faat3", "fung1", "pung3", "zong6"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "令", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "像頭", "pos": "X"}, {"text": "被囚", "pos": "X"}, {"text": "狼", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "發瘋", "pos": "X"}, {"text": "碰撞", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "狂", "artists": ["張學友"], "lyricists": ["林振強"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2065", "prev_line_id": "lyr_5byg5a2m5Y-L_MjA2NQ_0001", "next_line_id": "lyr_5byg5a2m5Y-L_MjA2NQ_0003", "paragraph_id": "para_01"}}
