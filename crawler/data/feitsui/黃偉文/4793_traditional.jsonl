{"id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0007", "text": "原罪太純潔 你跟我開色戒 大抵不受控", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 0, 4, 5, 3, 5, 3, 3, 4, 2, 9, 3, 2, 4], "tone_pattern_cantonese_jyutping": ["jyun4", "zeoi6", "taai3", "seon4", "git3", "nei5", "gan1", "ngo5", "hoi1", "sik1", "gaai3", "daai6", "dai2", "bat1", "sau6", "hung3"]}, "nlp": {"tokens": [{"text": "原罪", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "純潔", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "開色", "pos": "X"}, {"text": "戒", "pos": "X"}, {"text": "大抵", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "受控", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "零號", "artists": ["楊千嬅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4793", "prev_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0006", "next_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0008", "paragraph_id": "para_02"}}
