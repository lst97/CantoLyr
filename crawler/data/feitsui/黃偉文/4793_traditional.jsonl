{"id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0003", "text": "如福音 不過是沒法感動我的情信", "structure": {"line_index": 3, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 3, 4, 2, 2, 4, 9, 2, 5, 3, 0, 4], "tone_pattern_cantonese_jyutping": ["jyu4", "fuk1", "jam1", "bat1", "gwo3", "si6", "mut6", "faat3", "gam2", "dung6", "ngo5", "dik1", "cing4", "seon3"]}, "nlp": {"tokens": [{"text": "如", "pos": "X"}, {"text": "福音", "pos": "X"}, {"text": "不過", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "沒法", "pos": "X"}, {"text": "感動", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "情信", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "零號", "artists": ["楊千嬅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4793", "prev_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0002", "next_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0004", "text": "誰願愛愛我 我就誰都信奉", "structure": {"line_index": 4, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 4, 5, 5, 2, 0, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["seoi4", "jyun6", "oi3", "oi3", "ngo5", "ngo5", "zau6", "seoi4", "dou1", "seon3", "fung6"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "願", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "信奉", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "零號", "artists": ["楊千嬅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4793", "prev_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0003", "next_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0005", "text": "難道天主的愛寵 未能符合我的標準", "structure": {"line_index": 5, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 3, 9, 3, 4, 9, 2, 0, 0, 2, 5, 3, 3, 9], "tone_pattern_cantonese_jyutping": ["naan4", "dou6", "tin1", "zyu2", "dik1", "oi3", "cung2", "mei6", "nang4", "fu4", "hap6", "ngo5", "dik1", "biu1", "zeon2"]}, "nlp": {"tokens": [{"text": "難道", "pos": "X"}, {"text": "天主", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "寵", "pos": "X"}, {"text": "未能", "pos": "X"}, {"text": "符合", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "標準", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "零號", "artists": ["楊千嬅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4793", "prev_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0004", "next_line_id": "lyr_5p2o5Y2D5ayF_NDc5Mw_0006", "paragraph_id": "para_01"}}
