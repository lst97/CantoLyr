{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0017", "text": "或者我 驀然回首 旅途愉快過就夠", "structure": {"line_index": 17, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 9, 5, 2, 0, 0, 9, 5, 0, 0, 4, 4, 2, 4], "tone_pattern_cantonese_jyutping": ["waak6", "ze2", "ngo5", "mak6", "jin4", "wui4", "sau2", "leoi5", "tou4", "jyu4", "faai3", "gwo3", "zau6", "gau3"]}, "nlp": {"tokens": [{"text": "或者", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "驀然回首", "pos": "X"}, {"text": "旅途愉快", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "夠", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0016", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0018", "paragraph_id": "para_03"}}
