{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0015", "text": "還憑什麼搏鬥", "structure": {"line_index": 15, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 3, 4, 4], "tone_pattern_cantonese_jyutping": ["waan4", "pang4", "sam6", "mo1", "bok3", "dau3"]}, "nlp": {"tokens": [{"text": "還", "pos": "X"}, {"text": "憑", "pos": "X"}, {"text": "什麼", "pos": "X"}, {"text": "搏鬥", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0014", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0016", "paragraph_id": "para_03"}}
