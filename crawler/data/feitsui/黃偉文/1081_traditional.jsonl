{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0027", "text": "但最後 未想過放棄 但被人放棄", "structure": {"line_index": 27, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 2, 2, 9, 4, 4, 4, 2, 2, 0, 4, 4], "tone_pattern_cantonese_jyutping": ["daan6", "zeoi3", "hau6", "mei6", "soeng2", "gwo3", "fong3", "hei3", "daan6", "bei6", "jan4", "fong3", "hei3"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "最後", "pos": "X"}, {"text": "未想", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "放棄", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "放棄", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0026", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0028", "paragraph_id": "para_05"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0028", "text": "變成前男友的你", "structure": {"line_index": 28, "char_count": 7}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 0, 0, 0, 5, 3, 5], "tone_pattern_cantonese_jyutping": ["bin3", "sing4", "cin4", "naam4", "jau5", "dik1", "nei5"]}, "nlp": {"tokens": [{"text": "變成", "pos": "X"}, {"text": "前男友", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0027", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0029", "paragraph_id": "para_05"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0029", "text": "走 要是更喜歡自由", "structure": {"line_index": 29, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 2, 9, 3, 2, 0], "tone_pattern_cantonese_jyutping": ["zau2", "jiu3", "si6", "hei2", "fun1", "zi6", "jau4"]}, "nlp": {"tokens": [{"text": "走", "pos": "X"}, {"text": "要是", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "自由", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0028", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0030", "paragraph_id": "para_06"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0030", "text": "相愛不夠 隨意作藉口 都夠分手", "structure": {"line_index": 30, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 3, 4, 0, 4, 4, 2, 9, 3, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["oi3", "bat1", "gau3", "ceoi4", "ji3", "zok3", "zik6", "hau2", "dou1", "gau3", "fan1", "sau2"]}, "nlp": {"tokens": [{"text": "相愛", "pos": "X"}, {"text": "不夠", "pos": "X"}, {"text": "隨意", "pos": "X"}, {"text": "作", "pos": "X"}, {"text": "藉口", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "夠", "pos": "X"}, {"text": "分手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0029", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0031", "paragraph_id": "para_06"}}
