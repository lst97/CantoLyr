{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0003", "text": "但這秒 我正式得不到你", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 5, 5, 4, 3, 3, 3, 4, 5], "tone_pattern_cantonese_jyutping": ["daan6", "ze5", "miu5", "ngo5", "zing3", "sik1", "dak1", "bat1", "dou3", "nei5"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "秒", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "正式", "pos": "X"}, {"text": "得不到", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0002", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0004", "text": "願我失戀名單結尾 最後一個是你", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 3, 9, 0, 3, 4, 5, 4, 2, 3, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["jyun6", "ngo5", "sat1", "lyun2", "ming4", "daan1", "git3", "mei5", "zeoi3", "hau6", "jat1", "go3", "si6", "nei5"]}, "nlp": {"tokens": [{"text": "願", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "失戀", "pos": "X"}, {"text": "名單", "pos": "X"}, {"text": "結尾", "pos": "X"}, {"text": "最後", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0003", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0005", "paragraph_id": "para_01"}}
