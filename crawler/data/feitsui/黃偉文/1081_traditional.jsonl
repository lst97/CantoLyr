{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0006", "text": "其實 犯遍了錯誤先碰着你", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 4, 5, 4, 2, 3, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["kei4", "sat6", "faan6", "pin3", "liu5", "co3", "ng6", "sin1", "pung3", "zoek6", "nei5"]}, "nlp": {"tokens": [{"text": "其實", "pos": "X"}, {"text": "犯遍", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "錯誤", "pos": "X"}, {"text": "先", "pos": "X"}, {"text": "碰", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0005", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0007", "text": "自信我會懂 怎去愛你", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 5, 9, 9, 4, 4, 5], "tone_pattern_cantonese_jyutping": ["zi6", "seon3", "ngo5", "dung2", "zam2", "heoi3", "oi3", "nei5"]}, "nlp": {"tokens": [{"text": "自信", "pos": "X"}, {"text": "我會", "pos": "X"}, {"text": "懂", "pos": "X"}, {"text": "怎去", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0006", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0008", "text": "盼望 最喜歡那個 是最後", "structure": {"line_index": 8, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 4, 9, 3, 5, 4, 2, 4, 2], "tone_pattern_cantonese_jyutping": ["paan3", "mong6", "zeoi3", "hei2", "fun1", "naa5", "go3", "si6", "zeoi3", "hau6"]}, "nlp": {"tokens": [{"text": "盼望", "pos": "X"}, {"text": "最", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "那個", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "最後", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0007", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0009", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0009", "text": "但最後 未想過放棄 但被人放棄", "structure": {"line_index": 9, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 2, 2, 9, 4, 4, 4, 2, 2, 0, 4, 4], "tone_pattern_cantonese_jyutping": ["daan6", "zeoi3", "hau6", "mei6", "soeng2", "gwo3", "fong3", "hei3", "daan6", "bei6", "jan4", "fong3", "hei3"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "最後", "pos": "X"}, {"text": "未想", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "放棄", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "放棄", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0008", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0010", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0010", "text": "變成前男友的你", "structure": {"line_index": 10, "char_count": 7}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 0, 0, 0, 5, 3, 5], "tone_pattern_cantonese_jyutping": ["bin3", "sing4", "cin4", "naam4", "jau5", "dik1", "nei5"]}, "nlp": {"tokens": [{"text": "變成", "pos": "X"}, {"text": "前男友", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0009", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0011", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0011", "text": "走 我沒有阻止理由", "structure": {"line_index": 11, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 5, 2, 5, 9, 9, 5, 0], "tone_pattern_cantonese_jyutping": ["zau2", "ngo5", "mut6", "jau5", "zo2", "zi2", "lei5", "jau4"]}, "nlp": {"tokens": [{"text": "走", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "沒有", "pos": "X"}, {"text": "阻止", "pos": "X"}, {"text": "理由", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0010", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0012", "paragraph_id": "para_03"}}
{"id": "lyr_6Jab5Yev55Cq_MTA4MQ_0012", "text": "早已知道 能與你挽手 都會分手", "structure": {"line_index": 12, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 5, 3, 2, 0, 5, 5, 5, 9, 3, 3, 9], "tone_pattern_cantonese_jyutping": ["zou2", "ji5", "zi1", "dou6", "nang4", "jyu5", "nei5", "waan5", "sau2", "dou1", "fan1", "sau2"]}, "nlp": {"tokens": [{"text": "早已", "pos": "X"}, {"text": "知道", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "與", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "挽手", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "分手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "XBF", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1081", "prev_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0011", "next_line_id": "lyr_6Jab5Yev55Cq_MTA4MQ_0013", "paragraph_id": "para_03"}}
