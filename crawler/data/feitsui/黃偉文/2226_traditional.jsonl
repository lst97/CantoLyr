{"id": "lyr_5byg5pm66ZyW_MjIyNg_0014", "text": "想 怎樣作實爲情人負責 看 個個在疑惑", "structure": {"line_index": 14, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 2, 4, 2, 0, 0, 2, 4, 4, 4, 4, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["soeng2", "zam2", "joeng6", "zok3", "sat6", "cing4", "jan4", "fu6", "zaak3", "hon3", "go3", "go3", "zoi6", "ji4", "waak6"]}, "nlp": {"tokens": [{"text": "想", "pos": "X"}, {"text": "怎樣", "pos": "X"}, {"text": "作", "pos": "X"}, {"text": "實爲", "pos": "X"}, {"text": "情人", "pos": "X"}, {"text": "負責", "pos": "X"}, {"text": "看", "pos": "X"}, {"text": "個個", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "疑惑", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "未婚妻", "artists": ["張智霖"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2226", "prev_line_id": "lyr_5byg5pm66ZyW_MjIyNg_0013", "next_line_id": "lyr_5byg5pm66ZyW_MjIyNg_0015", "paragraph_id": "para_03"}}
