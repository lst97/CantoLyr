{"id": "lyr_5byg5pWs6L2p_Njg1MA_0030", "text": "有某些隱憂恐怕父母也不能既往不究", "structure": {"line_index": 30, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 3, 9, 3, 9, 4, 2, 5, 5, 3, 0, 4, 5, 3, 4], "tone_pattern_cantonese_jyutping": ["jau5", "mau5", "se1", "jan2", "jau1", "hung2", "paa3", "fu6", "mou5", "jaa5", "bat1", "nang4", "gei3", "wong5", "bat1", "gau3"]}, "nlp": {"tokens": [{"text": "有", "pos": "X"}, {"text": "某些", "pos": "X"}, {"text": "隱憂", "pos": "X"}, {"text": "恐怕", "pos": "X"}, {"text": "父母", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "不能", "pos": "X"}, {"text": "既往不究", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0029", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0031", "paragraph_id": "para_09"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0031", "text": "誰來假裝妥協心不對口暗地也有傷口", "structure": {"line_index": 31, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 9, 3, 9, 4, 3, 3, 4, 9, 4, 2, 5, 5, 3, 9], "tone_pattern_cantonese_jyutping": ["seoi4", "loi4", "gaa2", "zong1", "to2", "hip3", "sam1", "bat1", "deoi3", "hau2", "am3", "dei6", "jaa5", "jau5", "soeng1", "hau2"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "假裝", "pos": "X"}, {"text": "妥協", "pos": "X"}, {"text": "心", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "對口", "pos": "X"}, {"text": "暗地", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "傷口", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0030", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0032", "paragraph_id": "para_09"}}
