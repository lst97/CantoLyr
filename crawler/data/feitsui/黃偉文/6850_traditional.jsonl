{"id": "lyr_5byg5pWs6L2p_Njg1MA_0017", "text": "從前不懂 這出經典戲太誇張", "structure": {"line_index": 17, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 9, 5, 3, 3, 9, 4, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["cung4", "cin4", "bat1", "dung2", "ze5", "ceot1", "ging1", "din2", "hei3", "taai3", "kwaa1", "zoeng1"]}, "nlp": {"tokens": [{"text": "從前", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "懂", "pos": "X"}, {"text": "這出", "pos": "X"}, {"text": "經典", "pos": "X"}, {"text": "戲太", "pos": "X"}, {"text": "誇張", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0016", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0018", "paragraph_id": "para_05"}}
