{"id": "lyr_5byg5pWs6L2p_Njg1MA_0001", "text": "除非 將畢生所信 也推翻", "structure": {"line_index": 1, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 3, 3, 9, 4, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["ceoi4", "fei1", "zoeng1", "bat1", "sang1", "so2", "seon3", "jaa5", "teoi1", "faan1"]}, "nlp": {"tokens": [{"text": "除非", "pos": "X"}, {"text": "將", "pos": "X"}, {"text": "畢生", "pos": "X"}, {"text": "所信", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "推翻", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": null, "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0002", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0002", "text": "除非 能說服我 只開一隻眼", "structure": {"line_index": 2, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 0, 4, 2, 5, 9, 3, 3, 4, 5], "tone_pattern_cantonese_jyutping": ["ceoi4", "fei1", "nang4", "syut3", "fuk6", "ngo5", "zi2", "hoi1", "jat1", "zek3", "ngaan5"]}, "nlp": {"tokens": [{"text": "除非", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "說服", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "只開", "pos": "X"}, {"text": "一隻", "pos": "X"}, {"text": "眼", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0001", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0003", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0003", "text": "雖則你和我 已是爭吵慣", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 5, 0, 5, 5, 2, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["seoi1", "zak1", "nei5", "wo4", "ngo5", "ji5", "si6", "zang1", "caau2", "gwaan3"]}, "nlp": {"tokens": [{"text": "雖則", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "已", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "爭吵", "pos": "X"}, {"text": "慣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0002", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0004", "text": "常和好於當晚 這次諒解極難", "structure": {"line_index": 4, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 9, 3, 5, 5, 4, 2, 9, 2, 0], "tone_pattern_cantonese_jyutping": ["soeng4", "wo4", "hou2", "jyu1", "maan5", "ze5", "ci3", "loeng6", "gaai2", "gik6", "naan4"]}, "nlp": {"tokens": [{"text": "常", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "於", "pos": "X"}, {"text": "當晚", "pos": "X"}, {"text": "這次", "pos": "X"}, {"text": "諒解", "pos": "X"}, {"text": "極難", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0003", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0005", "text": "情人之間 講心比講理更簡單", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 9, 3, 9, 9, 5, 9, 3], "tone_pattern_cantonese_jyutping": ["cing4", "jan4", "zi1", "gong2", "sam1", "bei2", "gong2", "lei5", "gaan2", "daan1"]}, "nlp": {"tokens": [{"text": "情人", "pos": "X"}, {"text": "之間", "pos": "X"}, {"text": "講心", "pos": "X"}, {"text": "比", "pos": "X"}, {"text": "講理", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "簡單", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0004", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0006", "text": "纏綿一番 難教義理相沖也沖淡", "structure": {"line_index": 6, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 3, 0, 4, 2, 5, 3, 5, 3, 2], "tone_pattern_cantonese_jyutping": ["cin4", "min4", "jat1", "faan1", "naan4", "gaau3", "ji6", "lei5", "cung1", "jaa5", "cung1", "daam6"]}, "nlp": {"tokens": [{"text": "纏綿", "pos": "X"}, {"text": "一番", "pos": "X"}, {"text": "難", "pos": "X"}, {"text": "教義", "pos": "X"}, {"text": "理", "pos": "X"}, {"text": "相沖", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "沖淡", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0005", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0007", "text": "伴你共渡過劫難 分擔過人間悲慘", "structure": {"line_index": 7, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 2, 2, 4, 4, 0, 3, 3, 4, 0, 3, 9], "tone_pattern_cantonese_jyutping": ["bun6", "nei5", "gung6", "dou6", "gwo3", "gip3", "naan4", "fan1", "daam1", "gwo3", "jan4", "bei1", "caam2"]}, "nlp": {"tokens": [{"text": "伴", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "共", "pos": "X"}, {"text": "渡過", "pos": "X"}, {"text": "劫難", "pos": "X"}, {"text": "分擔", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "人間", "pos": "X"}, {"text": "悲慘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0006", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0008", "text": "想不到最後仍會散 只因你角度存偏袒", "structure": {"line_index": 8, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 4, 4, 2, 0, 9, 9, 3, 5, 4, 2, 0, 3, 9], "tone_pattern_cantonese_jyutping": ["soeng2", "bat1", "dou3", "zeoi3", "hau6", "jing4", "saan2", "zi2", "jan1", "nei5", "gok3", "dou6", "cyun4", "pin1", "taan2"]}, "nlp": {"tokens": [{"text": "想不到", "pos": "X"}, {"text": "最後", "pos": "X"}, {"text": "仍會散", "pos": "X"}, {"text": "只", "pos": "X"}, {"text": "因", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "角度", "pos": "X"}, {"text": "存", "pos": "X"}, {"text": "偏袒", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0007", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0009", "paragraph_id": "para_02"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0009", "text": "原來是世間太荒謬", "structure": {"line_index": 9, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 4, 4, 3, 2], "tone_pattern_cantonese_jyutping": ["jyun4", "loi4", "si6", "sai3", "taai3", "fong1", "mau6"]}, "nlp": {"tokens": [{"text": "原來", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "世間", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "荒謬", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0008", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0010", "paragraph_id": "para_03"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0010", "text": "你我分的手先最合理與溫柔", "structure": {"line_index": 10, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 3, 3, 9, 3, 4, 2, 5, 5, 3, 0], "tone_pattern_cantonese_jyutping": ["nei5", "ngo5", "fan1", "dik1", "sau2", "sin1", "zeoi3", "hap6", "lei5", "jyu5", "wan1", "jau4"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "分", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "手先", "pos": "X"}, {"text": "最", "pos": "X"}, {"text": "合理", "pos": "X"}, {"text": "與", "pos": "X"}, {"text": "溫柔", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0009", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0011", "paragraph_id": "para_03"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0011", "text": "每個爭鬥 誰來假裝妥協心不對口", "structure": {"line_index": 11, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 3, 4, 0, 0, 9, 3, 9, 4, 3, 3, 4, 9], "tone_pattern_cantonese_jyutping": ["mui5", "go3", "zang1", "dau3", "seoi4", "loi4", "gaa2", "zong1", "to2", "hip3", "sam1", "bat1", "deoi3", "hau2"]}, "nlp": {"tokens": [{"text": "每個", "pos": "X"}, {"text": "爭鬥", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "假裝", "pos": "X"}, {"text": "妥協", "pos": "X"}, {"text": "心", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "對口", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0010", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0012", "paragraph_id": "para_03"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0012", "text": "暗地也有傷口 無法善後", "structure": {"line_index": 12, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 5, 5, 3, 9, 0, 4, 2, 2], "tone_pattern_cantonese_jyutping": ["am3", "dei6", "jaa5", "jau5", "soeng1", "hau2", "mou4", "faat3", "sin6", "hau6"]}, "nlp": {"tokens": [{"text": "暗地", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "傷口", "pos": "X"}, {"text": "無法", "pos": "X"}, {"text": "善後", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0011", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0013", "paragraph_id": "para_03"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0013", "text": "跟你試過遷就", "structure": {"line_index": 13, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 5, 4, 4, 3, 2], "tone_pattern_cantonese_jyutping": ["gan1", "nei5", "si3", "gwo3", "cin1", "zau6"]}, "nlp": {"tokens": [{"text": "跟", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "試過", "pos": "X"}, {"text": "遷就", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0012", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0014", "paragraph_id": "para_04"}}
{"id": "lyr_5byg5pWs6L2p_Njg1MA_0014", "text": "痛也不分手先至悟透人世裏有一些價值", "structure": {"line_index": 14, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 5, 3, 3, 9, 3, 4, 2, 4, 0, 4, 5, 5, 3, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["tung3", "jaa5", "bat1", "fan1", "sau2", "sin1", "zi3", "ng6", "tau3", "jan4", "sai3", "leoi5", "jau5", "jat1", "se1", "gaa3", "zik6"]}, "nlp": {"tokens": [{"text": "痛", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "分手", "pos": "X"}, {"text": "先至悟", "pos": "X"}, {"text": "透", "pos": "X"}, {"text": "人世", "pos": "X"}, {"text": "裏", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "一些", "pos": "X"}, {"text": "價值", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "俏郎君", "artists": ["張敬軒"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6850", "prev_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0013", "next_line_id": "lyr_5byg5pWs6L2p_Njg1MA_0015", "paragraph_id": "para_04"}}
