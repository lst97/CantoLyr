{"id": "lyr_6Jab5Yev55Cq_MzQzMw_0006", "text": "盼望你猶如所想那樣優雅", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 5, 0, 0, 9, 9, 5, 2, 3, 5], "tone_pattern_cantonese_jyutping": ["paan3", "mong6", "nei5", "jau4", "jyu4", "so2", "soeng2", "naa5", "joeng6", "jau1", "ngaa5"]}, "nlp": {"tokens": [{"text": "盼望", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "猶如", "pos": "X"}, {"text": "所", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "那樣", "pos": "X"}, {"text": "優雅", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "拒絕畢彼特", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3433", "prev_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0005", "next_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MzQzMw_0007", "text": "任由我來妄想 其實較實物完美吧", "structure": {"line_index": 7, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 5, 0, 5, 9, 0, 2, 4, 2, 2, 0, 5, 2], "tone_pattern_cantonese_jyutping": ["jam6", "jau4", "ngo5", "loi4", "mong5", "soeng2", "kei4", "sat6", "gaau3", "sat6", "mat6", "jyun4", "mei5", "baa6"]}, "nlp": {"tokens": [{"text": "任由", "pos": "X"}, {"text": "我來", "pos": "X"}, {"text": "妄想", "pos": "X"}, {"text": "其實", "pos": "X"}, {"text": "較", "pos": "X"}, {"text": "實物", "pos": "X"}, {"text": "完美", "pos": "X"}, {"text": "吧", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "拒絕畢彼特", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3433", "prev_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0006", "next_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MzQzMw_0008", "text": "誰冀望你 下個首映 請我參加", "structure": {"line_index": 8, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 4, 2, 5, 2, 4, 9, 9, 9, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["seoi4", "kei3", "mong6", "nei5", "haa6", "go3", "sau2", "jing2", "cing2", "ngo5", "caam1", "gaa1"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "冀望", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "下個", "pos": "X"}, {"text": "首映", "pos": "X"}, {"text": "請", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "參加", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "拒絕畢彼特", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3433", "prev_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0007", "next_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0009", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_MzQzMw_0009", "text": "要是以後我天天都可跟偶像晚餐", "structure": {"line_index": 9, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 5, 2, 5, 3, 3, 3, 9, 3, 5, 2, 5, 3], "tone_pattern_cantonese_jyutping": ["jiu3", "si6", "ji5", "hau6", "ngo5", "tin1", "tin1", "dou1", "ho2", "gan1", "ngau5", "zoeng6", "maan5", "caan1"]}, "nlp": {"tokens": [{"text": "要是", "pos": "X"}, {"text": "以後", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "天天", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "可", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "偶像", "pos": "X"}, {"text": "晚餐", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "拒絕畢彼特", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3433", "prev_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0008", "next_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0010", "paragraph_id": "para_03"}}
