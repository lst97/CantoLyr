{"id": "lyr_6Jab5Yev55Cq_MzQzMw_0013", "text": "你別約會我不想憧憬消散在瞬間", "structure": {"line_index": 13, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 5, 3, 9, 3, 9, 3, 9, 2, 4], "tone_pattern_cantonese_jyutping": ["nei5", "bit6", "joek3", "ngo5", "bat1", "soeng2", "cung1", "ging2", "siu1", "saan2", "zoi6", "seon3"]}, "nlp": {"tokens": [{"text": "你別", "pos": "X"}, {"text": "約會", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "不想", "pos": "X"}, {"text": "憧憬", "pos": "X"}, {"text": "消散", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "瞬間", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "拒絕畢彼特", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3433", "prev_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0012", "next_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0014", "paragraph_id": "para_04"}}
