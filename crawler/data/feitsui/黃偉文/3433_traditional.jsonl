{"id": "lyr_6Jab5Yev55Cq_MzQzMw_0011", "text": "無論誰 換了衫 也不像臺前璀璨", "structure": {"line_index": 11, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 0, 2, 5, 3, 5, 3, 2, 0, 0, 3, 4], "tone_pattern_cantonese_jyutping": ["mou4", "leon6", "seoi4", "wun6", "liu5", "saam1", "jaa5", "bat1", "zoeng6", "toi4", "cin4", "ceoi1", "caan3"]}, "nlp": {"tokens": [{"text": "無論誰", "pos": "X"}, {"text": "換", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "衫", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "臺前", "pos": "X"}, {"text": "璀璨", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "拒絕畢彼特", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3433", "prev_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0010", "next_line_id": "lyr_6Jab5Yev55Cq_MzQzMw_0012", "paragraph_id": "para_03"}}
