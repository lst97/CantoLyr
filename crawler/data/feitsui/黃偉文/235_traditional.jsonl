{"id": "lyr_5Y2i5ben6Z-z_MjM1_0001", "text": "從塵土中 高貴地 飛身躺下", "structure": {"line_index": 1, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 9, 3, 3, 4, 2, 3, 3, 9, 2], "tone_pattern_cantonese_jyutping": ["cung4", "can4", "tou2", "zung1", "gou1", "gwai3", "dei6", "fei1", "san1", "tong2", "haa6"]}, "nlp": {"tokens": [{"text": "從", "pos": "X"}, {"text": "塵土", "pos": "X"}, {"text": "中", "pos": "X"}, {"text": "高貴", "pos": "X"}, {"text": "地", "pos": "X"}, {"text": "飛身", "pos": "X"}, {"text": "躺", "pos": "X"}, {"text": "下", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "落地開花", "artists": ["盧巧音"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_235", "prev_line_id": null, "next_line_id": "lyr_5Y2i5ben6Z-z_MjM1_0002", "paragraph_id": "para_01"}}
