{"id": "lyr_5Y2i5ben6Z-z_MjM1_0003", "text": "曾這麼 英勇地 愛上過他", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 3, 3, 5, 2, 4, 4, 3], "tone_pattern_cantonese_jyutping": ["cang4", "ze5", "mo1", "jing1", "jung5", "dei6", "oi3", "gwo3", "taa1"]}, "nlp": {"tokens": [{"text": "曾", "pos": "X"}, {"text": "這麼", "pos": "X"}, {"text": "英勇", "pos": "X"}, {"text": "地", "pos": "X"}, {"text": "愛上", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "他", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "落地開花", "artists": ["盧巧音"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_235", "prev_line_id": "lyr_5Y2i5ben6Z-z_MjM1_0002", "next_line_id": "lyr_5Y2i5ben6Z-z_MjM1_0004", "paragraph_id": "para_01"}}
