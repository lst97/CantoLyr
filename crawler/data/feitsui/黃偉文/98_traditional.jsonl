{"id": "lyr_6Jab5Yev55Cq_OTg_0001", "text": "男孩們來約我一般送花", "structure": {"line_index": 1, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 4, 5, 3, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["naam4", "haai4", "mun4", "loi4", "joek3", "ngo5", "jat1", "bun1", "sung3", "faa1"]}, "nlp": {"tokens": [{"text": "男孩", "pos": "X"}, {"text": "們", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "約", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "一般", "pos": "X"}, {"text": "送花", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": null, "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0002", "paragraph_id": "para_01"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0002", "text": "而無人能似你親手種花", "structure": {"line_index": 2, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 5, 5, 3, 9, 9, 3], "tone_pattern_cantonese_jyutping": ["ji4", "mou4", "jan4", "nang4", "ci5", "nei5", "can1", "sau2", "zung2", "faa1"]}, "nlp": {"tokens": [{"text": "而", "pos": "X"}, {"text": "無人", "pos": "X"}, {"text": "能似", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "親手", "pos": "X"}, {"text": "種花", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0001", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0003", "text": "但男孩像你 不要我下嫁", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 0, 2, 5, 3, 4, 5, 2, 4], "tone_pattern_cantonese_jyutping": ["daan6", "naam4", "haai4", "zoeng6", "nei5", "bat1", "jiu3", "ngo5", "haa6", "gaa3"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "男孩", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "不要", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "下嫁", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0002", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0004", "text": "男孩們能有你般纖細嗎", "structure": {"line_index": 4, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 5, 5, 3, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["naam4", "haai4", "mun4", "nang4", "jau5", "nei5", "bun1", "cim1", "sai3", "maa1"]}, "nlp": {"tokens": [{"text": "男孩", "pos": "X"}, {"text": "們", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "般", "pos": "X"}, {"text": "纖細", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0003", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0005", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0005", "text": "談情時明我那種感性嗎", "structure": {"line_index": 5, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 5, 5, 9, 9, 4, 3], "tone_pattern_cantonese_jyutping": ["taam4", "cing4", "si4", "ming4", "ngo5", "naa5", "zung2", "gam2", "sing3", "maa1"]}, "nlp": {"tokens": [{"text": "談情", "pos": "X"}, {"text": "時明", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "那種", "pos": "X"}, {"text": "感性", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0004", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0006", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0006", "text": "但男孩像你 只愛同類嗎", "structure": {"line_index": 6, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 0, 2, 5, 9, 4, 0, 2, 3], "tone_pattern_cantonese_jyutping": ["daan6", "naam4", "haai4", "zoeng6", "nei5", "zi2", "oi3", "tung4", "leoi6", "maa1"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "男孩", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "只愛", "pos": "X"}, {"text": "同類", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0005", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0007", "text": "假使間 這一刻 我與你 憑良心", "structure": {"line_index": 7, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 5, 3, 3, 5, 5, 5, 0, 0, 3], "tone_pattern_cantonese_jyutping": ["gaa2", "si2", "ze5", "jat1", "hak1", "ngo5", "jyu5", "nei5", "pang4", "loeng4", "sam1"]}, "nlp": {"tokens": [{"text": "假使", "pos": "X"}, {"text": "間", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "一刻", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "與", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "憑良心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0006", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0008", "paragraph_id": "para_03"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0008", "text": "想一想 揀一揀 實在是 和誰襯", "structure": {"line_index": 8, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 9, 9, 3, 9, 2, 2, 2, 0, 0, 4], "tone_pattern_cantonese_jyutping": ["soeng2", "jat1", "soeng2", "gaan2", "jat1", "gaan2", "sat6", "zoi6", "si6", "wo4", "seoi4", "can3"]}, "nlp": {"tokens": [{"text": "想一想", "pos": "X"}, {"text": "揀", "pos": "X"}, {"text": "一", "pos": "X"}, {"text": "揀", "pos": "X"}, {"text": "實在", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "襯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0007", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0009", "paragraph_id": "para_03"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0009", "text": "你會說 是命運 你與我 其實熟得很", "structure": {"line_index": 9, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 2, 2, 2, 5, 5, 5, 0, 2, 2, 3, 9], "tone_pattern_cantonese_jyutping": ["nei5", "syut3", "si6", "ming6", "wan6", "nei5", "jyu5", "ngo5", "kei4", "sat6", "suk6", "dak1", "han2"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "命運", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "與", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "其實", "pos": "X"}, {"text": "熟得", "pos": "X"}, {"text": "很", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0008", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0010", "paragraph_id": "para_03"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0010", "text": "但他總比較親", "structure": {"line_index": 10, "char_count": 6}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 3, 9, 9, 4, 3], "tone_pattern_cantonese_jyutping": ["daan6", "taa1", "zung2", "bei2", "gaau3", "can1"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "總", "pos": "X"}, {"text": "比較", "pos": "X"}, {"text": "親", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0009", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0011", "paragraph_id": "para_03"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0011", "text": "好知己 好姊妹 哪裏會 談情感", "structure": {"line_index": 11, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 9, 9, 9, 2, 5, 5, 0, 0, 9], "tone_pattern_cantonese_jyutping": ["hou2", "zi1", "gei2", "hou2", "zi2", "mui6", "naa5", "leoi5", "taam4", "cing4", "gam2"]}, "nlp": {"tokens": [{"text": "好", "pos": "X"}, {"text": "知己", "pos": "X"}, {"text": "好姊妹", "pos": "X"}, {"text": "哪裏", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "談", "pos": "X"}, {"text": "情感", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0010", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0012", "paragraph_id": "para_04"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0012", "text": "不牽手 不親嘴 但是亦 能陪我 下半生", "structure": {"line_index": 12, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 9, 3, 3, 9, 2, 2, 2, 0, 0, 5, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["bat1", "hin1", "sau2", "bat1", "can1", "zeoi2", "daan6", "si6", "jik6", "nang4", "pui4", "ngo5", "haa6", "bun3", "sang1"]}, "nlp": {"tokens": [{"text": "不", "pos": "X"}, {"text": "牽手", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "親嘴", "pos": "X"}, {"text": "但是", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "陪", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "下半生", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0011", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0013", "paragraph_id": "para_04"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0013", "text": "問你 這夜最後 送誰回家 我信那個會是我", "structure": {"line_index": 13, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 5, 2, 4, 2, 4, 0, 0, 3, 5, 4, 5, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["man6", "nei5", "ze5", "je6", "zeoi3", "hau6", "sung3", "seoi4", "wui4", "gaa1", "ngo5", "seon3", "naa5", "go3", "si6", "ngo5"]}, "nlp": {"tokens": [{"text": "問", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "這夜", "pos": "X"}, {"text": "最後", "pos": "X"}, {"text": "送", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "回家", "pos": "X"}, {"text": "我信", "pos": "X"}, {"text": "那個", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0012", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0014", "paragraph_id": "para_05"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0014", "text": "但我 心裏知道 男孩像你 不想跟妹妹拍拖", "structure": {"line_index": 14, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 3, 5, 3, 2, 0, 0, 2, 5, 3, 9, 3, 2, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["daan6", "ngo5", "sam1", "leoi5", "zi1", "dou6", "naam4", "haai4", "zoeng6", "nei5", "bat1", "soeng2", "gan1", "mui6", "mui6", "paak3", "to1"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "心裏", "pos": "X"}, {"text": "知道", "pos": "X"}, {"text": "男孩", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "不想", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "妹妹", "pos": "X"}, {"text": "拍拖", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0013", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0015", "paragraph_id": "para_05"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0015", "text": "共你笑着說着 戲劇時裝 哪怕錯過了幸福", "structure": {"line_index": 15, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 4, 2, 4, 2, 4, 2, 0, 3, 5, 4, 4, 4, 5, 2, 3], "tone_pattern_cantonese_jyutping": ["gung6", "nei5", "siu3", "zoek6", "syut3", "zoek6", "hei3", "kek6", "si4", "zong1", "naa5", "paa3", "co3", "gwo3", "liu5", "hang6", "fuk1"]}, "nlp": {"tokens": [{"text": "共", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "戲劇", "pos": "X"}, {"text": "時裝", "pos": "X"}, {"text": "哪怕", "pos": "X"}, {"text": "錯過", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "幸福", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0014", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0016", "paragraph_id": "para_06"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0016", "text": "彼此磋跎 仍然可以 彼此幫助 沉悶晚上 相約渡過", "structure": {"line_index": 16, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 3, 0, 0, 0, 9, 5, 9, 9, 3, 2, 0, 2, 5, 4, 2, 4], "tone_pattern_cantonese_jyutping": ["bei2", "ci2", "co1", "to4", "jing4", "jin4", "ho2", "ji5", "bei2", "ci2", "bong1", "zo6", "cam4", "mun6", "maan5", "joek3", "dou6", "gwo3"]}, "nlp": {"tokens": [{"text": "彼此", "pos": "X"}, {"text": "磋跎", "pos": "X"}, {"text": "仍然", "pos": "X"}, {"text": "可以", "pos": "X"}, {"text": "彼此", "pos": "X"}, {"text": "幫助", "pos": "X"}, {"text": "沉悶", "pos": "X"}, {"text": "晚上", "pos": "X"}, {"text": "相約", "pos": "X"}, {"text": "渡過", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0015", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0017", "paragraph_id": "para_06"}}
{"id": "lyr_6Jab5Yev55Cq_OTg_0017", "text": "寒流來何以你先擁抱他", "structure": {"line_index": 17, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 5, 5, 3, 9, 5, 3], "tone_pattern_cantonese_jyutping": ["hon4", "lau4", "loi4", "ho4", "ji5", "nei5", "sin1", "jung2", "pou5", "taa1"]}, "nlp": {"tokens": [{"text": "寒流", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "何以", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "先", "pos": "X"}, {"text": "擁抱", "pos": "X"}, {"text": "他", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男孩像你", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_98", "prev_line_id": "lyr_6Jab5Yev55Cq_OTg_0016", "next_line_id": "lyr_6Jab5Yev55Cq_OTg_0018", "paragraph_id": "para_07"}}
