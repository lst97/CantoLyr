{"id": "lyr_6ZmI5aWV6L-F_Mw_0001", "text": "有人問我 我就會講 但是無人來", "structure": {"line_index": 1, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 0, 2, 5, 5, 2, 9, 2, 2, 0, 0, 0], "tone_pattern_cantonese_jyutping": ["jau5", "jan4", "man6", "ngo5", "ngo5", "zau6", "gong2", "daan6", "si6", "mou4", "jan4", "loi4"]}, "nlp": {"tokens": [{"text": "有人", "pos": "X"}, {"text": "問", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "講", "pos": "X"}, {"text": "但是", "pos": "X"}, {"text": "無人", "pos": "X"}, {"text": "來", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "浮誇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3", "prev_line_id": null, "next_line_id": "lyr_6ZmI5aWV6L-F_Mw_0002", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5aWV6L-F_Mw_0002", "text": "我期待 到無奈 有話要講 得不到裝載", "structure": {"line_index": 2, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 0, 2, 4, 0, 2, 5, 2, 4, 9, 3, 3, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "kei4", "doi6", "dou3", "mou4", "noi6", "jau5", "waa6", "jiu3", "gong2", "dak1", "bat1", "dou3", "zong1", "zoi2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "期待", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "無奈", "pos": "X"}, {"text": "有話", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "講", "pos": "X"}, {"text": "得不到", "pos": "X"}, {"text": "裝載", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "浮誇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mw_0001", "next_line_id": "lyr_6ZmI5aWV6L-F_Mw_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5aWV6L-F_Mw_0003", "text": "我的心情猶像樽蓋 等被揭開", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 0, 0, 2, 3, 4, 9, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "dik1", "sam1", "cing4", "jau4", "zoeng6", "zeon1", "goi3", "dang2", "bei6", "kit3", "hoi1"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心情", "pos": "X"}, {"text": "猶像", "pos": "X"}, {"text": "樽", "pos": "X"}, {"text": "蓋", "pos": "X"}, {"text": "等", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "揭開", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "浮誇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mw_0002", "next_line_id": "lyr_6ZmI5aWV6L-F_Mw_0004", "paragraph_id": "para_01"}}
