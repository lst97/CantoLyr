{"id": "lyr_6ZmI5aWV6L-F_Mw_0011", "text": "似木頭 似石頭 的話 得到注意嗎", "structure": {"line_index": 11, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 5, 2, 0, 3, 2, 3, 4, 4, 4, 3], "tone_pattern_cantonese_jyutping": ["ci5", "muk6", "tau4", "ci5", "sek6", "tau4", "dik1", "waa6", "dak1", "dou3", "zyu3", "ji3", "maa1"]}, "nlp": {"tokens": [{"text": "似", "pos": "X"}, {"text": "木頭", "pos": "X"}, {"text": "似", "pos": "X"}, {"text": "石頭", "pos": "X"}, {"text": "的話", "pos": "X"}, {"text": "得到", "pos": "X"}, {"text": "注意", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "浮誇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mw_0010", "next_line_id": "lyr_6ZmI5aWV6L-F_Mw_0012", "paragraph_id": "para_03"}}
