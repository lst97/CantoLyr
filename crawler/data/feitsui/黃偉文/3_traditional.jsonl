{"id": "lyr_6ZmI5aWV6L-F_Mw_0007", "text": "像突然地高歌 任何地方也像開四面臺", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 0, 2, 3, 3, 2, 0, 2, 3, 5, 2, 3, 4, 2, 0], "tone_pattern_cantonese_jyutping": ["zoeng6", "dat6", "jin4", "dei6", "gou1", "go1", "jam6", "ho4", "dei6", "fong1", "jaa5", "zoeng6", "hoi1", "sei3", "min6", "toi4"]}, "nlp": {"tokens": [{"text": "像", "pos": "X"}, {"text": "突然", "pos": "X"}, {"text": "地", "pos": "X"}, {"text": "高歌", "pos": "X"}, {"text": "任何", "pos": "X"}, {"text": "地方", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "開", "pos": "X"}, {"text": "四面", "pos": "X"}, {"text": "臺", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "浮誇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mw_0006", "next_line_id": "lyr_6ZmI5aWV6L-F_Mw_0008", "paragraph_id": "para_02"}}
