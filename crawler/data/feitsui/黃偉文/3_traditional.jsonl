{"id": "lyr_6ZmI5aWV6L-F_Mw_0005", "text": "人潮內 愈文靜 愈變得 不受理睬", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 2, 0, 2, 2, 4, 3, 3, 2, 5, 9], "tone_pattern_cantonese_jyutping": ["jan4", "ciu4", "noi6", "jyu6", "man4", "zing6", "jyu6", "bin3", "dak1", "bat1", "sau6", "lei5", "coi2"]}, "nlp": {"tokens": [{"text": "人潮", "pos": "X"}, {"text": "內", "pos": "X"}, {"text": "愈", "pos": "X"}, {"text": "文靜", "pos": "X"}, {"text": "愈", "pos": "X"}, {"text": "變得", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "受", "pos": "X"}, {"text": "理睬", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "浮誇", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mw_0004", "next_line_id": "lyr_6ZmI5aWV6L-F_Mw_0006", "paragraph_id": "para_01"}}
