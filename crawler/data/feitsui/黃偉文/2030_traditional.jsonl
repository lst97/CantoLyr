{"id": "lyr_6Jab5Yev55Cq_MjAzMA_0007", "text": "再怪 那位 亦想 找個家", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 4, 5, 2, 2, 9, 9, 4, 3], "tone_pattern_cantonese_jyutping": ["zoi3", "gwaai3", "naa5", "wai6", "jik6", "soeng2", "zaau2", "go3", "gaa1"]}, "nlp": {"tokens": [{"text": "再怪", "pos": "X"}, {"text": "那位", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "找個", "pos": "X"}, {"text": "家", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "尋找獨角獸", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2030", "prev_line_id": "lyr_6Jab5Yev55Cq_MjAzMA_0006", "next_line_id": "lyr_6Jab5Yev55Cq_MjAzMA_0008", "paragraph_id": "para_02"}}
