{"id": "lyr_6Jab5Yev55Cq_MjAzMA_0019", "text": "我信某處定有他 我信空想創造神話", "structure": {"line_index": 19, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 2, 5, 3, 5, 4, 3, 9, 3, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["ngo5", "seon3", "mau5", "ding6", "jau5", "taa1", "ngo5", "seon3", "hung1", "soeng2", "cong1", "zou6", "san4", "waa6"]}, "nlp": {"tokens": [{"text": "我信", "pos": "X"}, {"text": "某處", "pos": "X"}, {"text": "定有", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "我信", "pos": "X"}, {"text": "空想", "pos": "X"}, {"text": "創造", "pos": "X"}, {"text": "神話", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "尋找獨角獸", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2030", "prev_line_id": "lyr_6Jab5Yev55Cq_MjAzMA_0018", "next_line_id": "lyr_6Jab5Yev55Cq_MjAzMA_0020", "paragraph_id": "para_05"}}
{"id": "lyr_6Jab5Yev55Cq_MjAzMA_0020", "text": "獨角獸也會找得到", "structure": {"line_index": 20, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 4, 5, 9, 3, 4], "tone_pattern_cantonese_jyutping": ["duk6", "gok3", "sau3", "jaa5", "zaau2", "dak1", "dou3"]}, "nlp": {"tokens": [{"text": "獨角獸", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "找", "pos": "X"}, {"text": "得到", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "尋找獨角獸", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2030", "prev_line_id": "lyr_6Jab5Yev55Cq_MjAzMA_0019", "next_line_id": "lyr_6Jab5Yev55Cq_MjAzMA_0021", "paragraph_id": "para_05"}}
