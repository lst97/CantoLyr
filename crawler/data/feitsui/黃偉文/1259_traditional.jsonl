{"id": "lyr_5p2o5Y2D5ayF_MTI1OQ_0019", "text": "但其實真實命運 很少寫得這麼吸引", "structure": {"line_index": 19, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 2, 3, 2, 2, 2, 9, 9, 3, 5, 3, 3, 5], "tone_pattern_cantonese_jyutping": ["daan6", "kei4", "sat6", "zan1", "sat6", "ming6", "wan6", "han2", "se2", "dak1", "ze5", "mo1", "kap1", "jan5"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "其實", "pos": "X"}, {"text": "真實", "pos": "X"}, {"text": "命運", "pos": "X"}, {"text": "很少", "pos": "X"}, {"text": "寫得", "pos": "X"}, {"text": "這麼", "pos": "X"}, {"text": "吸引", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一個人的童話", "artists": ["楊千嬅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1259", "prev_line_id": "lyr_5p2o5Y2D5ayF_MTI1OQ_0018", "next_line_id": "lyr_5p2o5Y2D5ayF_MTI1OQ_0020", "paragraph_id": "para_04"}}
{"id": "lyr_5p2o5Y2D5ayF_MTI1OQ_0020", "text": "如若童話永不變真 給趕出糖果屋", "structure": {"line_index": 20, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 0, 2, 5, 3, 4, 3, 3, 9, 3, 0, 9, 3], "tone_pattern_cantonese_jyutping": ["jyu4", "joek6", "tung4", "waa6", "wing5", "bat1", "bin3", "zan1", "kap1", "gon2", "ceot1", "tong4", "gwo2", "uk1"]}, "nlp": {"tokens": [{"text": "如若", "pos": "X"}, {"text": "童話", "pos": "X"}, {"text": "永不", "pos": "X"}, {"text": "變真", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "趕出", "pos": "X"}, {"text": "糖果屋", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一個人的童話", "artists": ["楊千嬅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1259", "prev_line_id": "lyr_5p2o5Y2D5ayF_MTI1OQ_0019", "next_line_id": "lyr_5p2o5Y2D5ayF_MTI1OQ_0021", "paragraph_id": "para_04"}}
