{"id": "lyr_6YOR56eA5paH_MTMzNw_0007", "text": "今天要告別 需要不太多 得一個", "structure": {"line_index": 7, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 4, 4, 2, 3, 4, 3, 4, 3, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["gam1", "tin1", "jiu3", "gou3", "bit6", "seoi1", "jiu3", "bat1", "taai3", "do1", "dak1", "jat1", "go3"]}, "nlp": {"tokens": [{"text": "今天", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "告別", "pos": "X"}, {"text": "需要", "pos": "X"}, {"text": "不太多", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "一個", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "Ladies First", "artists": ["鄭秀文"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1337", "prev_line_id": "lyr_6YOR56eA5paH_MTMzNw_0006", "next_line_id": "lyr_6YOR56eA5paH_MTMzNw_0008", "paragraph_id": "para_02"}}
