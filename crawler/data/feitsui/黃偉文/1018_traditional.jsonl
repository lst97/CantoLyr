{"id": "lyr_546L6I-y_MTAxOA_0003", "text": "假設跟誰遇上 像進出試身室那樣", "structure": {"line_index": 3, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 3, 0, 2, 2, 4, 3, 4, 3, 3, 5, 2], "tone_pattern_cantonese_jyutping": ["gaa2", "cit3", "gan1", "seoi4", "jyu6", "zoeng6", "zeon3", "ceot1", "si3", "san1", "sat1", "naa5", "joeng6"]}, "nlp": {"tokens": [{"text": "假設", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "遇上", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "進出", "pos": "X"}, {"text": "試身室", "pos": "X"}, {"text": "那樣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女皇的新衣", "artists": ["王菲"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1018", "prev_line_id": "lyr_546L6I-y_MTAxOA_0002", "next_line_id": "lyr_546L6I-y_MTAxOA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_546L6I-y_MTAxOA_0004", "text": "不要給誰賣帳 減價後 總有新貨馬上再登場", "structure": {"line_index": 4, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 0, 2, 4, 9, 4, 2, 9, 5, 3, 4, 5, 4, 3, 0], "tone_pattern_cantonese_jyutping": ["bat1", "jiu3", "kap1", "seoi4", "maai6", "zoeng3", "gaam2", "gaa3", "hau6", "zung2", "jau5", "san1", "fo3", "maa5", "zoi3", "dang1", "coeng4"]}, "nlp": {"tokens": [{"text": "不要", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "賣", "pos": "X"}, {"text": "帳", "pos": "X"}, {"text": "減價", "pos": "X"}, {"text": "後", "pos": "X"}, {"text": "總有", "pos": "X"}, {"text": "新貨", "pos": "X"}, {"text": "馬上", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "登場", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女皇的新衣", "artists": ["王菲"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1018", "prev_line_id": "lyr_546L6I-y_MTAxOA_0003", "next_line_id": "lyr_546L6I-y_MTAxOA_0005", "paragraph_id": "para_01"}}
