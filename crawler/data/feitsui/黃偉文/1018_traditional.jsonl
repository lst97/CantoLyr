{"id": "lyr_546L6I-y_MTAxOA_0001", "text": "一百雙鞋換上 未看出哪一雙漂亮", "structure": {"line_index": 1, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 0, 2, 2, 4, 3, 5, 3, 3, 3, 2], "tone_pattern_cantonese_jyutping": ["jat1", "baak3", "soeng1", "haai4", "wun6", "mei6", "hon3", "ceot1", "naa5", "jat1", "soeng1", "piu1", "loeng6"]}, "nlp": {"tokens": [{"text": "一百雙", "pos": "X"}, {"text": "鞋", "pos": "X"}, {"text": "換上", "pos": "X"}, {"text": "未", "pos": "X"}, {"text": "看出", "pos": "X"}, {"text": "哪", "pos": "X"}, {"text": "一雙", "pos": "X"}, {"text": "漂亮", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女皇的新衣", "artists": ["王菲"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1018", "prev_line_id": null, "next_line_id": "lyr_546L6I-y_MTAxOA_0002", "paragraph_id": "para_01"}}
