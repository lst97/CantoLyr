{"id": "lyr_546L6I-y_MTAxOA_0006", "text": "樂的很懶惰 如果新衣太多一絲不掛如何", "structure": {"line_index": 6, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 3, 9, 5, 2, 0, 9, 3, 3, 4, 3, 3, 3, 3, 4, 0, 0], "tone_pattern_cantonese_jyutping": ["lok6", "dik1", "han2", "laan5", "do6", "jyu4", "gwo2", "san1", "ji1", "taai3", "do1", "jat1", "si1", "bat1", "gwaa3", "jyu4", "ho4"]}, "nlp": {"tokens": [{"text": "樂", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "懶惰", "pos": "X"}, {"text": "如果", "pos": "X"}, {"text": "新衣", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "一絲不掛", "pos": "X"}, {"text": "如何", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女皇的新衣", "artists": ["王菲"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1018", "prev_line_id": "lyr_546L6I-y_MTAxOA_0005", "next_line_id": "lyr_546L6I-y_MTAxOA_0007", "paragraph_id": "para_02"}}
{"id": "lyr_546L6I-y_MTAxOA_0007", "text": "不怕感情地震 換套簇新軍裝上陣", "structure": {"line_index": 7, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 9, 0, 2, 4, 2, 4, 3, 3, 3, 3, 2], "tone_pattern_cantonese_jyutping": ["bat1", "paa3", "gam2", "cing4", "dei6", "zan3", "wun6", "tou3", "cuk1", "san1", "gwan1", "zong1", "zan6"]}, "nlp": {"tokens": [{"text": "不怕", "pos": "X"}, {"text": "感情", "pos": "X"}, {"text": "地震", "pos": "X"}, {"text": "換套", "pos": "X"}, {"text": "簇新", "pos": "X"}, {"text": "軍裝", "pos": "X"}, {"text": "上陣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女皇的新衣", "artists": ["王菲"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1018", "prev_line_id": "lyr_546L6I-y_MTAxOA_0006", "next_line_id": "lyr_546L6I-y_MTAxOA_0008", "paragraph_id": "para_03"}}
