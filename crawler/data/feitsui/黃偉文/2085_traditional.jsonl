{"id": "lyr_6IuP5rC45bq3_MjA4NQ_0013", "text": "明天也許 天氣漸冷 生命無復燦爛", "structure": {"line_index": 13, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 5, 9, 3, 4, 2, 5, 3, 2, 0, 2, 4, 2], "tone_pattern_cantonese_jyutping": ["ming4", "tin1", "jaa5", "heoi2", "tin1", "hei3", "zim6", "laang5", "sang1", "ming6", "mou4", "fuk6", "caan3", "laan6"]}, "nlp": {"tokens": [{"text": "明天", "pos": "X"}, {"text": "也許", "pos": "X"}, {"text": "天氣", "pos": "X"}, {"text": "漸冷", "pos": "X"}, {"text": "生命", "pos": "X"}, {"text": "無復", "pos": "X"}, {"text": "燦爛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我女人", "artists": ["蘇永康"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2085", "prev_line_id": "lyr_6IuP5rC45bq3_MjA4NQ_0012", "next_line_id": "lyr_6IuP5rC45bq3_MjA4NQ_0014", "paragraph_id": "para_06"}}
