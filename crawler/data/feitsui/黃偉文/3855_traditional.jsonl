{"id": "lyr_6Jab5Yev55Cq_Mzg1NQ_0024", "text": "我有時也恐懼 這掙扎總會累", "structure": {"line_index": 24, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 0, 5, 9, 2, 5, 2, 4, 9, 5], "tone_pattern_cantonese_jyutping": ["ngo5", "jau5", "si4", "jaa5", "hung2", "geoi6", "ze5", "zaang6", "zaat3", "zung2", "leoi5"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "有時", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "恐懼", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "掙扎", "pos": "X"}, {"text": "總會", "pos": "X"}, {"text": "累", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "水", "artists": ["薛凱琪"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3855", "prev_line_id": "lyr_6Jab5Yev55Cq_Mzg1NQ_0023", "next_line_id": "lyr_6Jab5Yev55Cq_Mzg1NQ_0025", "paragraph_id": "para_05"}}
