{"id": "lyr_6ZmI5aWV6L-F_MjUw_0007", "text": "若你 想欣賞 有沒有 金曲獎", "structure": {"line_index": 7, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 9, 3, 9, 5, 2, 5, 3, 3, 9], "tone_pattern_cantonese_jyutping": ["joek6", "nei5", "soeng2", "jan1", "soeng2", "jau5", "mut6", "jau5", "gam1", "kuk1", "zoeng2"]}, "nlp": {"tokens": [{"text": "若", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "欣賞", "pos": "X"}, {"text": "有沒有", "pos": "X"}, {"text": "金曲獎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "衝口而出", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_250", "prev_line_id": "lyr_6ZmI5aWV6L-F_MjUw_0006", "next_line_id": "lyr_6ZmI5aWV6L-F_MjUw_0008", "paragraph_id": "para_02"}}
