{"id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0009", "text": "但我更加不想就你", "structure": {"line_index": 9, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 3, 3, 9, 2, 5], "tone_pattern_cantonese_jyutping": ["daan6", "ngo5", "gaa1", "bat1", "soeng2", "zau6", "nei5"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "更加", "pos": "X"}, {"text": "不想", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "黑麪", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2955", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0008", "next_line_id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0010", "paragraph_id": "para_03"}}
