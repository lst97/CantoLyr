{"id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0006", "text": "你即管話 我這麼少氣", "structure": {"line_index": 6, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 9, 2, 5, 5, 3, 4], "tone_pattern_cantonese_jyutping": ["nei5", "zik1", "gun2", "waa6", "ngo5", "ze5", "mo1", "hei3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "即", "pos": "X"}, {"text": "管話", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "這麼", "pos": "X"}, {"text": "少氣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "黑麪", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2955", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0005", "next_line_id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0007", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0007", "text": "我不必被你看得起", "structure": {"line_index": 7, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 2, 5, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "bat1", "bit1", "bei6", "nei5", "hon3", "dak1", "hei2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "看得起", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "黑麪", "artists": ["陳奕迅"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2955", "prev_line_id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0006", "next_line_id": "lyr_6ZmI5aWV6L-F_Mjk1NQ_0008", "paragraph_id": "para_03"}}
