{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0002", "text": "整個超市 漸無人客 再度下調吧", "structure": {"line_index": 2, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 3, 5, 2, 0, 0, 4, 4, 2, 2, 2, 2], "tone_pattern_cantonese_jyutping": ["zing2", "go3", "ciu1", "si5", "zim6", "mou4", "jan4", "haak3", "zoi3", "dou6", "haa6", "diu6", "baa6"]}, "nlp": {"tokens": [{"text": "整個", "pos": "X"}, {"text": "超市", "pos": "X"}, {"text": "漸", "pos": "X"}, {"text": "無人", "pos": "X"}, {"text": "客", "pos": "X"}, {"text": "再度", "pos": "X"}, {"text": "下調", "pos": "X"}, {"text": "吧", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0001", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0003", "text": "留下有個草莓 即使狠狠減價", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 4, 9, 0, 3, 9, 9, 9, 9, 4], "tone_pattern_cantonese_jyutping": ["lau4", "haa6", "jau5", "go3", "cou2", "mui4", "zik1", "si2", "han2", "han2", "gaam2", "gaa3"]}, "nlp": {"tokens": [{"text": "留下", "pos": "X"}, {"text": "有個", "pos": "X"}, {"text": "草莓", "pos": "X"}, {"text": "即使", "pos": "X"}, {"text": "狠狠", "pos": "X"}, {"text": "減價", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0002", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0004", "text": "十個經過 十個摸過 沒抱起它", "structure": {"line_index": 4, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 3, 4, 2, 4, 9, 4, 2, 5, 9, 3], "tone_pattern_cantonese_jyutping": ["sap6", "go3", "ging1", "gwo3", "sap6", "go3", "mo2", "gwo3", "mut6", "pou5", "hei2", "taa1"]}, "nlp": {"tokens": [{"text": "十個", "pos": "X"}, {"text": "經過", "pos": "X"}, {"text": "十個", "pos": "X"}, {"text": "摸過", "pos": "X"}, {"text": "沒抱", "pos": "X"}, {"text": "起", "pos": "X"}, {"text": "它", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0003", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0005", "text": "春季收市 並無業績 只要努力呀", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 5, 2, 0, 2, 3, 9, 4, 5, 2, 3], "tone_pattern_cantonese_jyutping": ["ceon1", "gwai3", "sau1", "si5", "bing6", "mou4", "jip6", "zik1", "zi2", "jiu3", "nou5", "lik6", "aa1"]}, "nlp": {"tokens": [{"text": "春季", "pos": "X"}, {"text": "收市", "pos": "X"}, {"text": "並", "pos": "X"}, {"text": "無", "pos": "X"}, {"text": "業績", "pos": "X"}, {"text": "只要", "pos": "X"}, {"text": "努力", "pos": "X"}, {"text": "呀", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0004", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0006", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0006", "text": "冬季將至 門市更差 都要努力呀", "structure": {"line_index": 6, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 4, 0, 5, 3, 3, 4, 5, 2, 3], "tone_pattern_cantonese_jyutping": ["dung1", "gwai3", "zoeng1", "zi3", "mun4", "si5", "caa1", "dou1", "jiu3", "nou5", "lik6", "aa1"]}, "nlp": {"tokens": [{"text": "冬季", "pos": "X"}, {"text": "將", "pos": "X"}, {"text": "至", "pos": "X"}, {"text": "門市", "pos": "X"}, {"text": "更差", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "努力", "pos": "X"}, {"text": "呀", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0005", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0007", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0007", "text": "聽着沿路勉勵 心 卻越來越怕", "structure": {"line_index": 7, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 2, 0, 2, 5, 2, 3, 4, 2, 0, 2, 4], "tone_pattern_cantonese_jyutping": ["ting1", "zoek6", "jyun4", "lou6", "min5", "lai6", "sam1", "koek3", "jyut6", "loi4", "jyut6", "paa3"]}, "nlp": {"tokens": [{"text": "聽", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "沿路", "pos": "X"}, {"text": "勉勵", "pos": "X"}, {"text": "心", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "越來越", "pos": "X"}, {"text": "怕", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0006", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0008", "text": "若邂逅買家 有人認領 我會聽到嗎", "structure": {"line_index": 8, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 5, 3, 5, 0, 2, 5, 5, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["joek6", "haai6", "hau6", "maai5", "gaa1", "jau5", "jan4", "jing6", "ling5", "ngo5", "ting1", "dou3", "maa1"]}, "nlp": {"tokens": [{"text": "若", "pos": "X"}, {"text": "邂逅", "pos": "X"}, {"text": "買家", "pos": "X"}, {"text": "有人", "pos": "X"}, {"text": "認領", "pos": "X"}, {"text": "我會", "pos": "X"}, {"text": "聽到", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0007", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0009", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0009", "text": "期待到快爛掉 還未等到你要", "structure": {"line_index": 9, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 4, 2, 2, 0, 2, 9, 4, 5, 4], "tone_pattern_cantonese_jyutping": ["kei4", "doi6", "dou3", "faai3", "laan6", "diu6", "waan4", "mei6", "dang2", "dou3", "nei5", "jiu3"]}, "nlp": {"tokens": [{"text": "期待", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "快", "pos": "X"}, {"text": "爛掉", "pos": "X"}, {"text": "還", "pos": "X"}, {"text": "未", "pos": "X"}, {"text": "等到", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "要", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0008", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0010", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0010", "text": "旁人都 紛紛給買掉", "structure": {"line_index": 10, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 3, 3, 3, 5, 2], "tone_pattern_cantonese_jyutping": ["pong4", "jan4", "dou1", "fan1", "fan1", "kap1", "maai5", "diu6"]}, "nlp": {"tokens": [{"text": "旁人", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "紛紛", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "買", "pos": "X"}, {"text": "掉", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0009", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0011", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0011", "text": "唯獨自己 戀都失太少", "structure": {"line_index": 11, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 9, 9, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["wai4", "duk6", "zi6", "gei2", "lyun2", "dou1", "sat1", "taai3"]}, "nlp": {"tokens": [{"text": "唯獨", "pos": "X"}, {"text": "自己", "pos": "X"}, {"text": "戀", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "失太少", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0010", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0012", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0012", "text": "成熟得快爛掉 才獲悉 被遺忘了", "structure": {"line_index": 12, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 3, 4, 2, 2, 0, 2, 3, 2, 0, 0, 5], "tone_pattern_cantonese_jyutping": ["sing4", "suk6", "dak1", "faai3", "laan6", "diu6", "coi4", "wok6", "sik1", "bei6", "wai4", "mong4", "liu5"]}, "nlp": {"tokens": [{"text": "成熟", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "快", "pos": "X"}, {"text": "爛掉", "pos": "X"}, {"text": "才", "pos": "X"}, {"text": "獲悉", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "遺忘", "pos": "X"}, {"text": "了", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0011", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0013", "paragraph_id": "para_04"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0013", "text": "門就關了 期限終了", "structure": {"line_index": 13, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 3, 5, 0, 2, 3, 5], "tone_pattern_cantonese_jyutping": ["mun4", "zau6", "gwaan1", "liu5", "kei4", "haan6", "zung1", "liu5"]}, "nlp": {"tokens": [{"text": "門", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "關", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "期限", "pos": "X"}, {"text": "終了", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0012", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0014", "paragraph_id": "para_04"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0014", "text": "存貨的草莓 要換了", "structure": {"line_index": 14, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 4, 3, 9, 0, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["cyun4", "fo3", "dik1", "cou2", "mui4", "jiu3", "wun6", "liu5"]}, "nlp": {"tokens": [{"text": "存貨", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "草莓", "pos": "X"}, {"text": "要換", "pos": "X"}, {"text": "了", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0013", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0015", "paragraph_id": "para_04"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0015", "text": "資格不夠 若能自修 總會有密友", "structure": {"line_index": 15, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 4, 2, 0, 2, 3, 9, 5, 2, 5], "tone_pattern_cantonese_jyutping": ["zi1", "gaak3", "bat1", "gau3", "joek6", "nang4", "zi6", "sau1", "zung2", "jau5", "mat6", "jau5"]}, "nlp": {"tokens": [{"text": "資格", "pos": "X"}, {"text": "不夠", "pos": "X"}, {"text": "若能", "pos": "X"}, {"text": "自修", "pos": "X"}, {"text": "總會", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "密友", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0014", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0016", "paragraph_id": "para_05"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0016", "text": "不過修到 全套滿分 不見會自救", "structure": {"line_index": 16, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 4, 0, 4, 5, 3, 3, 4, 2, 4], "tone_pattern_cantonese_jyutping": ["bat1", "gwo3", "sau1", "dou3", "cyun4", "tou3", "mun5", "fan1", "bat1", "gin3", "zi6", "gau3"]}, "nlp": {"tokens": [{"text": "不過", "pos": "X"}, {"text": "修", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "全套", "pos": "X"}, {"text": "滿分", "pos": "X"}, {"text": "不見", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "自救", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0015", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0017", "paragraph_id": "para_05"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0017", "text": "你話甜蜜故事 等到熟成就有", "structure": {"line_index": 17, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 2, 4, 2, 9, 4, 2, 0, 2, 5], "tone_pattern_cantonese_jyutping": ["nei5", "waa6", "tim4", "mat6", "gu3", "si6", "dang2", "dou3", "suk6", "sing4", "zau6", "jau5"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "話", "pos": "X"}, {"text": "甜蜜", "pos": "X"}, {"text": "故事", "pos": "X"}, {"text": "等到", "pos": "X"}, {"text": "熟", "pos": "X"}, {"text": "成就", "pos": "X"}, {"text": "有", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0016", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0018", "paragraph_id": "para_05"}}
{"id": "lyr_6ZmI5p-P5a6H_NjY4OA_0018", "text": "但醞釀太久 有時亦會 變作了苦酒", "structure": {"line_index": 18, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 2, 4, 9, 5, 0, 2, 4, 4, 5, 9, 9], "tone_pattern_cantonese_jyutping": ["daan6", "wan3", "joeng6", "taai3", "gau2", "jau5", "si4", "jik6", "bin3", "zok3", "liu5", "fu2", "zau2"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "醞釀", "pos": "X"}, {"text": "太久", "pos": "X"}, {"text": "有時", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "變作", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "苦酒", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "金草莓", "artists": ["陳柏宇"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6688", "prev_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0017", "next_line_id": "lyr_6ZmI5p-P5a6H_NjY4OA_0019", "paragraph_id": "para_05"}}
