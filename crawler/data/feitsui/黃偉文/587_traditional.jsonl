{"id": "lyr_5a6Y5oGp5aic_NTg3_0006", "text": "誰人愛我偏偏看他不上眼", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 4, 5, 3, 3, 4, 3, 3, 5], "tone_pattern_cantonese_jyutping": ["seoi4", "jan4", "oi3", "ngo5", "pin1", "pin1", "hon3", "taa1", "bat1", "ngaan5"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "偏偏", "pos": "X"}, {"text": "看", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "上", "pos": "X"}, {"text": "眼", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "千帆", "artists": ["官恩娜"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_587", "prev_line_id": "lyr_5a6Y5oGp5aic_NTg3_0005", "next_line_id": "lyr_5a6Y5oGp5aic_NTg3_0007", "paragraph_id": "para_01"}}
{"id": "lyr_5a6Y5oGp5aic_NTg3_0007", "text": "仍然迷信愛 但中獎太難", "structure": {"line_index": 7, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 4, 4, 2, 3, 9, 4, 0], "tone_pattern_cantonese_jyutping": ["jing4", "jin4", "mai4", "seon3", "oi3", "daan6", "zung1", "zoeng2", "taai3", "naan4"]}, "nlp": {"tokens": [{"text": "仍然", "pos": "X"}, {"text": "迷信", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "中獎", "pos": "X"}, {"text": "太難", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "千帆", "artists": ["官恩娜"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_587", "prev_line_id": "lyr_5a6Y5oGp5aic_NTg3_0006", "next_line_id": "lyr_5a6Y5oGp5aic_NTg3_0008", "paragraph_id": "para_01"}}
