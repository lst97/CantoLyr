{"id": "lyr_5a6Y5oGp5aic_NTg3_0009", "text": "幾多只船來了 幾多只船離開", "structure": {"line_index": 9, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 4, 0, 0, 5, 9, 3, 4, 0, 0, 3], "tone_pattern_cantonese_jyutping": ["gei2", "do1", "zek3", "syun4", "loi4", "liu5", "gei2", "do1", "zek3", "syun4", "lei4", "hoi1"]}, "nlp": {"tokens": [{"text": "幾多", "pos": "X"}, {"text": "只船", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "幾多", "pos": "X"}, {"text": "只船", "pos": "X"}, {"text": "離開", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "千帆", "artists": ["官恩娜"], "lyricists": ["黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_587", "prev_line_id": "lyr_5a6Y5oGp5aic_NTg3_0008", "next_line_id": "lyr_5a6Y5oGp5aic_NTg3_0010", "paragraph_id": "para_02"}}
