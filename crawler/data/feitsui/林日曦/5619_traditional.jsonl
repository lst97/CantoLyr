{"id": "lyr_6YOR56eA5paH_NTYxOQ_0022", "text": "長跑之戀有高有低 有快和慢", "structure": {"line_index": 22, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 3, 9, 5, 3, 5, 3, 5, 4, 0, 2], "tone_pattern_cantonese_jyutping": ["coeng4", "paau2", "zi1", "lyun2", "jau5", "gou1", "jau5", "dai1", "jau5", "faai3", "wo4", "maan6"]}, "nlp": {"tokens": [{"text": "長跑", "pos": "X"}, {"text": "之戀", "pos": "X"}, {"text": "有高有低", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "快", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "慢", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我不是歌手", "artists": ["鄭秀文"], "lyricists": ["林日曦"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5619", "prev_line_id": "lyr_6YOR56eA5paH_NTYxOQ_0021", "next_line_id": "lyr_6YOR56eA5paH_NTYxOQ_0023", "paragraph_id": "para_06"}}
