{"id": "lyr_5byg5pWs6L2p_NTk3Ng_0004", "text": "算我錯了 愛你 永遠像發癲", "structure": {"line_index": 4, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 5, 4, 5, 4, 5, 5, 5, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["syun3", "ngo5", "co3", "liu5", "oi3", "nei5", "wing5", "jyun5", "zoeng6", "faat3", "din1"]}, "nlp": {"tokens": [{"text": "算", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "錯", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "永遠", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "發癲", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "溺愛", "artists": ["張敬軒"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5976", "prev_line_id": "lyr_5byg5pWs6L2p_NTk3Ng_0003", "next_line_id": "lyr_5byg5pWs6L2p_NTk3Ng_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5pWs6L2p_NTk3Ng_0005", "text": "一年前 應該就避免 這樣發展", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 0, 0, 3, 2, 2, 5, 5, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["jat1", "nin4", "cin4", "goi1", "zau6", "bei6", "min5", "ze5", "joeng6", "faat3", "zin2"]}, "nlp": {"tokens": [{"text": "一年", "pos": "X"}, {"text": "前", "pos": "X"}, {"text": "應該", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "避免", "pos": "X"}, {"text": "這樣", "pos": "X"}, {"text": "發展", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "溺愛", "artists": ["張敬軒"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5976", "prev_line_id": "lyr_5byg5pWs6L2p_NTk3Ng_0004", "next_line_id": "lyr_5byg5pWs6L2p_NTk3Ng_0006", "paragraph_id": "para_01"}}
