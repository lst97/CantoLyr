{"id": "lyr_5byg5pWs6L2p_NTk3Ng_0008", "text": "試過愛你更多 怨氣便更多", "structure": {"line_index": 8, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 4, 4, 5, 3, 4, 4, 2, 3], "tone_pattern_cantonese_jyutping": ["si3", "gwo3", "oi3", "nei5", "do1", "jyun3", "hei3", "bin6", "do1"]}, "nlp": {"tokens": [{"text": "試過", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "怨氣", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "溺愛", "artists": ["張敬軒"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5976", "prev_line_id": "lyr_5byg5pWs6L2p_NTk3Ng_0007", "next_line_id": "lyr_5byg5pWs6L2p_NTk3Ng_0009", "paragraph_id": "para_02"}}
