{"id": "lyr_6YOR56eA5paH_MTQ5MA_0005", "text": "就是在玩弄我 亦自願受着過錯", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 9, 2, 5, 2, 2, 2, 2, 2, 4, 4], "tone_pattern_cantonese_jyutping": ["zau6", "si6", "zoi6", "waan2", "lung6", "ngo5", "jik6", "zi6", "jyun6", "sau6", "zoek6", "gwo3", "co3"]}, "nlp": {"tokens": [{"text": "就是", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "玩弄", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "自願", "pos": "X"}, {"text": "受", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "過錯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛的輓歌", "artists": ["鄭秀文"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1490", "prev_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0004", "next_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0006", "paragraph_id": "para_02"}}
{"id": "lyr_6YOR56eA5paH_MTQ5MA_0006", "text": "道別話未說 亦儘量去拖", "structure": {"line_index": 6, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 2, 4, 2, 2, 0, 4, 3], "tone_pattern_cantonese_jyutping": ["dou6", "bit6", "waa6", "mei6", "syut3", "jik6", "zeon6", "loeng4", "heoi3", "to1"]}, "nlp": {"tokens": [{"text": "道別", "pos": "X"}, {"text": "話", "pos": "X"}, {"text": "未", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "儘量", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "拖", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛的輓歌", "artists": ["鄭秀文"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1490", "prev_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0005", "next_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0007", "paragraph_id": "para_02"}}
