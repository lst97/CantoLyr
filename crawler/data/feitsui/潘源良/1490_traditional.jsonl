{"id": "lyr_6YOR56eA5paH_MTQ5MA_0002", "text": "你 從我心中經過 讓我徹底無助 真的叫我非愛不可", "structure": {"line_index": 2, "char_count": 21}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 0, 5, 3, 3, 3, 4, 2, 5, 4, 9, 0, 2, 3, 3, 4, 5, 3, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["nei5", "cung4", "ngo5", "sam1", "zung1", "ging1", "gwo3", "joeng6", "ngo5", "cit3", "dai2", "mou4", "zo6", "zan1", "dik1", "giu3", "ngo5", "fei1", "oi3", "bat1", "ho2"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "從", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "心中", "pos": "X"}, {"text": "經過", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "徹底", "pos": "X"}, {"text": "無助", "pos": "X"}, {"text": "真的", "pos": "X"}, {"text": "叫", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "非愛不可", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛的輓歌", "artists": ["鄭秀文"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1490", "prev_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0001", "next_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6YOR56eA5paH_MTQ5MA_0003", "text": "願伴着你 就是沒自我", "structure": {"line_index": 3, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 5, 2, 2, 2, 2, 5], "tone_pattern_cantonese_jyutping": ["jyun6", "bun6", "zoek6", "nei5", "zau6", "si6", "mut6", "zi6", "ngo5"]}, "nlp": {"tokens": [{"text": "願伴", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "就是", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "自我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛的輓歌", "artists": ["鄭秀文"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1490", "prev_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0002", "next_line_id": "lyr_6YOR56eA5paH_MTQ5MA_0004", "paragraph_id": "para_02"}}
