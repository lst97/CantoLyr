{"id": "lyr_5p2O546f_MTQyNw_0005", "text": "你說我的愛 曾令你挺起胸膛做人", "structure": {"line_index": 5, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 3, 4, 0, 2, 5, 5, 9, 3, 0, 2, 0], "tone_pattern_cantonese_jyutping": ["nei5", "syut3", "ngo5", "dik1", "oi3", "cang4", "ling6", "nei5", "ting5", "hei2", "hung1", "tong4", "zou6", "jan4"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "曾令", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "挺起", "pos": "X"}, {"text": "胸膛", "pos": "X"}, {"text": "做人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "憂傷天使", "artists": ["李玟"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1427", "prev_line_id": "lyr_5p2O546f_MTQyNw_0004", "next_line_id": "lyr_5p2O546f_MTQyNw_0006", "paragraph_id": "para_01"}}
{"id": "lyr_5p2O546f_MTQyNw_0006", "text": "但是我像個憂傷天使 目光永遠傷感", "structure": {"line_index": 6, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 5, 2, 4, 3, 3, 3, 9, 2, 3, 5, 5, 3, 9], "tone_pattern_cantonese_jyutping": ["daan6", "si6", "ngo5", "zoeng6", "go3", "jau1", "soeng1", "tin1", "si2", "muk6", "gwong1", "wing5", "jyun5", "soeng1", "gam2"]}, "nlp": {"tokens": [{"text": "但是", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "個", "pos": "X"}, {"text": "憂傷", "pos": "X"}, {"text": "天使", "pos": "X"}, {"text": "目光", "pos": "X"}, {"text": "永遠", "pos": "X"}, {"text": "傷感", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "憂傷天使", "artists": ["李玟"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1427", "prev_line_id": "lyr_5p2O546f_MTQyNw_0005", "next_line_id": "lyr_5p2O546f_MTQyNw_0007", "paragraph_id": "para_01"}}
