{"id": "lyr_55SE5aau_MzE3Ng_0002", "text": "白雲是人類家鄉 這廣闊空間裏到處也未愁困住", "structure": {"line_index": 2, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 2, 0, 2, 3, 3, 5, 9, 4, 3, 5, 4, 5, 2, 0, 4, 2], "tone_pattern_cantonese_jyutping": ["baak6", "wan4", "si6", "jan4", "leoi6", "gaa1", "hoeng1", "ze5", "gwong2", "fut3", "hung1", "leoi5", "dou3", "jaa5", "mei6", "sau4", "kwan3", "zyu6"]}, "nlp": {"tokens": [{"text": "白雲", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "人類", "pos": "X"}, {"text": "家鄉", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "廣闊", "pos": "X"}, {"text": "空間", "pos": "X"}, {"text": "裏", "pos": "X"}, {"text": "到處", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "未愁", "pos": "X"}, {"text": "困住", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "飛翔境界", "artists": ["甄妮"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3176", "prev_line_id": "lyr_55SE5aau_MzE3Ng_0001", "next_line_id": "lyr_55SE5aau_MzE3Ng_0003", "paragraph_id": "para_01"}}
{"id": "lyr_55SE5aau_MzE3Ng_0003", "text": "飛翔飛翔天空中 從不迷失方向 放眼看地球美事", "structure": {"line_index": 3, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 0, 3, 0, 3, 3, 3, 0, 3, 0, 3, 3, 4, 4, 5, 4, 2, 0, 5, 2], "tone_pattern_cantonese_jyutping": ["fei1", "coeng4", "fei1", "coeng4", "tin1", "hung1", "zung1", "cung4", "bat1", "mai4", "sat1", "fong1", "hoeng3", "fong3", "ngaan5", "hon3", "dei6", "kau4", "mei5", "si6"]}, "nlp": {"tokens": [{"text": "飛翔", "pos": "X"}, {"text": "飛翔", "pos": "X"}, {"text": "天空", "pos": "X"}, {"text": "中", "pos": "X"}, {"text": "從不", "pos": "X"}, {"text": "迷失方向", "pos": "X"}, {"text": "放", "pos": "X"}, {"text": "眼看", "pos": "X"}, {"text": "地球", "pos": "X"}, {"text": "美事", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "飛翔境界", "artists": ["甄妮"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3176", "prev_line_id": "lyr_55SE5aau_MzE3Ng_0002", "next_line_id": "lyr_55SE5aau_MzE3Ng_0004", "paragraph_id": "para_01"}}
