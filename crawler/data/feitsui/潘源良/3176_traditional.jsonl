{"id": "lyr_55SE5aau_MzE3Ng_0007", "text": "不能飛翔的空虛藏於人的心裏 跌進這地球角落", "structure": {"line_index": 7, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 0, 3, 0, 3, 3, 3, 0, 3, 0, 3, 3, 5, 4, 4, 5, 2, 0, 4, 2], "tone_pattern_cantonese_jyutping": ["bat1", "nang4", "fei1", "coeng4", "dik1", "hung1", "heoi1", "cong4", "jyu1", "jan4", "dik1", "sam1", "leoi5", "dit3", "zeon3", "ze5", "dei6", "kau4", "gok3", "lok6"]}, "nlp": {"tokens": [{"text": "不能", "pos": "X"}, {"text": "飛翔", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "空虛", "pos": "X"}, {"text": "藏於", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心裏", "pos": "X"}, {"text": "跌進", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "地球", "pos": "X"}, {"text": "角落", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "飛翔境界", "artists": ["甄妮"], "lyricists": ["潘源良"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3176", "prev_line_id": "lyr_55SE5aau_MzE3Ng_0006", "next_line_id": "lyr_55SE5aau_MzE3Ng_0008", "paragraph_id": "para_01"}}
