{"id": "lyr_6YOR56eA5paH_MjgxMw_0007", "text": "我以爲喜歡跟你爭吵 也許得到的更多", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 9, 3, 3, 5, 3, 9, 5, 9, 3, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "ji5", "hei2", "fun1", "gan1", "nei5", "zang1", "caau2", "jaa5", "heoi2", "dak1", "dou3", "dik1", "do1"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "以爲", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "跟", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "爭吵", "pos": "X"}, {"text": "也許", "pos": "X"}, {"text": "得到", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡憎你", "artists": ["鄭秀文"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2813", "prev_line_id": "lyr_6YOR56eA5paH_MjgxMw_0006", "next_line_id": "lyr_6YOR56eA5paH_MjgxMw_0008", "paragraph_id": "para_03"}}
