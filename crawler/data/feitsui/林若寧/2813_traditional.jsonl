{"id": "lyr_6YOR56eA5paH_MjgxMw_0004", "text": "我總使你 這麼生氣 如何令你歡喜", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 9, 5, 5, 3, 3, 4, 0, 0, 2, 5, 3, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "zung2", "si2", "nei5", "ze5", "mo1", "sang1", "hei3", "jyu4", "ho4", "ling6", "nei5", "fun1", "hei2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "總使", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "這麼", "pos": "X"}, {"text": "生氣", "pos": "X"}, {"text": "如何", "pos": "X"}, {"text": "令", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "歡喜", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡憎你", "artists": ["鄭秀文"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2813", "prev_line_id": "lyr_6YOR56eA5paH_MjgxMw_0003", "next_line_id": "lyr_6YOR56eA5paH_MjgxMw_0005", "paragraph_id": "para_01"}}
