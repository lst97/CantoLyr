{"id": "lyr_5byg5pWs6L2p_NjUxMw_0027", "text": "姑息你濫用我彌補這空檔", "structure": {"line_index": 27, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 5, 2, 2, 5, 0, 9, 5, 3, 4], "tone_pattern_cantonese_jyutping": ["gu1", "sik1", "nei5", "laam6", "jung6", "ngo5", "nei4", "bou2", "ze5", "hung1", "dong3"]}, "nlp": {"tokens": [{"text": "姑息", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "濫用", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "彌補", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "空檔", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "裝睡的情人", "artists": ["張敬軒"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6513", "prev_line_id": "lyr_5byg5pWs6L2p_NjUxMw_0026", "next_line_id": "lyr_5byg5pWs6L2p_NjUxMw_0028", "paragraph_id": "para_04"}}
