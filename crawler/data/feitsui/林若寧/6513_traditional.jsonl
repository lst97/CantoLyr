{"id": "lyr_5byg5pWs6L2p_NjUxMw_0023", "text": "而你恐怕忘記 其實是我的手", "structure": {"line_index": 23, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 9, 4, 0, 4, 0, 2, 2, 5, 3, 9], "tone_pattern_cantonese_jyutping": ["ji4", "nei5", "hung2", "paa3", "mong4", "gei3", "kei4", "sat6", "si6", "ngo5", "dik1", "sau2"]}, "nlp": {"tokens": [{"text": "而", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "恐怕", "pos": "X"}, {"text": "忘記", "pos": "X"}, {"text": "其實", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "裝睡的情人", "artists": ["張敬軒"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6513", "prev_line_id": "lyr_5byg5pWs6L2p_NjUxMw_0022", "next_line_id": "lyr_5byg5pWs6L2p_NjUxMw_0024", "paragraph_id": "para_03"}}
