{"id": "lyr_5a6556WW5YS__NDY1Mg_0025", "text": "時間不能拖 明白我只不過寂寞便惹禍", "structure": {"line_index": 25, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 0, 3, 0, 2, 5, 9, 3, 4, 2, 2, 2, 5, 2], "tone_pattern_cantonese_jyutping": ["si4", "bat1", "nang4", "to1", "ming4", "baak6", "ngo5", "zi2", "bat1", "gwo3", "zik6", "mok6", "bin6", "je5", "wo6"]}, "nlp": {"tokens": [{"text": "時間", "pos": "X"}, {"text": "不能", "pos": "X"}, {"text": "拖", "pos": "X"}, {"text": "明白", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "只不過", "pos": "X"}, {"text": "寂寞", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "惹禍", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛怪物的你", "artists": ["容祖兒"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4652", "prev_line_id": "lyr_5a6556WW5YS__NDY1Mg_0024", "next_line_id": "lyr_5a6556WW5YS__NDY1Mg_0026", "paragraph_id": "para_05"}}
