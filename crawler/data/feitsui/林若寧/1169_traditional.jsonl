{"id": "lyr_5byg5L-h5ZOy_MTE2OQ_0002", "text": "長路短 蕩失多遠我們原來亦有天碰到", "structure": {"line_index": 2, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 9, 2, 3, 3, 5, 5, 0, 0, 0, 2, 5, 3, 4, 4], "tone_pattern_cantonese_jyutping": ["coeng4", "lou6", "dyun2", "dong6", "sat1", "do1", "jyun5", "ngo5", "mun4", "jyun4", "loi4", "jik6", "jau5", "tin1", "pung3", "dou3"]}, "nlp": {"tokens": [{"text": "長路", "pos": "X"}, {"text": "短", "pos": "X"}, {"text": "蕩", "pos": "X"}, {"text": "失多遠", "pos": "X"}, {"text": "我們", "pos": "X"}, {"text": "原來", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "天", "pos": "X"}, {"text": "碰到", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "寧靜雪", "artists": ["張信哲"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1169", "prev_line_id": "lyr_5byg5L-h5ZOy_MTE2OQ_0001", "next_line_id": "lyr_5byg5L-h5ZOy_MTE2OQ_0003", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5L-h5ZOy_MTE2OQ_0003", "text": "尚記得淺草風雪嗎 欣賞它比較抱着高雅", "structure": {"line_index": 3, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 3, 9, 9, 3, 4, 3, 3, 9, 3, 9, 4, 5, 2, 3, 5], "tone_pattern_cantonese_jyutping": ["soeng6", "gei3", "dak1", "cin2", "cou2", "fung1", "syut3", "maa1", "jan1", "soeng2", "taa1", "bei2", "gaau3", "pou5", "zoek6", "gou1", "ngaa5"]}, "nlp": {"tokens": [{"text": "尚", "pos": "X"}, {"text": "記得", "pos": "X"}, {"text": "淺草", "pos": "X"}, {"text": "風雪", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "欣賞", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "比較", "pos": "X"}, {"text": "抱", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "高雅", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "寧靜雪", "artists": ["張信哲"], "lyricists": ["林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1169", "prev_line_id": "lyr_5byg5L-h5ZOy_MTE2OQ_0002", "next_line_id": "lyr_5byg5L-h5ZOy_MTE2OQ_0004", "paragraph_id": "para_02"}}
