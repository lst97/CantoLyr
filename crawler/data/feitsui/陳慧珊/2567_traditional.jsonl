{"id": "lyr_6K645b-X5a6J_MjU2Nw_0005", "text": "無論你昨天的吻 給我吻出傷痕", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 4, 3, 3, 5, 3, 5, 5, 3, 3, 0], "tone_pattern_cantonese_jyutping": ["mou4", "leon6", "nei5", "zok3", "tin1", "dik1", "man5", "kap1", "ngo5", "man5", "ceot1", "soeng1", "han4"]}, "nlp": {"tokens": [{"text": "無論", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "昨天", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "吻", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "吻", "pos": "X"}, {"text": "出", "pos": "X"}, {"text": "傷痕", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "苦口良藥", "artists": ["許志安"], "lyricists": ["陳慧珊", "林若寧"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2567", "prev_line_id": "lyr_6K645b-X5a6J_MjU2Nw_0004", "next_line_id": "lyr_6K645b-X5a6J_MjU2Nw_0006", "paragraph_id": "para_02"}}
