{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0001", "text": "你控訴我 接吻接上癮", "structure": {"line_index": 1, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 4, 5, 4, 5, 4, 9], "tone_pattern_cantonese_jyutping": ["nei5", "hung3", "sou3", "ngo5", "zip3", "man5", "zip3", "jan2"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "控訴", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "接吻", "pos": "X"}, {"text": "接", "pos": "X"}, {"text": "上癮", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": null, "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0002", "paragraph_id": "para_01"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0002", "text": "密密外遇 令你很痛恨", "structure": {"line_index": 2, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 2, 2, 5, 9, 4, 2], "tone_pattern_cantonese_jyutping": ["mat6", "mat6", "ngoi6", "jyu6", "ling6", "nei5", "han2", "tung3", "han6"]}, "nlp": {"tokens": [{"text": "密密", "pos": "X"}, {"text": "外遇", "pos": "X"}, {"text": "令", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "痛恨", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0001", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0003", "paragraph_id": "para_01"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0003", "text": "你呷醋呷上癮 膽敢去諷刺我 不愧是女人", "structure": {"line_index": 3, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 4, 4, 9, 9, 9, 4, 4, 4, 5, 3, 5, 2, 5, 0], "tone_pattern_cantonese_jyutping": ["nei5", "haap3", "cou3", "haap3", "jan2", "daam2", "gam2", "heoi3", "fung3", "ci3", "ngo5", "bat1", "kwai5", "si6", "neoi5", "jan4"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "呷", "pos": "X"}, {"text": "醋", "pos": "X"}, {"text": "呷", "pos": "X"}, {"text": "上癮", "pos": "X"}, {"text": "膽敢", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "諷刺", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "不愧", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "女人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0002", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0004", "text": "平時和人 如何尋開心", "structure": {"line_index": 4, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 0, 0, 0, 3, 3], "tone_pattern_cantonese_jyutping": ["ping4", "si4", "wo4", "jan4", "jyu4", "ho4", "cam4", "hoi1", "sam1"]}, "nlp": {"tokens": [{"text": "平時", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "如何", "pos": "X"}, {"text": "尋開心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0003", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0005", "text": "捏着浴巾 去擁抱別人", "structure": {"line_index": 5, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 3, 4, 9, 5, 2, 0], "tone_pattern_cantonese_jyutping": ["nip6", "zoek6", "juk6", "gan1", "heoi3", "jung2", "pou5", "bit6", "jan4"]}, "nlp": {"tokens": [{"text": "捏", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "浴巾", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "擁抱", "pos": "X"}, {"text": "別人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0004", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0006", "paragraph_id": "para_01"}}
