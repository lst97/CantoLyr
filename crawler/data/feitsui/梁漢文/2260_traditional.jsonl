{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0008", "text": "你作個證據 再對我教訓", "structure": {"line_index": 8, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 4, 4, 4, 4, 4, 5, 4, 4], "tone_pattern_cantonese_jyutping": ["nei5", "zok3", "go3", "zing3", "geoi3", "zoi3", "deoi3", "ngo5", "gaau3", "fan3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "作個", "pos": "X"}, {"text": "證據", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "教訓", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0007", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0009", "paragraph_id": "para_02"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0009", "text": "和他搞公司 是你蝦我笨", "structure": {"line_index": 9, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 9, 3, 3, 2, 5, 3, 5, 2], "tone_pattern_cantonese_jyutping": ["wo4", "taa1", "gaau2", "gung1", "si1", "si6", "nei5", "haa1", "ngo5", "ban6"]}, "nlp": {"tokens": [{"text": "和", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "搞", "pos": "X"}, {"text": "公司", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "蝦", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "笨", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0008", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0010", "paragraph_id": "para_02"}}
