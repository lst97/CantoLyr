{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0028", "text": "從未了解你 我偏再縱寵你", "structure": {"line_index": 28, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 9, 5, 5, 3, 4, 4, 9, 5], "tone_pattern_cantonese_jyutping": ["cung4", "mei6", "liu5", "gaai2", "nei5", "ngo5", "pin1", "zoi3", "zung3", "cung2", "nei5"]}, "nlp": {"tokens": [{"text": "從未", "pos": "X"}, {"text": "瞭解", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "偏", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "縱", "pos": "X"}, {"text": "寵", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0027", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0029", "paragraph_id": "para_08"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0029", "text": "我也太縱你 你當我已死", "structure": {"line_index": 29, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 4, 4, 5, 5, 5, 5, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "jaa5", "taai3", "zung3", "nei5", "nei5", "ngo5", "ji5", "sei2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "縱", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "當", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "已", "pos": "X"}, {"text": "死", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0028", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0030", "paragraph_id": "para_08"}}
{"id": "lyr_5p2o5Y2D5ayF_MjI2MA_0030", "text": "別日夜在妒忌 假得你", "structure": {"line_index": 30, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 2, 4, 2, 9, 3, 5], "tone_pattern_cantonese_jyutping": ["bit6", "jat6", "je6", "zoi6", "dou3", "gei6", "gaa2", "dak1", "nei5"]}, "nlp": {"tokens": [{"text": "別", "pos": "X"}, {"text": "日夜", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "妒忌", "pos": "X"}, {"text": "假得", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "滾", "artists": ["楊千嬅"], "lyricists": ["梁漢文", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2260", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0029", "next_line_id": "lyr_5p2o5Y2D5ayF_MjI2MA_0031", "paragraph_id": "para_08"}}
