{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0002", "text": "如果夜裏反正沒事情 留下看陣戲", "structure": {"line_index": 2, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 2, 5, 9, 4, 2, 2, 0, 0, 2, 4, 2, 4], "tone_pattern_cantonese_jyutping": ["jyu4", "gwo2", "je6", "leoi5", "faan2", "zing3", "mut6", "si6", "cing4", "lau4", "haa6", "hon3", "zan6", "hei3"]}, "nlp": {"tokens": [{"text": "如果", "pos": "X"}, {"text": "夜裏", "pos": "X"}, {"text": "反正", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "事情", "pos": "X"}, {"text": "留下", "pos": "X"}, {"text": "看陣戲", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0001", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0003", "paragraph_id": "para_01"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0003", "text": "或跳陣舞 都不錯", "structure": {"line_index": 3, "char_count": 7}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 2, 5, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["waak6", "tiu3", "zan6", "mou5", "dou1", "bat1", "co3"]}, "nlp": {"tokens": [{"text": "或", "pos": "X"}, {"text": "跳", "pos": "X"}, {"text": "陣舞", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "不錯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0002", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0004", "text": "寂寞成一對 也勝於獨個在看天花", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 0, 3, 4, 5, 4, 3, 2, 4, 2, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["zik6", "mok6", "sing4", "jat1", "deoi3", "jaa5", "sing3", "jyu1", "duk6", "go3", "zoi6", "hon3", "tin1", "faa1"]}, "nlp": {"tokens": [{"text": "寂寞", "pos": "X"}, {"text": "成", "pos": "X"}, {"text": "一對", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "勝於", "pos": "X"}, {"text": "獨個", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "看", "pos": "X"}, {"text": "天花", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0003", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0005", "text": "無邊夜裏漫談下去 是你伴我 或我伴你都不怕", "structure": {"line_index": 5, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 2, 5, 2, 0, 2, 4, 2, 5, 2, 5, 2, 5, 2, 5, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["mou4", "bin1", "je6", "leoi5", "maan6", "taam4", "haa6", "heoi3", "si6", "nei5", "bun6", "ngo5", "waak6", "ngo5", "bun6", "nei5", "dou1", "bat1", "paa3"]}, "nlp": {"tokens": [{"text": "無邊", "pos": "X"}, {"text": "夜裏", "pos": "X"}, {"text": "漫談", "pos": "X"}, {"text": "下去", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "伴", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "或", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "伴", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "不怕", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0004", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0006", "paragraph_id": "para_01"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0006", "text": "儘量地夜歸 仍然難逃過 寂寞像在家坐好等我", "structure": {"line_index": 6, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 0, 2, 2, 3, 0, 0, 0, 0, 4, 2, 2, 2, 2, 3, 5, 9, 9, 5], "tone_pattern_cantonese_jyutping": ["zeon2", "loeng4", "dei6", "je6", "gwai1", "jing4", "jin4", "naan4", "tou4", "gwo3", "zik6", "mok6", "zoeng6", "zoi6", "gaa1", "co5", "hou2", "dang2", "ngo5"]}, "nlp": {"tokens": [{"text": "儘量", "pos": "X"}, {"text": "地", "pos": "X"}, {"text": "夜歸", "pos": "X"}, {"text": "仍然", "pos": "X"}, {"text": "難逃", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "寂寞", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "在家", "pos": "X"}, {"text": "坐好", "pos": "X"}, {"text": "等", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0005", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0007", "text": "若是留住我 凌晨容易過 何妨來讓我挺身相助", "structure": {"line_index": 7, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 0, 2, 5, 0, 0, 0, 2, 4, 0, 0, 0, 2, 5, 5, 3, 2], "tone_pattern_cantonese_jyutping": ["joek6", "si6", "lau4", "zyu6", "ngo5", "ling4", "san4", "jung4", "ji6", "gwo3", "ho4", "fong4", "loi4", "joeng6", "ngo5", "ting5", "san1", "zo6"]}, "nlp": {"tokens": [{"text": "若", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "留住", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "凌晨", "pos": "X"}, {"text": "容易", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "何妨", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "挺身", "pos": "X"}, {"text": "相助", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0006", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0008", "text": "誰來陪着我 誰來平伏我 無法睡去的晚上太多", "structure": {"line_index": 8, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 2, 5, 0, 0, 0, 2, 5, 0, 4, 2, 4, 3, 5, 4, 3], "tone_pattern_cantonese_jyutping": ["seoi4", "loi4", "pui4", "zoek6", "ngo5", "seoi4", "loi4", "ping4", "fuk6", "ngo5", "mou4", "faat3", "seoi6", "heoi3", "dik1", "maan5", "taai3", "do1"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "陪", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "平伏", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "無法", "pos": "X"}, {"text": "睡去", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "晚上", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0007", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0009", "paragraph_id": "para_02"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0009", "text": "寂寞也間中 會約我探戈 能夠換舞伴都很不錯", "structure": {"line_index": 9, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 5, 3, 4, 5, 4, 3, 0, 4, 2, 5, 2, 3, 9, 3, 4], "tone_pattern_cantonese_jyutping": ["zik6", "mok6", "jaa5", "zung1", "joek3", "ngo5", "taam3", "gwo1", "nang4", "gau3", "wun6", "mou5", "bun6", "dou1", "han2", "bat1", "co3"]}, "nlp": {"tokens": [{"text": "寂寞", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "間", "pos": "X"}, {"text": "中", "pos": "X"}, {"text": "會約", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "探戈", "pos": "X"}, {"text": "能夠", "pos": "X"}, {"text": "換", "pos": "X"}, {"text": "舞伴", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "不錯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0008", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0010", "paragraph_id": "para_02"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0010", "text": "夜就在這地方 熟睡到天光 睡在我的暖爐旁", "structure": {"line_index": 10, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 5, 2, 3, 2, 2, 4, 3, 3, 2, 2, 5, 3, 5, 0, 0], "tone_pattern_cantonese_jyutping": ["je6", "zau6", "zoi6", "ze5", "dei6", "fong1", "suk6", "seoi6", "dou3", "tin1", "gwong1", "seoi6", "zoi6", "ngo5", "dik1", "nyun5", "lou4", "pong4"]}, "nlp": {"tokens": [{"text": "夜", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "地方", "pos": "X"}, {"text": "熟睡", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "天光", "pos": "X"}, {"text": "睡", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "暖爐", "pos": "X"}, {"text": "旁", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0009", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0011", "paragraph_id": "para_03"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0011", "text": "就像密友夜訪 治癒我不安 每晚客廳裏遊蕩", "structure": {"line_index": 11, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 5, 2, 9, 2, 2, 5, 3, 3, 5, 5, 4, 3, 5, 0, 2], "tone_pattern_cantonese_jyutping": ["zau6", "zoeng6", "mat6", "jau5", "je6", "fong2", "zi6", "jyu6", "ngo5", "bat1", "on1", "mui5", "maan5", "haak3", "ting1", "leoi5", "jau4", "dong6"]}, "nlp": {"tokens": [{"text": "就", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "密友", "pos": "X"}, {"text": "夜訪", "pos": "X"}, {"text": "治癒", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "不安", "pos": "X"}, {"text": "每晚", "pos": "X"}, {"text": "客廳", "pos": "X"}, {"text": "裏", "pos": "X"}, {"text": "遊蕩", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0010", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0012", "paragraph_id": "para_03"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0012", "text": "夜就爲你護航 故作很開朗 你卻很怕被淡忘", "structure": {"line_index": 12, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 5, 2, 0, 4, 4, 9, 3, 5, 5, 4, 9, 4, 2, 2, 0], "tone_pattern_cantonese_jyutping": ["je6", "zau6", "nei5", "wu6", "hong4", "gu3", "zok3", "han2", "hoi1", "long5", "nei5", "koek3", "han2", "paa3", "bei6", "daam6", "mong4"]}, "nlp": {"tokens": [{"text": "夜", "pos": "X"}, {"text": "就", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "護航", "pos": "X"}, {"text": "故作", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "開朗", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "很", "pos": "X"}, {"text": "怕", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "淡忘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0011", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0013", "paragraph_id": "para_03"}}
{"id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0013", "text": "但剩下我在旁 我卻擔心我 對你溺愛曝了光", "structure": {"line_index": 13, "char_count": 18}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 2, 5, 2, 0, 5, 4, 3, 3, 5, 4, 5, 3, 4, 2, 5, 3], "tone_pattern_cantonese_jyutping": ["daan6", "sing6", "haa6", "ngo5", "zoi6", "pong4", "ngo5", "koek3", "daam1", "sam1", "ngo5", "deoi3", "nei5", "nik1", "oi3", "buk6", "liu5", "gwong1"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "剩下", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "旁", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "擔心", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "溺愛", "pos": "X"}, {"text": "曝", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "光", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "先謊夜談", "artists": ["梅豔芳"], "lyricists": ["許志安", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2894", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0012", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5NA_0014", "paragraph_id": "para_03"}}
