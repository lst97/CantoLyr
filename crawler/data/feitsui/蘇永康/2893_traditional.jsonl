{"id": "lyr_5qKF6Imz6Iqz_Mjg5Mw_0004", "text": "爲這一種興奮 相信做人 越難越開心", "structure": {"line_index": 4, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 9, 3, 5, 4, 2, 0, 2, 0, 2, 3, 3], "tone_pattern_cantonese_jyutping": ["ze5", "jat1", "zung2", "hing1", "fan5", "seon3", "zou6", "jan4", "jyut6", "naan4", "jyut6", "hoi1", "sam1"]}, "nlp": {"tokens": [{"text": "爲", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "一種", "pos": "X"}, {"text": "興奮", "pos": "X"}, {"text": "相信", "pos": "X"}, {"text": "做人", "pos": "X"}, {"text": "越難", "pos": "X"}, {"text": "越", "pos": "X"}, {"text": "開心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "兩粒糖", "artists": ["梅豔芳"], "lyricists": ["蘇永康", "林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2893", "prev_line_id": "lyr_5qKF6Imz6Iqz_Mjg5Mw_0003", "next_line_id": "lyr_5qKF6Imz6Iqz_Mjg5Mw_0005", "paragraph_id": "para_02"}}
