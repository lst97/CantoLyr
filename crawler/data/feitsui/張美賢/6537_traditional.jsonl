{"id": "lyr_5ZC06Iul5biM_NjUzNw_0005", "text": "我記得 天空一片黑 沒人愛", "structure": {"line_index": 5, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 3, 3, 3, 3, 9, 3, 2, 0, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "gei3", "dak1", "tin1", "hung1", "jat1", "pin2", "hak1", "mut6", "jan4", "oi3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "記得", "pos": "X"}, {"text": "天空", "pos": "X"}, {"text": "一片", "pos": "X"}, {"text": "黑", "pos": "X"}, {"text": "沒人", "pos": "X"}, {"text": "愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我記得", "artists": ["吳若希"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6537", "prev_line_id": "lyr_5ZC06Iul5biM_NjUzNw_0004", "next_line_id": "lyr_5ZC06Iul5biM_NjUzNw_0006", "paragraph_id": "para_02"}}
