{"id": "lyr_5L2V6ZuB6K-X_NjMzMA_0004", "text": "拿來做留念 一起遮風擋箭", "structure": {"line_index": 4, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 0, 2, 3, 9, 3, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["naa4", "loi4", "zou6", "lau4", "nim6", "jat1", "hei2", "ze1", "fung1", "dong2", "zin3"]}, "nlp": {"tokens": [{"text": "拿來", "pos": "X"}, {"text": "做", "pos": "X"}, {"text": "留念", "pos": "X"}, {"text": "一起", "pos": "X"}, {"text": "遮", "pos": "X"}, {"text": "風擋", "pos": "X"}, {"text": "箭", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛近在眼前", "artists": ["何雁詩"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6330", "prev_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0003", "next_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5L2V6ZuB6K-X_NjMzMA_0005", "text": "要自信一點 頑強一點 全力備戰", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 4, 3, 9, 0, 0, 3, 9, 0, 2, 2, 4], "tone_pattern_cantonese_jyutping": ["jiu3", "zi6", "seon3", "jat1", "dim2", "waan4", "koeng4", "jat1", "dim2", "cyun4", "lik6", "bei6", "zin3"]}, "nlp": {"tokens": [{"text": "要", "pos": "X"}, {"text": "自信", "pos": "X"}, {"text": "一點", "pos": "X"}, {"text": "頑強", "pos": "X"}, {"text": "一點", "pos": "X"}, {"text": "全力", "pos": "X"}, {"text": "備戰", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛近在眼前", "artists": ["何雁詩"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6330", "prev_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0004", "next_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5L2V6ZuB6K-X_NjMzMA_0006", "text": "讚頌和掌聲 我也甘心在你背面", "structure": {"line_index": 6, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 0, 9, 3, 5, 5, 3, 3, 2, 5, 2, 2], "tone_pattern_cantonese_jyutping": ["zaan3", "zung6", "wo4", "zoeng2", "sing1", "ngo5", "jaa5", "gam1", "sam1", "zoi6", "nei5", "bui6", "min6"]}, "nlp": {"tokens": [{"text": "讚頌", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "掌聲", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "甘心", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "背面", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛近在眼前", "artists": ["何雁詩"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6330", "prev_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0005", "next_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5L2V6ZuB6K-X_NjMzMA_0007", "text": "原來白天消逝 繁星天際 纔看到光輝", "structure": {"line_index": 7, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 3, 3, 2, 0, 3, 3, 4, 0, 4, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["jyun4", "loi4", "baak6", "tin1", "siu1", "sai6", "faan4", "sing1", "tin1", "zai3", "coi4", "hon3", "dou3", "gwong1", "fai1"]}, "nlp": {"tokens": [{"text": "原來", "pos": "X"}, {"text": "白天", "pos": "X"}, {"text": "消逝", "pos": "X"}, {"text": "繁星", "pos": "X"}, {"text": "天際", "pos": "X"}, {"text": "才", "pos": "X"}, {"text": "看到", "pos": "X"}, {"text": "光輝", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛近在眼前", "artists": ["何雁詩"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6330", "prev_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0006", "next_line_id": "lyr_5L2V6ZuB6K-X_NjMzMA_0008", "paragraph_id": "para_03"}}
