{"id": "lyr_6I-K5qKT5LmU_NjQ5Mw_0004", "text": "仰望崇拜你 完美得太離地", "structure": {"line_index": 4, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 0, 4, 5, 0, 5, 3, 4, 0, 2], "tone_pattern_cantonese_jyutping": ["joeng5", "mong6", "sung4", "baai3", "nei5", "jyun4", "mei5", "dak1", "taai3", "lei4", "dei6"]}, "nlp": {"tokens": [{"text": "仰望", "pos": "X"}, {"text": "崇拜", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "完美", "pos": "X"}, {"text": "得太離", "pos": "X"}, {"text": "地", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "欲言又止", "artists": ["菊梓喬"], "lyricists": ["張美賢"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6493", "prev_line_id": "lyr_6I-K5qKT5LmU_NjQ5Mw_0003", "next_line_id": "lyr_6I-K5qKT5LmU_NjQ5Mw_0005", "paragraph_id": "para_01"}}
