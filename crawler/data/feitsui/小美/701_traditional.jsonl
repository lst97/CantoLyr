{"id": "lyr_5byg5Zu96I2j_NzAx_0001", "text": "抬頭望星空一片靜 我獨行 夜雨漸停", "structure": {"line_index": 1, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 3, 3, 3, 9, 2, 5, 2, 0, 2, 5, 2, 0], "tone_pattern_cantonese_jyutping": ["toi4", "tau4", "mong6", "sing1", "hung1", "jat1", "pin2", "zing6", "ngo5", "duk6", "hang4", "je6", "jyu5", "zim6", "ting4"]}, "nlp": {"tokens": [{"text": "抬頭", "pos": "X"}, {"text": "望星空", "pos": "X"}, {"text": "一片", "pos": "X"}, {"text": "靜", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "獨行", "pos": "X"}, {"text": "夜雨", "pos": "X"}, {"text": "漸停", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "有誰共鳴", "artists": ["張國榮"], "lyricists": ["小美"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_701", "prev_line_id": null, "next_line_id": "lyr_5byg5Zu96I2j_NzAx_0002", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5Zu96I2j_NzAx_0002", "text": "無言是此刻的冷靜 笑問誰 肝膽照應", "structure": {"line_index": 2, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 9, 3, 3, 5, 2, 4, 2, 0, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["mou4", "jin4", "si6", "ci2", "hak1", "dik1", "laang5", "zing6", "siu3", "man6", "seoi4", "gon1", "daam2", "ziu3"]}, "nlp": {"tokens": [{"text": "無言", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "此刻", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "冷靜", "pos": "X"}, {"text": "笑", "pos": "X"}, {"text": "問", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "肝膽", "pos": "X"}, {"text": "照應", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "有誰共鳴", "artists": ["張國榮"], "lyricists": ["小美"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_701", "prev_line_id": "lyr_5byg5Zu96I2j_NzAx_0001", "next_line_id": "lyr_5byg5Zu96I2j_NzAx_0003", "paragraph_id": "para_01"}}
{"id": "lyr_5byg5Zu96I2j_NzAx_0003", "text": "風急風也清 告知變幻是無定", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 5, 3, 4, 3, 4, 2, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["fung1", "gap1", "fung1", "jaa5", "cing1", "gou3", "zi1", "bin3", "waan6", "si6", "mou4", "ding6"]}, "nlp": {"tokens": [{"text": "風", "pos": "X"}, {"text": "急風", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "清", "pos": "X"}, {"text": "告知", "pos": "X"}, {"text": "變幻", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "無定", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "有誰共鳴", "artists": ["張國榮"], "lyricists": ["小美"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_701", "prev_line_id": "lyr_5byg5Zu96I2j_NzAx_0002", "next_line_id": "lyr_5byg5Zu96I2j_NzAx_0004", "paragraph_id": "para_02"}}
{"id": "lyr_5byg5Zu96I2j_NzAx_0004", "text": "未明是我苦笑卻未停", "structure": {"line_index": 4, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 2, 5, 9, 4, 4, 2, 0], "tone_pattern_cantonese_jyutping": ["mei6", "ming4", "si6", "ngo5", "fu2", "siu3", "koek3", "mei6", "ting4"]}, "nlp": {"tokens": [{"text": "未明", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "苦笑", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "未", "pos": "X"}, {"text": "停", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "有誰共鳴", "artists": ["張國榮"], "lyricists": ["小美"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_701", "prev_line_id": "lyr_5byg5Zu96I2j_NzAx_0003", "next_line_id": "lyr_5byg5Zu96I2j_NzAx_0005", "paragraph_id": "para_02"}}
