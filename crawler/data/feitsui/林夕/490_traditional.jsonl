{"id": "lyr_6YOR56eA5paH_NDkw_0007", "text": "朋友 誰曾令你受過傷別人同樣也被你所", "structure": {"line_index": 7, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 0, 0, 2, 5, 2, 4, 3, 2, 0, 0, 2, 5, 2, 5, 9], "tone_pattern_cantonese_jyutping": ["pang4", "jau5", "seoi4", "cang4", "ling6", "nei5", "sau6", "gwo3", "soeng1", "bit6", "jan4", "tung4", "joeng6", "jaa5", "bei6", "nei5", "so2"]}, "nlp": {"tokens": [{"text": "朋友", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "令", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "受過傷", "pos": "X"}, {"text": "別人", "pos": "X"}, {"text": "同樣", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "所", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "傷", "artists": ["鄭秀文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_490", "prev_line_id": "lyr_6YOR56eA5paH_NDkw_0006", "next_line_id": "lyr_6YOR56eA5paH_NDkw_0008", "paragraph_id": "para_02"}}
