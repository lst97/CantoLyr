{"id": "lyr_6YOR56eA5paH_NDkw_0004", "text": "望盡世間櫥窗 我也想找對象", "structure": {"line_index": 4, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 4, 3, 3, 5, 5, 9, 9, 4, 2], "tone_pattern_cantonese_jyutping": ["mong6", "zeon6", "sai3", "cyu1", "coeng1", "ngo5", "jaa5", "soeng2", "zaau2", "deoi3", "zoeng6"]}, "nlp": {"tokens": [{"text": "望", "pos": "X"}, {"text": "盡", "pos": "X"}, {"text": "世間", "pos": "X"}, {"text": "櫥窗", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "找對象", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "傷", "artists": ["鄭秀文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_490", "prev_line_id": "lyr_6YOR56eA5paH_NDkw_0003", "next_line_id": "lyr_6YOR56eA5paH_NDkw_0005", "paragraph_id": "para_02"}}
