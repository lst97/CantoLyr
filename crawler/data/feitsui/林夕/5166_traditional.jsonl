{"id": "lyr_5a6556WW5YS__NTE2Ng_0007", "text": "你不要擔憂", "structure": {"line_index": 7, "char_count": 5}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["nei5", "bat1", "jiu3", "daam1", "jau1"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "不要", "pos": "X"}, {"text": "擔憂", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "新貴", "artists": ["容祖兒"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5166", "prev_line_id": "lyr_5a6556WW5YS__NTE2Ng_0006", "next_line_id": "lyr_5a6556WW5YS__NTE2Ng_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5a6556WW5YS__NTE2Ng_0008", "text": "爲了掩飾傷口便找個人代你", "structure": {"line_index": 8, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 3, 3, 9, 2, 9, 4, 0, 2, 5], "tone_pattern_cantonese_jyutping": ["liu5", "jim2", "sik1", "soeng1", "hau2", "bin6", "zaau2", "go3", "jan4", "doi6", "nei5"]}, "nlp": {"tokens": [{"text": "爲了", "pos": "X"}, {"text": "掩飾", "pos": "X"}, {"text": "傷口", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "找", "pos": "X"}, {"text": "個人", "pos": "X"}, {"text": "代", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "新貴", "artists": ["容祖兒"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5166", "prev_line_id": "lyr_5a6556WW5YS__NTE2Ng_0007", "next_line_id": "lyr_5a6556WW5YS__NTE2Ng_0009", "paragraph_id": "para_02"}}
