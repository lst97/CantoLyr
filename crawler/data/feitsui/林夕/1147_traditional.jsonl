{"id": "lyr_6I2J6Jyi_MTE0Nw_0003", "text": "能夠和你在一起 去經歷下一個冒險", "structure": {"line_index": 3, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 4, 0, 5, 2, 3, 9, 4, 3, 2, 2, 3, 4, 2, 9], "tone_pattern_cantonese_jyutping": ["nang4", "gau3", "wo4", "nei5", "zoi6", "jat1", "hei2", "heoi3", "ging1", "lik6", "haa6", "jat1", "go3", "mou6", "him2"]}, "nlp": {"tokens": [{"text": "能夠", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "一起", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "經歷", "pos": "X"}, {"text": "下", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "冒險", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "朋友", "artists": ["草蜢"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1147", "prev_line_id": "lyr_6I2J6Jyi_MTE0Nw_0002", "next_line_id": "lyr_6I2J6Jyi_MTE0Nw_0004", "paragraph_id": "para_01"}}
