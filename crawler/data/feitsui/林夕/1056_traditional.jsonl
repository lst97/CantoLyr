{"id": "lyr_5YWz5b-D5aaN_MTA1Ng_0010", "text": "殘忍到 怕去承認真相", "structure": {"line_index": 10, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 9, 4, 4, 4, 0, 2, 3], "tone_pattern_cantonese_jyutping": ["caan4", "jan2", "dou3", "paa3", "heoi3", "sing4", "jing6", "zan1"]}, "nlp": {"tokens": [{"text": "殘忍", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "怕", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "承認", "pos": "X"}, {"text": "真相", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "假使我漂亮", "artists": ["關心妍"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1056", "prev_line_id": "lyr_5YWz5b-D5aaN_MTA1Ng_0009", "next_line_id": "lyr_5YWz5b-D5aaN_MTA1Ng_0011", "paragraph_id": "para_02"}}
