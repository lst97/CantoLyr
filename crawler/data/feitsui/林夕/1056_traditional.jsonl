{"id": "lyr_5YWz5b-D5aaN_MTA1Ng_0012", "text": "到我親吻你即使要面對面時你沒有在乎一看", "structure": {"line_index": 12, "char_count": 19}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 5, 3, 5, 5, 3, 9, 4, 2, 4, 2, 0, 5, 2, 5, 2, 0, 3, 4], "tone_pattern_cantonese_jyutping": ["dou3", "ngo5", "can1", "man5", "nei5", "zik1", "si2", "jiu3", "min6", "deoi3", "min6", "si4", "nei5", "mut6", "jau5", "zoi6", "fu4", "jat1", "hon3"]}, "nlp": {"tokens": [{"text": "到", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "親吻", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "即使", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "面對面", "pos": "X"}, {"text": "時", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "沒有", "pos": "X"}, {"text": "在乎", "pos": "X"}, {"text": "一看", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "假使我漂亮", "artists": ["關心妍"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1056", "prev_line_id": "lyr_5YWz5b-D5aaN_MTA1Ng_0011", "next_line_id": "lyr_5YWz5b-D5aaN_MTA1Ng_0013", "paragraph_id": "para_03"}}
