{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0009", "text": "看着眼前人睡了 和幸福多接近", "structure": {"line_index": 9, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [4, 2, 5, 0, 0, 2, 5, 0, 2, 3, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["hon3", "zoek6", "ngaan5", "cin4", "jan4", "seoi6", "liu5", "wo4", "hang6", "fuk1", "do1", "zip3", "gan6"]}, "nlp": {"tokens": [{"text": "看着", "pos": "X"}, {"text": "眼前", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "睡", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "幸福", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "接近", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0008", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0010", "paragraph_id": "para_03"}}
{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0010", "text": "等了多年這角色 做你的女人", "structure": {"line_index": 10, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 5, 3, 0, 5, 4, 3, 2, 5, 3, 5, 0], "tone_pattern_cantonese_jyutping": ["dang2", "liu5", "do1", "nin4", "ze5", "gok3", "sik1", "zou6", "nei5", "dik1", "neoi5", "jan4"]}, "nlp": {"tokens": [{"text": "等", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "多年", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "角色", "pos": "X"}, {"text": "做", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "女人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0009", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0011", "paragraph_id": "para_03"}}
