{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0003", "text": "努力向前誰沒有 誰料歇息的藉口", "structure": {"line_index": 3, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 0, 0, 2, 5, 0, 2, 4, 3, 3, 2, 9], "tone_pattern_cantonese_jyutping": ["nou5", "lik6", "hoeng3", "cin4", "seoi4", "mut6", "jau5", "seoi4", "liu6", "hit3", "sik1", "dik1", "zik6", "hau2"]}, "nlp": {"tokens": [{"text": "努力", "pos": "X"}, {"text": "向前", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "沒有", "pos": "X"}, {"text": "誰料", "pos": "X"}, {"text": "歇息", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "藉口", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0002", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0004", "text": "是要把抑鬱眼淚再流", "structure": {"line_index": 4, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 9, 3, 3, 5, 2, 4, 0], "tone_pattern_cantonese_jyutping": ["si6", "jiu3", "baa2", "jik1", "wat1", "ngaan5", "leoi6", "zoi3", "lau4"]}, "nlp": {"tokens": [{"text": "是", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "把", "pos": "X"}, {"text": "抑鬱", "pos": "X"}, {"text": "眼淚", "pos": "X"}, {"text": "再流", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0003", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0005", "text": "誰自願獨立於天地 痛了也讓人看", "structure": {"line_index": 5, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 2, 2, 3, 3, 2, 4, 5, 5, 2, 0, 4], "tone_pattern_cantonese_jyutping": ["seoi4", "zi6", "jyun6", "duk6", "laap6", "jyu1", "tin1", "dei6", "tung3", "liu5", "jaa5", "joeng6", "jan4", "hon3"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "自願", "pos": "X"}, {"text": "獨立", "pos": "X"}, {"text": "於", "pos": "X"}, {"text": "天地", "pos": "X"}, {"text": "痛", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "看", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0004", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0006", "text": "你我卻須要 在人前被仰望", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 4, 3, 4, 2, 0, 0, 2, 5, 2], "tone_pattern_cantonese_jyutping": ["nei5", "ngo5", "koek3", "seoi1", "jiu3", "zoi6", "jan4", "cin4", "bei6", "joeng5", "mong6"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "須要", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "人前", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "仰望", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0005", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0007", "text": "連造夢亦未敢想像 我會這樣硬朗", "structure": {"line_index": 7, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 2, 2, 9, 9, 2, 5, 5, 2, 2, 5], "tone_pattern_cantonese_jyutping": ["lin4", "zou6", "mung6", "jik6", "mei6", "gam2", "soeng2", "zoeng6", "ngo5", "ze5", "joeng6", "ngaang6", "long5"]}, "nlp": {"tokens": [{"text": "連造", "pos": "X"}, {"text": "夢", "pos": "X"}, {"text": "亦", "pos": "X"}, {"text": "未敢", "pos": "X"}, {"text": "想像", "pos": "X"}, {"text": "我會", "pos": "X"}, {"text": "這樣", "pos": "X"}, {"text": "硬朗", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "女人心", "artists": ["梅豔芳"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3253", "prev_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0006", "next_line_id": "lyr_5qKF6Imz6Iqz_MzI1Mw_0008", "paragraph_id": "para_02"}}
