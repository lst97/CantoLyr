{"id": "lyr_6YOt5a-M5Z-O_MjgxNA_0018", "text": "懷疑你喜歡得將它每晚都深呼吸幾下", "structure": {"line_index": 18, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 5, 9, 3, 3, 3, 3, 5, 5, 3, 3, 3, 3, 9, 2], "tone_pattern_cantonese_jyutping": ["waai4", "ji4", "nei5", "hei2", "fun1", "dak1", "zoeng1", "taa1", "mui5", "maan5", "dou1", "sam1", "fu1", "kap1", "gei2", "haa6"]}, "nlp": {"tokens": [{"text": "懷疑", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "將", "pos": "X"}, {"text": "它", "pos": "X"}, {"text": "每晚", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "深呼吸", "pos": "X"}, {"text": "幾下", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "錯愛的呼喚", "artists": ["郭富城"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2814", "prev_line_id": "lyr_6YOt5a-M5Z-O_MjgxNA_0017", "next_line_id": "lyr_6YOt5a-M5Z-O_MjgxNA_0019", "paragraph_id": "para_05"}}
{"id": "lyr_6YOt5a-M5Z-O_MjgxNA_0019", "text": "其時你愛暫住我家 渡過今生未渡的假", "structure": {"line_index": 19, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 5, 4, 2, 2, 5, 3, 2, 4, 3, 3, 2, 2, 3, 9], "tone_pattern_cantonese_jyutping": ["kei4", "si4", "nei5", "oi3", "zaam6", "zyu6", "ngo5", "gaa1", "dou6", "gwo3", "gam1", "sang1", "mei6", "dou6", "dik1", "gaa2"]}, "nlp": {"tokens": [{"text": "其時", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "暫住", "pos": "X"}, {"text": "我家", "pos": "X"}, {"text": "渡過", "pos": "X"}, {"text": "今生", "pos": "X"}, {"text": "未渡", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "假", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "錯愛的呼喚", "artists": ["郭富城"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2814", "prev_line_id": "lyr_6YOt5a-M5Z-O_MjgxNA_0018", "next_line_id": "lyr_6YOt5a-M5Z-O_MjgxNA_0020", "paragraph_id": "para_05"}}
