{"id": "lyr_6ZmI5aWV6L-F_MTA0_0021", "text": "只想你和伴侶要好才頑強病好", "structure": {"line_index": 21, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 5, 0, 2, 5, 4, 9, 0, 0, 0, 2, 9], "tone_pattern_cantonese_jyutping": ["zi2", "soeng2", "nei5", "wo4", "bun6", "leoi5", "jiu3", "hou2", "coi4", "waan4", "koeng4", "beng6", "hou2"]}, "nlp": {"tokens": [{"text": "只想", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "伴侶", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "才", "pos": "X"}, {"text": "頑強", "pos": "X"}, {"text": "病好", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "一絲不掛", "artists": ["陳奕迅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_104", "prev_line_id": "lyr_6ZmI5aWV6L-F_MTA0_0020", "next_line_id": "lyr_6ZmI5aWV6L-F_MTA0_0022", "paragraph_id": "para_05"}}
