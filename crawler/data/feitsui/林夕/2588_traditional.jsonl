{"id": "lyr_5p6X5bOw_MjU4OA_0006", "text": "你大概自尊心不再 再不敢出來", "structure": {"line_index": 6, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 2, 3, 3, 3, 4, 4, 3, 9, 3, 0], "tone_pattern_cantonese_jyutping": ["nei5", "daai6", "koi3", "zi6", "zyun1", "sam1", "bat1", "zoi3", "zoi3", "bat1", "gam2", "ceot1", "loi4"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "大概", "pos": "X"}, {"text": "自尊心", "pos": "X"}, {"text": "不再", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "不敢", "pos": "X"}, {"text": "出來", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "你並不孤單", "artists": ["林峯"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2588", "prev_line_id": "lyr_5p6X5bOw_MjU4OA_0005", "next_line_id": "lyr_5p6X5bOw_MjU4OA_0007", "paragraph_id": "para_01"}}
