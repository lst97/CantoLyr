{"id": "lyr_5YWz5pm65paM_Mjk2OA_0003", "text": "傷心的我 似活在夢中 都因被你擊中", "structure": {"line_index": 3, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 5, 5, 2, 2, 2, 3, 3, 3, 2, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["soeng1", "sam1", "dik1", "ngo5", "ci5", "wut6", "zoi6", "mung6", "zung1", "dou1", "jan1", "bei6", "nei5", "gik1", "zung1"]}, "nlp": {"tokens": [{"text": "傷心", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "似活", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "夢", "pos": "X"}, {"text": "中", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "因", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "擊中", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0002", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0004", "text": "知你尚對我好 第三者殺到", "structure": {"line_index": 4, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 5, 2, 4, 5, 9, 2, 3, 9, 4, 4], "tone_pattern_cantonese_jyutping": ["zi1", "nei5", "soeng6", "deoi3", "ngo5", "hou2", "dai6", "saam1", "ze2", "saat3", "dou3"]}, "nlp": {"tokens": [{"text": "知", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "尚", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "第三者", "pos": "X"}, {"text": "殺到", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0003", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0005", "paragraph_id": "para_02"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0005", "text": "你卻內疚吻我不到", "structure": {"line_index": 5, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 2, 4, 5, 5, 3, 4], "tone_pattern_cantonese_jyutping": ["nei5", "koek3", "noi6", "gau3", "man5", "ngo5", "bat1", "dou3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "內疚", "pos": "X"}, {"text": "吻", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "不到", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0004", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0006", "paragraph_id": "para_02"}}
