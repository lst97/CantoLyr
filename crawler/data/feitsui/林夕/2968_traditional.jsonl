{"id": "lyr_5YWz5pm65paM_Mjk2OA_0014", "text": "所希望太少 所失望太多 誰人想我", "structure": {"line_index": 14, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 2, 4, 9, 3, 2, 4, 3, 0, 0, 9, 5], "tone_pattern_cantonese_jyutping": ["so2", "hei1", "mong6", "taai3", "so2", "sat1", "mong6", "taai3", "do1", "seoi4", "jan4", "soeng2", "ngo5"]}, "nlp": {"tokens": [{"text": "所", "pos": "X"}, {"text": "希望", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "少", "pos": "X"}, {"text": "所", "pos": "X"}, {"text": "失望", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0013", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0015", "paragraph_id": "para_04"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0015", "text": "想我 想我 那會愛定我", "structure": {"line_index": 15, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 5, 9, 5, 5, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["soeng2", "ngo5", "soeng2", "ngo5", "naa5", "oi3", "ding6", "ngo5"]}, "nlp": {"tokens": [{"text": "想", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "那會", "pos": "X"}, {"text": "愛定", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0014", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0016", "paragraph_id": "para_04"}}
