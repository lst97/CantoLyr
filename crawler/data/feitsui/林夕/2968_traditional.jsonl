{"id": "lyr_5YWz5pm65paM_Mjk2OA_0025", "text": "我也對你偉大 誠實去祝賀", "structure": {"line_index": 25, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 4, 5, 5, 2, 0, 2, 4, 3, 2], "tone_pattern_cantonese_jyutping": ["ngo5", "jaa5", "deoi3", "nei5", "wai5", "daai6", "sing4", "sat6", "heoi3", "zuk1", "ho6"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "偉大", "pos": "X"}, {"text": "誠實", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "祝賀", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0024", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0026", "paragraph_id": "para_07"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0026", "text": "這麼方能提醒我 沒情人仍是我", "structure": {"line_index": 26, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 0, 0, 9, 5, 2, 0, 0, 0, 2, 5], "tone_pattern_cantonese_jyutping": ["ze5", "mo1", "fong1", "nang4", "tai4", "sing2", "ngo5", "mut6", "cing4", "jan4", "jing4", "si6", "ngo5"]}, "nlp": {"tokens": [{"text": "這麼", "pos": "X"}, {"text": "方", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "提醒", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "情人", "pos": "X"}, {"text": "仍", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0025", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0027", "paragraph_id": "para_08"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0027", "text": "無謂受盡痛苦 但求拒絕折磨", "structure": {"line_index": 27, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 2, 4, 9, 2, 0, 5, 2, 4, 0], "tone_pattern_cantonese_jyutping": ["mou4", "wai6", "sau6", "zeon6", "tung3", "fu2", "daan6", "kau4", "keoi5", "zyut6", "zit3", "mo4"]}, "nlp": {"tokens": [{"text": "無謂", "pos": "X"}, {"text": "受盡", "pos": "X"}, {"text": "痛苦", "pos": "X"}, {"text": "但求", "pos": "X"}, {"text": "拒絕", "pos": "X"}, {"text": "折磨", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0026", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0028", "paragraph_id": "para_08"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0028", "text": "所希望太少 所失望太多 誰人想我", "structure": {"line_index": 28, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 2, 4, 9, 3, 2, 4, 3, 0, 0, 9, 5], "tone_pattern_cantonese_jyutping": ["so2", "hei1", "mong6", "taai3", "so2", "sat1", "mong6", "taai3", "do1", "seoi4", "jan4", "soeng2", "ngo5"]}, "nlp": {"tokens": [{"text": "所", "pos": "X"}, {"text": "希望", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "少", "pos": "X"}, {"text": "所", "pos": "X"}, {"text": "失望", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0027", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0029", "paragraph_id": "para_08"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0029", "text": "想我 想我 那會愛定我", "structure": {"line_index": 29, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 5, 9, 5, 5, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["soeng2", "ngo5", "soeng2", "ngo5", "naa5", "oi3", "ding6", "ngo5"]}, "nlp": {"tokens": [{"text": "想", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "那會", "pos": "X"}, {"text": "愛定", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0028", "next_line_id": null, "paragraph_id": "para_08"}}
