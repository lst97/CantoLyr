{"id": "lyr_5YWz5pm65paM_Mjk2OA_0021", "text": "如良朋來回仲更多 日後更珍惜我是我", "structure": {"line_index": 21, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 0, 0, 0, 2, 3, 2, 2, 3, 3, 5, 2, 5], "tone_pattern_cantonese_jyutping": ["jyu4", "loeng4", "pang4", "loi4", "wui4", "zung6", "do1", "jat6", "hau6", "zan1", "sik1", "ngo5", "si6", "ngo5"]}, "nlp": {"tokens": [{"text": "如", "pos": "X"}, {"text": "良朋", "pos": "X"}, {"text": "來回", "pos": "X"}, {"text": "仲", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "日後", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "珍惜", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0020", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0022", "paragraph_id": "para_06"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0022", "text": "彼此曾認真過 但其餘人物太多", "structure": {"line_index": 22, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 0, 2, 3, 4, 2, 0, 0, 0, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["bei2", "ci2", "cang4", "jing6", "zan1", "gwo3", "daan6", "kei4", "jyu4", "jan4", "mat6", "taai3", "do1"]}, "nlp": {"tokens": [{"text": "彼此", "pos": "X"}, {"text": "曾", "pos": "X"}, {"text": "認真", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "其餘", "pos": "X"}, {"text": "人物", "pos": "X"}, {"text": "太", "pos": "X"}, {"text": "多", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0021", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0023", "paragraph_id": "para_07"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0023", "text": "終於多得你沒有枉過", "structure": {"line_index": 23, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 3, 5, 2, 5, 9, 4], "tone_pattern_cantonese_jyutping": ["zung1", "jyu1", "do1", "dak1", "nei5", "mut6", "jau5", "wong2", "gwo3"]}, "nlp": {"tokens": [{"text": "終於", "pos": "X"}, {"text": "多得", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "沒有", "pos": "X"}, {"text": "枉", "pos": "X"}, {"text": "過", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0022", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0024", "paragraph_id": "para_07"}}
