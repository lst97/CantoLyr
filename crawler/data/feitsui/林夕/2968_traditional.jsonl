{"id": "lyr_5YWz5pm65paM_Mjk2OA_0008", "text": "靈犀一點誰提點我", "structure": {"line_index": 8, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 9, 0, 0, 9, 5], "tone_pattern_cantonese_jyutping": ["ling4", "sai1", "jat1", "dim2", "seoi4", "tai4", "dim2", "ngo5"]}, "nlp": {"tokens": [{"text": "靈犀", "pos": "X"}, {"text": "一點", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "提點", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0007", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0009", "paragraph_id": "para_03"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0009", "text": "二人行難渡過 擠多位怎樣過", "structure": {"line_index": 9, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 0, 0, 2, 4, 3, 3, 2, 9, 2, 4], "tone_pattern_cantonese_jyutping": ["ji6", "jan4", "hang4", "naan4", "dou6", "gwo3", "zai1", "do1", "wai6", "zam2", "joeng6", "gwo3"]}, "nlp": {"tokens": [{"text": "二人", "pos": "X"}, {"text": "行難", "pos": "X"}, {"text": "渡過", "pos": "X"}, {"text": "擠", "pos": "X"}, {"text": "多位", "pos": "X"}, {"text": "怎樣", "pos": "X"}, {"text": "過", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0008", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0010", "paragraph_id": "para_03"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0010", "text": "情伴有很多 明日留給我", "structure": {"line_index": 10, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 9, 3, 0, 2, 0, 3, 5], "tone_pattern_cantonese_jyutping": ["cing4", "bun6", "jau5", "han2", "do1", "ming4", "jat6", "lau4", "kap1", "ngo5"]}, "nlp": {"tokens": [{"text": "情", "pos": "X"}, {"text": "伴有", "pos": "X"}, {"text": "很多", "pos": "X"}, {"text": "明日", "pos": "X"}, {"text": "留給", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0009", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0011", "paragraph_id": "para_03"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0011", "text": "怎麼要喫苦果 受盡冷落", "structure": {"line_index": 11, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 4, 4, 9, 9, 2, 2, 5, 2], "tone_pattern_cantonese_jyutping": ["zam2", "mo1", "jiu3", "hek3", "fu2", "gwo2", "sau6", "zeon6", "laang5", "lok6"]}, "nlp": {"tokens": [{"text": "怎麼", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "喫", "pos": "X"}, {"text": "苦果", "pos": "X"}, {"text": "受盡", "pos": "X"}, {"text": "冷落", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0010", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0012", "paragraph_id": "para_03"}}
{"id": "lyr_5YWz5pm65paM_Mjk2OA_0012", "text": "靈機一觸來提醒我 沒情人仍是我", "structure": {"line_index": 12, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 3, 0, 0, 9, 5, 2, 0, 0, 0, 2, 5], "tone_pattern_cantonese_jyutping": ["ling4", "gei1", "jat1", "cuk1", "loi4", "tai4", "sing2", "ngo5", "mut6", "cing4", "jan4", "jing4", "si6", "ngo5"]}, "nlp": {"tokens": [{"text": "靈機", "pos": "X"}, {"text": "一觸", "pos": "X"}, {"text": "來", "pos": "X"}, {"text": "提醒", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "情人", "pos": "X"}, {"text": "仍", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "靈犀", "artists": ["關智斌"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2968", "prev_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0011", "next_line_id": "lyr_5YWz5pm65paM_Mjk2OA_0013", "paragraph_id": "para_04"}}
