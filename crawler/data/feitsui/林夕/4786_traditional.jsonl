{"id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0003", "text": "怎慶祝 還是去街 別搞得這麼大", "structure": {"line_index": 3, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 3, 0, 2, 4, 3, 2, 9, 3, 5, 3, 2], "tone_pattern_cantonese_jyutping": ["zam2", "hing3", "zuk1", "waan4", "si6", "heoi3", "gaai1", "bit6", "gaau2", "dak1", "ze5", "mo1", "daai6"]}, "nlp": {"tokens": [{"text": "怎", "pos": "X"}, {"text": "慶祝", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "街", "pos": "X"}, {"text": "別搞", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "這麼", "pos": "X"}, {"text": "大", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛你入骨", "artists": ["陳奕迅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4786", "prev_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0002", "next_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0004", "text": "你卻說沒法挨 我真的要了解", "structure": {"line_index": 4, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 4, 2, 4, 0, 5, 3, 3, 4, 5, 9], "tone_pattern_cantonese_jyutping": ["nei5", "koek3", "syut3", "mut6", "faat3", "ngaai4", "ngo5", "zan1", "dik1", "jiu3", "liu5", "gaai2"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "卻說", "pos": "X"}, {"text": "沒法", "pos": "X"}, {"text": "挨", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "真的", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "瞭解", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛你入骨", "artists": ["陳奕迅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4786", "prev_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0003", "next_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0005", "text": "我心中的你深得見骨", "structure": {"line_index": 5, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 3, 5, 3, 3, 4, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "sam1", "zung1", "dik1", "nei5", "sam1", "dak1", "gin3", "gwat1"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "心中", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "深得", "pos": "X"}, {"text": "見", "pos": "X"}, {"text": "骨", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛你入骨", "artists": ["陳奕迅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4786", "prev_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0004", "next_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0006", "paragraph_id": "para_02"}}
