{"id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0001", "text": "你總記得 拿着雪糕 牽手闖天涯", "structure": {"line_index": 1, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 4, 3, 0, 2, 4, 3, 3, 9, 9, 3, 0], "tone_pattern_cantonese_jyutping": ["nei5", "zung2", "gei3", "dak1", "naa4", "zoek6", "syut3", "gou1", "hin1", "sau2", "cong2", "tin1", "ngaai4"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "總", "pos": "X"}, {"text": "記得", "pos": "X"}, {"text": "拿", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "雪糕", "pos": "X"}, {"text": "牽手", "pos": "X"}, {"text": "闖", "pos": "X"}, {"text": "天涯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛你入骨", "artists": ["陳奕迅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_4786", "prev_line_id": null, "next_line_id": "lyr_6ZmI5aWV6L-F_NDc4Ng_0002", "paragraph_id": "para_01"}}
