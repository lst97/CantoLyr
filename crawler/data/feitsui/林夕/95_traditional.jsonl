{"id": "lyr_6LCi5a6J55Cq_OTU_0033", "text": "哪需得你的允許 我都會愛下去", "structure": {"line_index": 33, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 5, 3, 5, 9, 5, 3, 4, 2, 4], "tone_pattern_cantonese_jyutping": ["naa5", "seoi1", "dak1", "nei5", "dik1", "wan5", "heoi2", "ngo5", "dou1", "oi3", "haa6", "heoi3"]}, "nlp": {"tokens": [{"text": "哪", "pos": "X"}, {"text": "需得", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "允許", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "下去", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "鍾無豔", "artists": ["謝安琪"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_95", "prev_line_id": "lyr_6LCi5a6J55Cq_OTU_0032", "next_line_id": "lyr_6LCi5a6J55Cq_OTU_0034", "paragraph_id": "para_09"}}
{"id": "lyr_6LCi5a6J55Cq_OTU_0034", "text": "互相祝福心軟之際或者準我吻下去", "structure": {"line_index": 34, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 3, 3, 3, 5, 3, 4, 2, 9, 9, 5, 5, 2, 4], "tone_pattern_cantonese_jyutping": ["wu6", "zuk1", "fuk1", "sam1", "jyun5", "zi1", "zai3", "waak6", "ze2", "zeon2", "ngo5", "man5", "haa6", "heoi3"]}, "nlp": {"tokens": [{"text": "互相", "pos": "X"}, {"text": "祝福", "pos": "X"}, {"text": "心軟", "pos": "X"}, {"text": "之際", "pos": "X"}, {"text": "或者", "pos": "X"}, {"text": "準", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "吻下去", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "鍾無豔", "artists": ["謝安琪"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_95", "prev_line_id": "lyr_6LCi5a6J55Cq_OTU_0033", "next_line_id": "lyr_6LCi5a6J55Cq_OTU_0035", "paragraph_id": "para_09"}}
