{"id": "lyr_6LCi5a6J55Cq_OTU_0003", "text": "無人及我用字絕重拾了你信心", "structure": {"line_index": 3, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 5, 2, 2, 2, 2, 5, 5, 4, 3], "tone_pattern_cantonese_jyutping": ["mou4", "jan4", "kap6", "ngo5", "jung6", "zi6", "zyut6", "sap6", "liu5", "nei5", "seon3", "sam1"]}, "nlp": {"tokens": [{"text": "無人", "pos": "X"}, {"text": "及", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "用字", "pos": "X"}, {"text": "絕", "pos": "X"}, {"text": "重拾", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "信心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "鍾無豔", "artists": ["謝安琪"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_95", "prev_line_id": "lyr_6LCi5a6J55Cq_OTU_0002", "next_line_id": "lyr_6LCi5a6J55Cq_OTU_0004", "paragraph_id": "para_01"}}
{"id": "lyr_6LCi5a6J55Cq_OTU_0004", "text": "無人問我可甘心演這偉大化身", "structure": {"line_index": 4, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 5, 9, 3, 3, 9, 5, 5, 2, 4, 3], "tone_pattern_cantonese_jyutping": ["mou4", "jan4", "man6", "ngo5", "ho2", "gam1", "sam1", "jin2", "ze5", "wai5", "daai6", "faa3", "san1"]}, "nlp": {"tokens": [{"text": "無人", "pos": "X"}, {"text": "問", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "可", "pos": "X"}, {"text": "甘心", "pos": "X"}, {"text": "演", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "偉大", "pos": "X"}, {"text": "化身", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "鍾無豔", "artists": ["謝安琪"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_95", "prev_line_id": "lyr_6LCi5a6J55Cq_OTU_0003", "next_line_id": "lyr_6LCi5a6J55Cq_OTU_0005", "paragraph_id": "para_01"}}
