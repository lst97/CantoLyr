{"id": "lyr_6LCi5a6J55Cq_OTU_0019", "text": "無人問我寂寞盡頭何處去養傷", "structure": {"line_index": 19, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 5, 2, 2, 2, 0, 0, 4, 5, 3], "tone_pattern_cantonese_jyutping": ["mou4", "jan4", "man6", "ngo5", "zik6", "mok6", "zeon6", "tau4", "ho4", "heoi3", "joeng5", "soeng1"]}, "nlp": {"tokens": [{"text": "無人", "pos": "X"}, {"text": "問", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "寂寞", "pos": "X"}, {"text": "盡頭", "pos": "X"}, {"text": "何處", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "養傷", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "鍾無豔", "artists": ["謝安琪"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_95", "prev_line_id": "lyr_6LCi5a6J55Cq_OTU_0018", "next_line_id": "lyr_6LCi5a6J55Cq_OTU_0020", "paragraph_id": "para_05"}}
{"id": "lyr_6LCi5a6J55Cq_OTU_0020", "text": "原來是我的心境高到變爲偶像", "structure": {"line_index": 20, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 2, 5, 3, 3, 9, 3, 4, 4, 5, 2], "tone_pattern_cantonese_jyutping": ["jyun4", "loi4", "si6", "ngo5", "dik1", "sam1", "ging2", "gou1", "dou3", "bin3", "ngau5", "zoeng6"]}, "nlp": {"tokens": [{"text": "原來", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心境", "pos": "X"}, {"text": "高到", "pos": "X"}, {"text": "變爲", "pos": "X"}, {"text": "偶像", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "鍾無豔", "artists": ["謝安琪"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_95", "prev_line_id": "lyr_6LCi5a6J55Cq_OTU_0019", "next_line_id": "lyr_6LCi5a6J55Cq_OTU_0021", "paragraph_id": "para_05"}}
