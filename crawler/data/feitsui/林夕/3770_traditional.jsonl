{"id": "lyr_5a2Z6ICA5aiB_Mzc3MA_0023", "text": "情人已背叛你 我是你 已經將她拋棄", "structure": {"line_index": 23, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 5, 2, 2, 5, 5, 2, 5, 5, 3, 3, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["cing4", "jan4", "ji5", "bui6", "bun6", "nei5", "ngo5", "si6", "nei5", "ji5", "ging1", "zoeng1", "taa1", "paau1", "hei3"]}, "nlp": {"tokens": [{"text": "情人", "pos": "X"}, {"text": "已", "pos": "X"}, {"text": "背叛", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "已經", "pos": "X"}, {"text": "將", "pos": "X"}, {"text": "她", "pos": "X"}, {"text": "拋棄", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "我教你分手", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3770", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzc3MA_0022", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzc3MA_0024", "paragraph_id": "para_06"}}
