{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0001", "text": "爲何狂歡時 仍讓眼淚不經意掉下來", "structure": {"line_index": 1, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 3, 0, 0, 2, 5, 2, 3, 3, 4, 2, 2, 0], "tone_pattern_cantonese_jyutping": ["ho4", "kwong4", "fun1", "si4", "jing4", "joeng6", "ngaan5", "leoi6", "bat1", "ging1", "ji3", "diu6", "haa6", "loi4"]}, "nlp": {"tokens": [{"text": "爲何", "pos": "X"}, {"text": "狂歡", "pos": "X"}, {"text": "時", "pos": "X"}, {"text": "仍", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "眼淚", "pos": "X"}, {"text": "不經意", "pos": "X"}, {"text": "掉下來", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": null, "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0002", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0002", "text": "爲何還感慨 難道我們不登對不恩愛", "structure": {"line_index": 2, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 9, 4, 0, 2, 5, 0, 3, 3, 4, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["ho4", "waan4", "gam2", "koi3", "naan4", "dou6", "ngo5", "mun4", "bat1", "dang1", "deoi3", "bat1", "jan1", "oi3"]}, "nlp": {"tokens": [{"text": "爲何", "pos": "X"}, {"text": "還", "pos": "X"}, {"text": "感慨", "pos": "X"}, {"text": "難道", "pos": "X"}, {"text": "我們", "pos": "X"}, {"text": "不登", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "恩愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0001", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0003", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0003", "text": "彼此都怕旁人問 每一晚 是共誰", "structure": {"line_index": 3, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 3, 4, 0, 0, 2, 5, 3, 5, 2, 2, 0], "tone_pattern_cantonese_jyutping": ["bei2", "ci2", "dou1", "paa3", "pong4", "jan4", "man6", "mui5", "jat1", "maan5", "si6", "gung6", "seoi4"]}, "nlp": {"tokens": [{"text": "彼此", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "怕", "pos": "X"}, {"text": "旁人", "pos": "X"}, {"text": "問", "pos": "X"}, {"text": "每一晚", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "共", "pos": "X"}, {"text": "誰", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0002", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0004", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0004", "text": "怎麼打發光陰 彼此都怕沒別人", "structure": {"line_index": 4, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 9, 4, 3, 3, 9, 9, 3, 4, 2, 2, 0], "tone_pattern_cantonese_jyutping": ["zam2", "mo1", "daa2", "faat3", "gwong1", "jam1", "bei2", "ci2", "dou1", "paa3", "mut6", "bit6", "jan4"]}, "nlp": {"tokens": [{"text": "怎麼", "pos": "X"}, {"text": "打發", "pos": "X"}, {"text": "光陰", "pos": "X"}, {"text": "彼此", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "怕", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "別人", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0003", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0005", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0005", "text": "留下如履薄冰的一吻", "structure": {"line_index": 5, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 0, 5, 2, 3, 3, 3, 5], "tone_pattern_cantonese_jyutping": ["lau4", "haa6", "jyu4", "lei5", "bok6", "bing1", "dik1", "jat1", "man5"]}, "nlp": {"tokens": [{"text": "留下", "pos": "X"}, {"text": "如履薄冰", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "一吻", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0004", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0006", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0006", "text": "分享孤獨 不必一個人老", "structure": {"line_index": 6, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 3, 2, 3, 3, 3, 4, 0, 5], "tone_pattern_cantonese_jyutping": ["fan1", "hoeng2", "gu1", "duk6", "bat1", "bit1", "jat1", "go3", "jan4", "lou5"]}, "nlp": {"tokens": [{"text": "分享", "pos": "X"}, {"text": "孤獨", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "老", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0005", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0007", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0007", "text": "找到理想 無非想人叫好", "structure": {"line_index": 7, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 4, 5, 9, 0, 3, 9, 0, 4, 9], "tone_pattern_cantonese_jyutping": ["zaau2", "dou3", "lei5", "soeng2", "mou4", "fei1", "soeng2", "jan4", "giu3", "hou2"]}, "nlp": {"tokens": [{"text": "找到", "pos": "X"}, {"text": "理想", "pos": "X"}, {"text": "無非", "pos": "X"}, {"text": "想人", "pos": "X"}, {"text": "叫好", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0006", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0008", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0008", "text": "分享孤獨 不必一個人傾訴", "structure": {"line_index": 8, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 3, 2, 3, 3, 3, 4, 0, 3, 4], "tone_pattern_cantonese_jyutping": ["fan1", "hoeng2", "gu1", "duk6", "bat1", "bit1", "jat1", "go3", "jan4", "king1", "sou3"]}, "nlp": {"tokens": [{"text": "分享", "pos": "X"}, {"text": "孤獨", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "傾訴", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0007", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0009", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0009", "text": "精緻晚餐 仍須找人去一起消耗", "structure": {"line_index": 9, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 5, 3, 0, 3, 9, 0, 4, 3, 9, 3, 4], "tone_pattern_cantonese_jyutping": ["zing1", "zi3", "maan5", "caan1", "jing4", "seoi1", "zaau2", "jan4", "heoi3", "jat1", "hei2", "siu1", "hou3"]}, "nlp": {"tokens": [{"text": "精緻", "pos": "X"}, {"text": "晚餐", "pos": "X"}, {"text": "仍須", "pos": "X"}, {"text": "找人", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "一起", "pos": "X"}, {"text": "消耗", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "分享孤獨", "artists": ["陳潔儀"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1882", "prev_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0008", "next_line_id": "lyr_6ZmI5rSB5Luq_MTg4Mg_0010", "paragraph_id": "para_03"}}
