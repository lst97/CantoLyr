{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0004", "text": "高攀過俯衝過幾個沙丘 自己一個走", "structure": {"line_index": 4, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 4, 9, 3, 4, 9, 4, 3, 3, 2, 9, 3, 4, 9], "tone_pattern_cantonese_jyutping": ["gou1", "paan1", "gwo3", "fu2", "cung1", "gwo3", "gei2", "go3", "saa1", "jau1", "zi6", "gei2", "jat1", "go3", "zau2"]}, "nlp": {"tokens": [{"text": "高攀", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "俯衝", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "幾個", "pos": "X"}, {"text": "沙丘", "pos": "X"}, {"text": "自己", "pos": "X"}, {"text": "一個", "pos": "X"}, {"text": "走", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0003", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0005", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0005", "text": "東歪西倒得一對手 夠依靠沒有", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 9, 3, 3, 4, 9, 4, 3, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["dung1", "waai1", "sai1", "dou2", "dak1", "jat1", "deoi3", "sau2", "gau3", "ji1", "kaau3", "mut6", "jau5"]}, "nlp": {"tokens": [{"text": "東歪西倒", "pos": "X"}, {"text": "得", "pos": "X"}, {"text": "一", "pos": "X"}, {"text": "對手", "pos": "X"}, {"text": "夠", "pos": "X"}, {"text": "依靠", "pos": "X"}, {"text": "沒有", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0004", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0006", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0006", "text": "我聽着我每步每步節奏 我怎樣承受", "structure": {"line_index": 6, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 2, 5, 5, 2, 5, 2, 4, 4, 5, 9, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["ngo5", "ting1", "zoek6", "ngo5", "mui5", "bou6", "mui5", "bou6", "zit3", "zau3", "ngo5", "zam2", "joeng6", "sing4", "sau6"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "聽", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "每步", "pos": "X"}, {"text": "每步", "pos": "X"}, {"text": "節奏", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "怎樣", "pos": "X"}, {"text": "承受", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0005", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0007", "paragraph_id": "para_01"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0007", "text": "不知你可有 站在我背後", "structure": {"line_index": 7, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 5, 9, 5, 2, 2, 5, 2, 2], "tone_pattern_cantonese_jyutping": ["bat1", "zi1", "nei5", "ho2", "jau5", "zaam6", "zoi6", "ngo5", "bui6", "hau6"]}, "nlp": {"tokens": [{"text": "不知", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "可", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "站", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "背後", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0006", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0008", "paragraph_id": "para_02"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0008", "text": "多麼的堅忍和強壯 都必需肩膊", "structure": {"line_index": 8, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 3, 9, 0, 0, 4, 3, 3, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["do1", "mo1", "dik1", "gin1", "jan2", "wo4", "koeng4", "zong3", "dou1", "bit1", "seoi1", "gin1", "bok3"]}, "nlp": {"tokens": [{"text": "多麼", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "堅忍", "pos": "X"}, {"text": "和", "pos": "X"}, {"text": "強壯", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "必需", "pos": "X"}, {"text": "肩膊", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0007", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0009", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0009", "text": "即使黑暗絕望至少 找得到倚傍", "structure": {"line_index": 9, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 3, 4, 2, 2, 4, 9, 3, 4, 9, 2], "tone_pattern_cantonese_jyutping": ["zik1", "si2", "hak1", "am3", "zyut6", "mong6", "zi3", "zaau2", "dak1", "dou3", "ji2", "bong6"]}, "nlp": {"tokens": [{"text": "即使", "pos": "X"}, {"text": "黑暗", "pos": "X"}, {"text": "絕望", "pos": "X"}, {"text": "至少", "pos": "X"}, {"text": "找", "pos": "X"}, {"text": "得到", "pos": "X"}, {"text": "倚傍", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0008", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0010", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0010", "text": "多麼的孤單如流放 藉藉你肩膊", "structure": {"line_index": 10, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 3, 3, 0, 0, 4, 4, 4, 5, 3, 4], "tone_pattern_cantonese_jyutping": ["do1", "mo1", "dik1", "gu1", "daan1", "jyu4", "lau4", "fong3", "ze3", "ze3", "nei5", "gin1", "bok3"]}, "nlp": {"tokens": [{"text": "多麼", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "孤單", "pos": "X"}, {"text": "如", "pos": "X"}, {"text": "流放", "pos": "X"}, {"text": "藉藉", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "肩膊", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0009", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0011", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0011", "text": "即使總會寂寞至少 倦了便回岸", "structure": {"line_index": 11, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 9, 2, 2, 4, 2, 5, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["zik1", "si2", "zung2", "zik6", "mok6", "zi3", "gyun6", "liu5", "bin6", "wui4", "ngon6"]}, "nlp": {"tokens": [{"text": "即使", "pos": "X"}, {"text": "總會", "pos": "X"}, {"text": "寂寞", "pos": "X"}, {"text": "至少", "pos": "X"}, {"text": "倦", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "回岸", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0010", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0012", "paragraph_id": "para_03"}}
