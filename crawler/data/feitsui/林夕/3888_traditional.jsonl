{"id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0002", "text": "一眨眼一眨眼忍了多久 我哭過沒有", "structure": {"line_index": 2, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 5, 3, 4, 5, 9, 5, 3, 9, 5, 3, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["jat1", "zaap3", "ngaan5", "jat1", "zaap3", "ngaan5", "jan2", "liu5", "do1", "gau2", "ngo5", "huk1", "gwo3", "mut6", "jau5"]}, "nlp": {"tokens": [{"text": "一眨眼", "pos": "X"}, {"text": "一眨眼", "pos": "X"}, {"text": "忍", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "多久", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "哭", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "沒有", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "藉藉你肩膀", "artists": ["陳曉東"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3888", "prev_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0001", "next_line_id": "lyr_6ZmI5pmT5Lic_Mzg4OA_0003", "paragraph_id": "para_01"}}
