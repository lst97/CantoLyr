{"id": "lyr_5p2o5Y2D5ayF_MjkyOQ_0005", "text": "彼此理想一致 積蓄也都消耗", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 5, 9, 3, 4, 3, 3, 5, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["bei2", "ci2", "lei5", "soeng2", "jat1", "zi3", "zik1", "cuk1", "jaa5", "dou1", "siu1", "hou3"]}, "nlp": {"tokens": [{"text": "彼此", "pos": "X"}, {"text": "理想", "pos": "X"}, {"text": "一致", "pos": "X"}, {"text": "積蓄", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "消耗", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "她成功了他沒有", "artists": ["楊千嬅"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_2929", "prev_line_id": "lyr_5p2o5Y2D5ayF_MjkyOQ_0004", "next_line_id": "lyr_5p2o5Y2D5ayF_MjkyOQ_0006", "paragraph_id": "para_02"}}
