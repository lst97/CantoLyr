{"id": "lyr_5Y2i5ben6Z-z_MzM0_0003", "text": "若你還是男人分手不用氣喘", "structure": {"line_index": 3, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 0, 2, 0, 0, 3, 9, 3, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["joek6", "nei5", "waan4", "si6", "naam4", "jan4", "fan1", "sau2", "bat1", "jung6", "hei3", "cyun2"]}, "nlp": {"tokens": [{"text": "若", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "男人", "pos": "X"}, {"text": "分手", "pos": "X"}, {"text": "不用", "pos": "X"}, {"text": "氣喘", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0002", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0004", "text": "難堪不過給你當做副選", "structure": {"line_index": 4, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 4, 3, 5, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["naan4", "ham1", "bat1", "gwo3", "kap1", "nei5", "zou6", "fu3", "syun2"]}, "nlp": {"tokens": [{"text": "難堪", "pos": "X"}, {"text": "不過", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "當做", "pos": "X"}, {"text": "副", "pos": "X"}, {"text": "選", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0003", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0005", "text": "點起香菸說 對不起你交足戲", "structure": {"line_index": 5, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 9, 3, 3, 4, 4, 3, 9, 5, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["dim2", "hei2", "hoeng1", "jin1", "syut3", "deoi3", "bat1", "hei2", "nei5", "gaau1", "zuk1", "hei3"]}, "nlp": {"tokens": [{"text": "點起", "pos": "X"}, {"text": "香菸", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "對不起", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "交足", "pos": "X"}, {"text": "戲", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0004", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0006", "text": "而我 愛只愛這電油味", "structure": {"line_index": 6, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 4, 9, 4, 5, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["ji4", "ngo5", "oi3", "zi2", "oi3", "ze5", "din6", "jau4", "mei6"]}, "nlp": {"tokens": [{"text": "而", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "只", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "電油味", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0005", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0007", "text": "或者喜歡你 完全爲 麻醉自己", "structure": {"line_index": 7, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 9, 9, 3, 5, 0, 0, 0, 4, 2, 9], "tone_pattern_cantonese_jyutping": ["waak6", "ze2", "hei2", "fun1", "nei5", "jyun4", "cyun4", "maa4", "zeoi3", "zi6", "gei2"]}, "nlp": {"tokens": [{"text": "或者", "pos": "X"}, {"text": "喜歡", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "完全", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "麻醉", "pos": "X"}, {"text": "自己", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0006", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0008", "text": "失去工作也不必 寂寞致死", "structure": {"line_index": 8, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 4, 5, 3, 3, 2, 2, 4, 9], "tone_pattern_cantonese_jyutping": ["sat1", "heoi3", "gung1", "zok3", "jaa5", "bat1", "bit1", "zik6", "mok6", "zi3", "sei2"]}, "nlp": {"tokens": [{"text": "失去", "pos": "X"}, {"text": "工作", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "寂寞", "pos": "X"}, {"text": "致死", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0007", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0009", "paragraph_id": "para_02"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0009", "text": "談什麼戀愛 無需深愛", "structure": {"line_index": 9, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 3, 9, 4, 0, 3, 3, 4], "tone_pattern_cantonese_jyutping": ["taam4", "sam6", "mo1", "lyun2", "oi3", "mou4", "seoi1", "sam1", "oi3"]}, "nlp": {"tokens": [{"text": "談", "pos": "X"}, {"text": "什麼", "pos": "X"}, {"text": "戀愛", "pos": "X"}, {"text": "無需", "pos": "X"}, {"text": "深愛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0008", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0010", "paragraph_id": "para_03"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0010", "text": "前非都不必急於痛改", "structure": {"line_index": 10, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 3, 3, 3, 3, 3, 4, 9], "tone_pattern_cantonese_jyutping": ["cin4", "fei1", "dou1", "bat1", "bit1", "gap1", "jyu1", "tung3", "goi2"]}, "nlp": {"tokens": [{"text": "前非", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "不必", "pos": "X"}, {"text": "急於", "pos": "X"}, {"text": "痛改", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0009", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0011", "paragraph_id": "para_03"}}
{"id": "lyr_5Y2i5ben6Z-z_MzM0_0011", "text": "難得到你的將來 誰會覺得意外", "structure": {"line_index": 11, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 4, 5, 3, 3, 0, 0, 4, 3, 4, 2], "tone_pattern_cantonese_jyutping": ["naan4", "dak1", "dou3", "nei5", "dik1", "zoeng1", "loi4", "seoi4", "gok3", "dak1", "ji3", "ngoi6"]}, "nlp": {"tokens": [{"text": "難", "pos": "X"}, {"text": "得到", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "將來", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "會", "pos": "X"}, {"text": "覺得", "pos": "X"}, {"text": "意外", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "喜歡戀愛", "artists": ["盧巧音"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_334", "prev_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0010", "next_line_id": "lyr_5Y2i5ben6Z-z_MzM0_0012", "paragraph_id": "para_03"}}
