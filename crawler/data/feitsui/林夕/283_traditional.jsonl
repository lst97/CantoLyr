{"id": "lyr_5byg5pWs6L2p_Mjgz_0023", "text": "難爲這洗劫永沒罪證", "structure": {"line_index": 23, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 9, 4, 5, 2, 2, 4], "tone_pattern_cantonese_jyutping": ["naan4", "ze5", "sai2", "gip3", "wing5", "mut6", "zeoi6", "zing3"]}, "nlp": {"tokens": [{"text": "難爲", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "洗劫", "pos": "X"}, {"text": "永沒", "pos": "X"}, {"text": "罪證", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "酷愛", "artists": ["張敬軒"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_283", "prev_line_id": "lyr_5byg5pWs6L2p_Mjgz_0022", "next_line_id": "lyr_5byg5pWs6L2p_Mjgz_0024", "paragraph_id": "para_06"}}
