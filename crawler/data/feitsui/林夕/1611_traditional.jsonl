{"id": "lyr_5byg5L-h5ZOy_MTYxMQ_0005", "text": "我自覺心已死 但這刻卻對不起", "structure": {"line_index": 5, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 3, 5, 9, 2, 5, 3, 4, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["ngo5", "zi6", "gok3", "sam1", "ji5", "sei2", "daan6", "ze5", "hak1", "koek3", "deoi3", "bat1", "hei2"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "自覺", "pos": "X"}, {"text": "心已", "pos": "X"}, {"text": "死", "pos": "X"}, {"text": "但", "pos": "X"}, {"text": "這刻", "pos": "X"}, {"text": "卻", "pos": "X"}, {"text": "對不起", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "惹塵", "artists": ["張信哲"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1611", "prev_line_id": "lyr_5byg5L-h5ZOy_MTYxMQ_0004", "next_line_id": "lyr_5byg5L-h5ZOy_MTYxMQ_0006", "paragraph_id": "para_02"}}
