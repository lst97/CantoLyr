{"id": "lyr_6ZmI5bCP5pil_MTI2NQ_0008", "text": "越是到巔峯 越快變 變得似瘋癲", "structure": {"line_index": 8, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 4, 3, 3, 2, 4, 4, 4, 3, 5, 3, 3], "tone_pattern_cantonese_jyutping": ["jyut6", "si6", "dou3", "din1", "fung1", "jyut6", "faai3", "bin3", "bin3", "dak1", "ci5", "fung1", "din1"]}, "nlp": {"tokens": [{"text": "越是", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "巔峯", "pos": "X"}, {"text": "越快", "pos": "X"}, {"text": "變", "pos": "X"}, {"text": "變得", "pos": "X"}, {"text": "似", "pos": "X"}, {"text": "瘋癲", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "戰無不勝", "artists": ["陳小春"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1265", "prev_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0007", "next_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0009", "paragraph_id": "para_03"}}
{"id": "lyr_6ZmI5bCP5pil_MTI2NQ_0009", "text": "一個人 怎可以一手勝天", "structure": {"line_index": 9, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 0, 9, 9, 5, 3, 9, 4, 3], "tone_pattern_cantonese_jyutping": ["jat1", "go3", "jan4", "zam2", "ho2", "ji5", "jat1", "sau2", "sing3", "tin1"]}, "nlp": {"tokens": [{"text": "一個", "pos": "X"}, {"text": "人", "pos": "X"}, {"text": "怎", "pos": "X"}, {"text": "可以", "pos": "X"}, {"text": "一手", "pos": "X"}, {"text": "勝天", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "戰無不勝", "artists": ["陳小春"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1265", "prev_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0008", "next_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0010", "paragraph_id": "para_03"}}
