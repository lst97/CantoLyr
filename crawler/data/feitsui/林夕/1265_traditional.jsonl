{"id": "lyr_6ZmI5bCP5pil_MTI2NQ_0005", "text": "但是天闊地厚 誰都知這叫作荒謬", "structure": {"line_index": 5, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 2, 3, 4, 2, 5, 0, 3, 3, 5, 4, 4, 3, 2], "tone_pattern_cantonese_jyutping": ["daan6", "si6", "tin1", "fut3", "dei6", "hau5", "seoi4", "dou1", "zi1", "ze5", "giu3", "zok3", "fong1", "mau6"]}, "nlp": {"tokens": [{"text": "但是", "pos": "X"}, {"text": "天闊", "pos": "X"}, {"text": "地厚", "pos": "X"}, {"text": "誰", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "知", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "叫作", "pos": "X"}, {"text": "荒謬", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "戰無不勝", "artists": ["陳小春"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1265", "prev_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0004", "next_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0006", "paragraph_id": "para_02"}}
