{"id": "lyr_6ZmI5bCP5pil_MTI2NQ_0003", "text": "也許一出手 將世界左右", "structure": {"line_index": 3, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 3, 3, 9, 3, 4, 4, 9, 2], "tone_pattern_cantonese_jyutping": ["jaa5", "heoi2", "jat1", "ceot1", "sau2", "zoeng1", "sai3", "gaai3", "zo2", "jau6"]}, "nlp": {"tokens": [{"text": "也許", "pos": "X"}, {"text": "一", "pos": "X"}, {"text": "出手", "pos": "X"}, {"text": "將", "pos": "X"}, {"text": "世界", "pos": "X"}, {"text": "左右", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "戰無不勝", "artists": ["陳小春"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1265", "prev_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0002", "next_line_id": "lyr_6ZmI5bCP5pil_MTI2NQ_0004", "paragraph_id": "para_02"}}
