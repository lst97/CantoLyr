{"id": "lyr_6YOR56eA5paH_MTMwOA_0007", "text": "今天一見 我知我弱點", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 3, 4, 5, 3, 5, 2, 9], "tone_pattern_cantonese_jyutping": ["gam1", "tin1", "jat1", "gin3", "ngo5", "zi1", "ngo5", "joek6", "dim2"]}, "nlp": {"tokens": [{"text": "今天", "pos": "X"}, {"text": "一見", "pos": "X"}, {"text": "我知", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "弱點", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "你愛我愛不起", "artists": ["鄭秀文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1308", "prev_line_id": "lyr_6YOR56eA5paH_MTMwOA_0006", "next_line_id": "lyr_6YOR56eA5paH_MTMwOA_0008", "paragraph_id": "para_01"}}
