{"id": "lyr_6YOR56eA5paH_MTMwOA_0005", "text": "也許好伴侶毫無分別", "structure": {"line_index": 5, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 9, 2, 5, 0, 0, 3, 2], "tone_pattern_cantonese_jyutping": ["jaa5", "heoi2", "hou2", "bun6", "leoi5", "hou4", "mou4", "fan1", "bit6"]}, "nlp": {"tokens": [{"text": "也許", "pos": "X"}, {"text": "好伴侶", "pos": "X"}, {"text": "毫無", "pos": "X"}, {"text": "分別", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "你愛我愛不起", "artists": ["鄭秀文"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1308", "prev_line_id": "lyr_6YOR56eA5paH_MTMwOA_0004", "next_line_id": "lyr_6YOR56eA5paH_MTMwOA_0006", "paragraph_id": "para_01"}}
