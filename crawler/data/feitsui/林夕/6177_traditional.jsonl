{"id": "lyr_5YiY5b635Y2O_NjE3Nw_0003", "text": "你話過志願要去做結他手 不過並無成就", "structure": {"line_index": 3, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 4, 2, 4, 4, 2, 4, 3, 9, 3, 4, 2, 0, 0, 2], "tone_pattern_cantonese_jyutping": ["nei5", "waa6", "gwo3", "zi3", "jyun6", "jiu3", "heoi3", "zou6", "git3", "taa1", "sau2", "bat1", "gwo3", "bing6", "mou4", "sing4", "zau6"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "話", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "志願", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "去", "pos": "X"}, {"text": "做結", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "手", "pos": "X"}, {"text": "不過", "pos": "X"}, {"text": "並", "pos": "X"}, {"text": "無", "pos": "X"}, {"text": "成就", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "按摩女郎", "artists": ["劉德華"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6177", "prev_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0002", "next_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0004", "paragraph_id": "para_02"}}
{"id": "lyr_5YiY5b635Y2O_NjE3Nw_0004", "text": "即使這裏沒歌曲給你奏 憑著過活也是你這雙手", "structure": {"line_index": 4, "char_count": 20}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 9, 5, 5, 2, 3, 3, 3, 5, 4, 0, 2, 4, 2, 5, 2, 5, 5, 3, 9], "tone_pattern_cantonese_jyutping": ["zik1", "si2", "ze5", "leoi5", "mut6", "go1", "kuk1", "kap1", "nei5", "zau3", "pang4", "zoek6", "gwo3", "wut6", "jaa5", "si6", "nei5", "ze5", "soeng1", "sau2"]}, "nlp": {"tokens": [{"text": "即使", "pos": "X"}, {"text": "這裏", "pos": "X"}, {"text": "沒", "pos": "X"}, {"text": "歌曲", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "奏", "pos": "X"}, {"text": "憑著", "pos": "X"}, {"text": "過活", "pos": "X"}, {"text": "也", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "雙手", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "按摩女郎", "artists": ["劉德華"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6177", "prev_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0003", "next_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0005", "paragraph_id": "para_02"}}
{"id": "lyr_5YiY5b635Y2O_NjE3Nw_0005", "text": "別放棄 祝福你 就算這個世界再不景氣", "structure": {"line_index": 5, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 4, 3, 3, 5, 2, 4, 5, 4, 4, 4, 4, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["bit6", "fong3", "hei3", "zuk1", "fuk1", "nei5", "zau6", "syun3", "ze5", "go3", "sai3", "gaai3", "zoi3", "bat1", "ging2", "hei3"]}, "nlp": {"tokens": [{"text": "別", "pos": "X"}, {"text": "放棄", "pos": "X"}, {"text": "祝福", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "就算", "pos": "X"}, {"text": "這個", "pos": "X"}, {"text": "世界", "pos": "X"}, {"text": "再", "pos": "X"}, {"text": "不景氣", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "按摩女郎", "artists": ["劉德華"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6177", "prev_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0004", "next_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0006", "paragraph_id": "para_03"}}
