{"id": "lyr_5YiY5b635Y2O_NjE3Nw_0009", "text": "曾抱着我 而這天看着我", "structure": {"line_index": 9, "char_count": 10}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 5, 2, 5, 0, 5, 3, 4, 2, 5], "tone_pattern_cantonese_jyutping": ["cang4", "pou5", "zoek6", "ngo5", "ji4", "ze5", "tin1", "hon3", "zoek6", "ngo5"]}, "nlp": {"tokens": [{"text": "曾", "pos": "X"}, {"text": "抱", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "而", "pos": "X"}, {"text": "這天", "pos": "X"}, {"text": "看着", "pos": "X"}, {"text": "我", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "按摩女郎", "artists": ["劉德華"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6177", "prev_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0008", "next_line_id": "lyr_5YiY5b635Y2O_NjE3Nw_0010", "paragraph_id": "para_04"}}
