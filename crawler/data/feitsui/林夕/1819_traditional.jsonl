{"id": "lyr_5ZOB5Yag_MTgxOQ_0009", "text": "仍望到快樂 離別是個序幕 重逢爲了捕獲 被懷念的感覺", "structure": {"line_index": 9, "char_count": 23}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 4, 2, 0, 2, 2, 4, 2, 2, 0, 5, 2, 2, 2, 0, 2, 3, 9, 4], "tone_pattern_cantonese_jyutping": ["jing4", "mong6", "dou3", "faai3", "lok6", "lei4", "bit6", "si6", "go3", "zeoi6", "mok6", "fung4", "liu5", "bou6", "wok6", "bei6", "waai4", "nim6", "dik1", "gam2", "gok3"]}, "nlp": {"tokens": [{"text": "仍望", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "快樂", "pos": "X"}, {"text": "離別", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "個", "pos": "X"}, {"text": "序幕", "pos": "X"}, {"text": "重逢", "pos": "X"}, {"text": "爲了", "pos": "X"}, {"text": "捕獲", "pos": "X"}, {"text": "被", "pos": "X"}, {"text": "懷念", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "感覺", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "愛情在香港轉機", "artists": ["品冠"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1819", "prev_line_id": "lyr_5ZOB5Yag_MTgxOQ_0008", "next_line_id": "lyr_5ZOB5Yag_MTgxOQ_0010", "paragraph_id": "para_03"}}
