{"id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0016", "text": "當天你挑選他 其實都深愛我嗎", "structure": {"line_index": 16, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 5, 3, 9, 3, 0, 2, 3, 3, 4, 5, 3], "tone_pattern_cantonese_jyutping": ["tin1", "nei5", "tiu1", "syun2", "taa1", "kei4", "sat6", "dou1", "sam1", "oi3", "ngo5", "maa1"]}, "nlp": {"tokens": [{"text": "當天", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "挑選", "pos": "X"}, {"text": "他", "pos": "X"}, {"text": "其實", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "深", "pos": "X"}, {"text": "愛我嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "思前戀後", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3372", "prev_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0015", "next_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0017", "paragraph_id": "para_03"}}
