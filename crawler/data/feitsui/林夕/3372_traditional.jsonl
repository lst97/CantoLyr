{"id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0003", "text": "分擔你的悽慘 如像醫生要看症", "structure": {"line_index": 3, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 3, 5, 3, 3, 9, 0, 2, 3, 3, 4, 4, 4], "tone_pattern_cantonese_jyutping": ["fan1", "daam1", "nei5", "dik1", "cai1", "caam2", "jyu4", "zoeng6", "ji1", "sang1", "jiu3", "hon3", "zing3"]}, "nlp": {"tokens": [{"text": "分擔", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "悽慘", "pos": "X"}, {"text": "如像", "pos": "X"}, {"text": "醫生", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "看症", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "思前戀後", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3372", "prev_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0002", "next_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0004", "text": "忘掉自己的心事是這樣難", "structure": {"line_index": 4, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 9, 3, 3, 2, 2, 5, 2, 0], "tone_pattern_cantonese_jyutping": ["mong4", "diu6", "zi6", "gei2", "dik1", "sam1", "si6", "si6", "ze5", "joeng6", "naan4"]}, "nlp": {"tokens": [{"text": "忘掉", "pos": "X"}, {"text": "自己", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心事", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "這樣", "pos": "X"}, {"text": "難", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "思前戀後", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3372", "prev_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0003", "next_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0005", "text": "你想說到明晚 我可以 獻出半世時間", "structure": {"line_index": 5, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 9, 4, 4, 0, 5, 5, 9, 5, 4, 3, 4, 4, 0], "tone_pattern_cantonese_jyutping": ["nei5", "soeng2", "syut3", "dou3", "ming4", "maan5", "ngo5", "ho2", "ji5", "hin3", "ceot1", "bun3", "sai3", "si4"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "想", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "明晚", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "可以", "pos": "X"}, {"text": "獻出", "pos": "X"}, {"text": "半世", "pos": "X"}, {"text": "時間", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "思前戀後", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3372", "prev_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0004", "next_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0006", "paragraph_id": "para_01"}}
{"id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0006", "text": "誰願來做英雄 爲前度解夢", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 0, 2, 3, 0, 0, 2, 9, 2], "tone_pattern_cantonese_jyutping": ["seoi4", "jyun6", "loi4", "zou6", "jing1", "hung4", "cin4", "dou6", "gaai2", "mung6"]}, "nlp": {"tokens": [{"text": "誰", "pos": "X"}, {"text": "願來", "pos": "X"}, {"text": "做", "pos": "X"}, {"text": "英雄", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "前度", "pos": "X"}, {"text": "解夢", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "思前戀後", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3372", "prev_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0005", "next_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0007", "text": "你傷心處仍舊讓我痛", "structure": {"line_index": 7, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 3, 3, 0, 2, 2, 5, 4], "tone_pattern_cantonese_jyutping": ["nei5", "soeng1", "sam1", "jing4", "gau6", "joeng6", "ngo5", "tung3"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "傷心", "pos": "X"}, {"text": "處", "pos": "X"}, {"text": "仍舊", "pos": "X"}, {"text": "讓", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "痛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "思前戀後", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3372", "prev_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0006", "next_line_id": "lyr_5a2Z6ICA5aiB_MzM3Mg_0008", "paragraph_id": "para_02"}}
