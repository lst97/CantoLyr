{"id": "lyr_6YOR56eA5paH_MTY1_0007", "text": "但回頭目睹你 爲我好自己不好", "structure": {"line_index": 7, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 0, 0, 2, 9, 5, 5, 9, 2, 9, 3, 9], "tone_pattern_cantonese_jyutping": ["daan6", "wui4", "tau4", "muk6", "dou2", "nei5", "ngo5", "hou2", "zi6", "gei2", "bat1", "hou2"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "回頭", "pos": "X"}, {"text": "目睹", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "爲", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "好", "pos": "X"}, {"text": "自己", "pos": "X"}, {"text": "不好", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "終身美麗", "artists": ["鄭秀文"], "lyricists": ["林夕", "蒙面歌王"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_165", "prev_line_id": "lyr_6YOR56eA5paH_MTY1_0006", "next_line_id": "lyr_6YOR56eA5paH_MTY1_0008", "paragraph_id": "para_02"}}
