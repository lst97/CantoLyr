{"id": "lyr_6YOR56eA5paH_MTY1_0018", "text": "我這幸運兒幸運到一轉身找得到你", "structure": {"line_index": 18, "char_count": 15}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 2, 2, 0, 2, 2, 4, 3, 9, 3, 9, 3, 4, 5], "tone_pattern_cantonese_jyutping": ["ngo5", "ze5", "hang6", "wan6", "ji4", "hang6", "wan6", "dou3", "jat1", "zyun2", "san1", "zaau2", "dak1", "dou3", "nei5"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "幸運兒", "pos": "X"}, {"text": "幸運", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "一", "pos": "X"}, {"text": "轉身", "pos": "X"}, {"text": "找", "pos": "X"}, {"text": "得到", "pos": "X"}, {"text": "你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "終身美麗", "artists": ["鄭秀文"], "lyricists": ["林夕", "蒙面歌王"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_165", "prev_line_id": "lyr_6YOR56eA5paH_MTY1_0017", "next_line_id": "lyr_6YOR56eA5paH_MTY1_0019", "paragraph_id": "para_04"}}
