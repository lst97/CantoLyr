{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0003", "text": "當你在赤地痛哭 無人反應", "structure": {"line_index": 3, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 4, 2, 4, 3, 0, 0, 9], "tone_pattern_cantonese_jyutping": ["nei5", "zoi6", "cek3", "dei6", "tung3", "huk1", "mou4", "jan4", "faan2"]}, "nlp": {"tokens": [{"text": "當", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "在", "pos": "X"}, {"text": "赤地", "pos": "X"}, {"text": "痛哭", "pos": "X"}, {"text": "無人", "pos": "X"}, {"text": "反應", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0002", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0004", "paragraph_id": "para_01"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0004", "text": "可知悲泣最痛無聲", "structure": {"line_index": 4, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [9, 3, 3, 3, 4, 4, 0, 3], "tone_pattern_cantonese_jyutping": ["ho2", "zi1", "bei1", "jap1", "zeoi3", "tung3", "mou4", "sing1"]}, "nlp": {"tokens": [{"text": "可知", "pos": "X"}, {"text": "悲泣", "pos": "X"}, {"text": "最痛", "pos": "X"}, {"text": "無聲", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0003", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0005", "paragraph_id": "para_01"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0005", "text": "殘酷像你 當愛是象牙", "structure": {"line_index": 5, "char_count": 9}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 5, 4, 2, 2, 0], "tone_pattern_cantonese_jyutping": ["caan4", "huk6", "zoeng6", "nei5", "oi3", "si6", "zoeng6", "ngaa4"]}, "nlp": {"tokens": [{"text": "殘酷", "pos": "X"}, {"text": "像", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "當愛", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "象牙", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0004", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0006", "paragraph_id": "para_02"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0006", "text": "拔去我那刻 彷彿擁有以後", "structure": {"line_index": 6, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 5, 5, 3, 9, 3, 9, 5, 5, 2], "tone_pattern_cantonese_jyutping": ["bat6", "heoi3", "ngo5", "naa5", "hak1", "fong2", "fat1", "jung2", "jau5", "ji5", "hau6"]}, "nlp": {"tokens": [{"text": "拔去", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "那刻", "pos": "X"}, {"text": "彷彿", "pos": "X"}, {"text": "擁有", "pos": "X"}, {"text": "以後", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0005", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0007", "paragraph_id": "para_02"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0007", "text": "我有我痛苦 喚不起你內疚", "structure": {"line_index": 7, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 5, 4, 9, 2, 3, 9, 5, 2, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "jau5", "ngo5", "tung3", "fu2", "wun6", "bat1", "hei2", "nei5", "noi6", "gau3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "痛苦", "pos": "X"}, {"text": "喚不起", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "內疚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0006", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0008", "paragraph_id": "para_02"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0008", "text": "其實你愛我 還是愛看傷口", "structure": {"line_index": 8, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 4, 5, 0, 2, 4, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["kei4", "sat6", "nei5", "oi3", "ngo5", "waan4", "si6", "oi3", "hon3", "soeng1", "hau2"]}, "nlp": {"tokens": [{"text": "其實", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "愛看", "pos": "X"}, {"text": "傷口", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0007", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0009", "paragraph_id": "para_02"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0009", "text": "憑人性還能用心聽得懂我嗎", "structure": {"line_index": 9, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 4, 0, 0, 2, 3, 3, 3, 9, 5, 3], "tone_pattern_cantonese_jyutping": ["pang4", "jan4", "sing3", "waan4", "nang4", "jung6", "sam1", "ting1", "dak1", "dung2", "ngo5", "maa1"]}, "nlp": {"tokens": [{"text": "憑", "pos": "X"}, {"text": "人性", "pos": "X"}, {"text": "還", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "用心", "pos": "X"}, {"text": "聽得懂", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0008", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0010", "paragraph_id": "para_03"}}
