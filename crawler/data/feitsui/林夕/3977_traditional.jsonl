{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0012", "text": "那切膚之痛能叫你的心更寒嗎", "structure": {"line_index": 12, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 3, 3, 4, 0, 4, 5, 3, 3, 0, 3], "tone_pattern_cantonese_jyutping": ["naa5", "cai3", "fu1", "zi1", "tung3", "nang4", "giu3", "nei5", "dik1", "sam1", "hon4", "maa1"]}, "nlp": {"tokens": [{"text": "那", "pos": "X"}, {"text": "切膚之痛", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "叫", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "寒", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0011", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0013", "paragraph_id": "para_03"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0013", "text": "連螻蟻仍能互愛 不講也罷", "structure": {"line_index": 13, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 5, 0, 0, 2, 4, 3, 9, 5, 2], "tone_pattern_cantonese_jyutping": ["lin4", "lau4", "ngai5", "jing4", "nang4", "wu6", "oi3", "bat1", "gong2", "jaa5", "baa6"]}, "nlp": {"tokens": [{"text": "連", "pos": "X"}, {"text": "螻蟻", "pos": "X"}, {"text": "仍能", "pos": "X"}, {"text": "互愛", "pos": "X"}, {"text": "不", "pos": "X"}, {"text": "講", "pos": "X"}, {"text": "也罷", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0012", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0014", "paragraph_id": "para_04"}}
