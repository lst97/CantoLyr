{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0023", "text": "我有我痛苦 喚不起你內疚", "structure": {"line_index": 23, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 5, 4, 9, 2, 3, 9, 5, 2, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "jau5", "ngo5", "tung3", "fu2", "wun6", "bat1", "hei2", "nei5", "noi6", "gau3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "痛苦", "pos": "X"}, {"text": "喚不起", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "內疚", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0022", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0024", "paragraph_id": "para_06"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0024", "text": "其實你愛我 還是愛看傷口", "structure": {"line_index": 24, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 4, 5, 0, 2, 4, 4, 3, 9], "tone_pattern_cantonese_jyutping": ["kei4", "sat6", "nei5", "oi3", "ngo5", "waan4", "si6", "oi3", "hon3", "soeng1", "hau2"]}, "nlp": {"tokens": [{"text": "其實", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "還是", "pos": "X"}, {"text": "愛看", "pos": "X"}, {"text": "傷口", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0023", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0025", "paragraph_id": "para_06"}}
{"id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0025", "text": "憑人性還能用心聽得懂我嗎", "structure": {"line_index": 25, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 0, 4, 0, 0, 2, 3, 3, 3, 9, 5, 3], "tone_pattern_cantonese_jyutping": ["pang4", "jan4", "sing3", "waan4", "nang4", "jung6", "sam1", "ting1", "dak1", "dung2", "ngo5", "maa1"]}, "nlp": {"tokens": [{"text": "憑", "pos": "X"}, {"text": "人性", "pos": "X"}, {"text": "還", "pos": "X"}, {"text": "能", "pos": "X"}, {"text": "用心", "pos": "X"}, {"text": "聽得懂", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "最痛無聲", "artists": ["孫耀威"], "lyricists": ["林夕"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3977", "prev_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0024", "next_line_id": "lyr_5a2Z6ICA5aiB_Mzk3Nw_0026", "paragraph_id": "para_07"}}
