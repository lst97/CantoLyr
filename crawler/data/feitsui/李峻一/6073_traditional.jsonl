{"id": "lyr_5bCP6IKl_NjA3Mw_0006", "text": "我這種老友 你說有一位足夠", "structure": {"line_index": 6, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 5, 9, 5, 5, 5, 4, 5, 3, 2, 3, 4], "tone_pattern_cantonese_jyutping": ["ngo5", "ze5", "zung2", "lou5", "jau5", "nei5", "syut3", "jau5", "jat1", "wai6", "zuk1", "gau3"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "這種", "pos": "X"}, {"text": "老友", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "說", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "一位", "pos": "X"}, {"text": "足夠", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "有情有義", "artists": ["小肥"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6073", "prev_line_id": "lyr_5bCP6IKl_NjA3Mw_0005", "next_line_id": "lyr_5bCP6IKl_NjA3Mw_0007", "paragraph_id": "para_02"}}
