{"id": "lyr_6bqm5rWa6b6Z_NTc5Ng_0007", "text": "明白到分手都要好好保重 不要有病痛", "structure": {"line_index": 7, "char_count": 16}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 4, 3, 9, 3, 4, 9, 9, 9, 3, 4, 5, 2, 4], "tone_pattern_cantonese_jyutping": ["ming4", "baak6", "dou3", "fan1", "sau2", "dou1", "jiu3", "hou2", "hou2", "bou2", "bat1", "jiu3", "jau5", "beng6", "tung3"]}, "nlp": {"tokens": [{"text": "明白", "pos": "X"}, {"text": "到", "pos": "X"}, {"text": "分手", "pos": "X"}, {"text": "都", "pos": "X"}, {"text": "要", "pos": "X"}, {"text": "好好", "pos": "X"}, {"text": "保重", "pos": "X"}, {"text": "不要", "pos": "X"}, {"text": "有", "pos": "X"}, {"text": "病痛", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "自己保重", "artists": ["麥浚龍"], "lyricists": ["李峻一"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_5796", "prev_line_id": "lyr_6bqm5rWa6b6Z_NTc5Ng_0006", "next_line_id": "lyr_6bqm5rWa6b6Z_NTc5Ng_0008", "paragraph_id": "para_04"}}
