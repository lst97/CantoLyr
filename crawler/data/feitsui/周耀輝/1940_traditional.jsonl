{"id": "lyr_5Y2i5Yev5b2k_MTk0MA_0004", "text": "就發怪的夢 就算尾巴獨角多罕有", "structure": {"line_index": 4, "char_count": 14}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 4, 4, 3, 2, 2, 4, 5, 3, 2, 4, 3, 9, 5], "tone_pattern_cantonese_jyutping": ["zau6", "faat3", "gwaai3", "dik1", "mung6", "zau6", "syun3", "mei5", "baa1", "duk6", "gok3", "do1", "hon2", "jau5"]}, "nlp": {"tokens": [{"text": "就", "pos": "X"}, {"text": "發怪", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "夢", "pos": "X"}, {"text": "就算", "pos": "X"}, {"text": "尾巴", "pos": "X"}, {"text": "獨角", "pos": "X"}, {"text": "多", "pos": "X"}, {"text": "罕有", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "囂張", "artists": ["盧凱彤"], "lyricists": ["周耀輝"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1940", "prev_line_id": "lyr_5Y2i5Yev5b2k_MTk0MA_0003", "next_line_id": "lyr_5Y2i5Yev5b2k_MTk0MA_0005", "paragraph_id": "para_01"}}
