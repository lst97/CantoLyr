{"id": "lyr_6I6r5paH6JSa_MTg3Mg_0004", "text": "蒙着你的不願流淚的臉 留下眼睛泄漏了破碎的心", "structure": {"line_index": 4, "char_count": 21}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 5, 3, 3, 2, 0, 2, 3, 5, 0, 2, 5, 3, 4, 2, 5, 4, 4, 3, 3], "tone_pattern_cantonese_jyutping": ["mung4", "zoek6", "nei5", "dik1", "bat1", "jyun6", "lau4", "leoi6", "dik1", "lim5", "lau4", "haa6", "ngaan5", "zing1", "sit3", "lau6", "liu5", "po3", "seoi3", "dik1", "sam1"]}, "nlp": {"tokens": [{"text": "蒙着", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "不願", "pos": "X"}, {"text": "流淚", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "臉", "pos": "X"}, {"text": "留下", "pos": "X"}, {"text": "眼睛", "pos": "X"}, {"text": "泄漏", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "破碎", "pos": "X"}, {"text": "的", "pos": "X"}, {"text": "心", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "比夜更黑", "artists": ["莫文蔚"], "lyricists": ["周耀輝"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1872", "prev_line_id": "lyr_6I6r5paH6JSa_MTg3Mg_0003", "next_line_id": "lyr_6I6r5paH6JSa_MTg3Mg_0005", "paragraph_id": "para_02"}}
{"id": "lyr_6I6r5paH6JSa_MTg3Mg_0005", "text": "其實是你嗎 黑暗內藏着誘惑 明明夜更黑", "structure": {"line_index": 5, "char_count": 17}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 2, 2, 5, 3, 3, 4, 2, 0, 2, 5, 2, 0, 0, 2, 3], "tone_pattern_cantonese_jyutping": ["kei4", "sat6", "si6", "nei5", "maa1", "hak1", "am3", "noi6", "cong4", "zoek6", "jau5", "waak6", "ming4", "ming4", "je6", "hak1"]}, "nlp": {"tokens": [{"text": "其實", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "黑暗", "pos": "X"}, {"text": "內藏", "pos": "X"}, {"text": "着", "pos": "X"}, {"text": "誘惑", "pos": "X"}, {"text": "明明", "pos": "X"}, {"text": "夜", "pos": "X"}, {"text": "更", "pos": "X"}, {"text": "黑", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "比夜更黑", "artists": ["莫文蔚"], "lyricists": ["周耀輝"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1872", "prev_line_id": "lyr_6I6r5paH6JSa_MTg3Mg_0004", "next_line_id": "lyr_6I6r5paH6JSa_MTg3Mg_0006", "paragraph_id": "para_02"}}
