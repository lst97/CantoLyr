{"id": "lyr_6YKT5Li95qyj_MTMxMg_0009", "text": "分隔開 過了十米 我便懷念", "structure": {"line_index": 9, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 4, 3, 4, 5, 2, 5, 5, 2, 0, 2], "tone_pattern_cantonese_jyutping": ["fan1", "gaak3", "hoi1", "gwo3", "liu5", "sap6", "mai5", "ngo5", "bin6", "waai4", "nim6"]}, "nlp": {"tokens": [{"text": "分", "pos": "X"}, {"text": "隔開", "pos": "X"}, {"text": "過", "pos": "X"}, {"text": "了", "pos": "X"}, {"text": "十米", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "便", "pos": "X"}, {"text": "懷念", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "不要離我太遠", "artists": ["鄧麗欣"], "lyricists": ["Cookies", "黃偉文"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_1312", "prev_line_id": "lyr_6YKT5Li95qyj_MTMxMg_0008", "next_line_id": "lyr_6YKT5Li95qyj_MTMxMg_0010", "paragraph_id": "para_03"}}
