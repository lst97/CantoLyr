{"id": "lyr_6K645b-X5a6J_MzYyMw_0004", "text": "明知是仍捨不得你", "structure": {"line_index": 4, "char_count": 8}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [0, 3, 2, 0, 9, 3, 3, 5], "tone_pattern_cantonese_jyutping": ["ming4", "zi1", "si6", "jing4", "se2", "bat1", "dak1", "nei5"]}, "nlp": {"tokens": [{"text": "明知", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "仍", "pos": "X"}, {"text": "捨不得你", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "男人最痛", "artists": ["許志安"], "lyricists": ["周禮茂"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_3623", "prev_line_id": "lyr_6K645b-X5a6J_MzYyMw_0003", "next_line_id": "lyr_6K645b-X5a6J_MzYyMw_0005", "paragraph_id": "para_02"}}
