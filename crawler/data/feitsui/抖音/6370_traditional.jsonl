{"id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0003", "text": "當初 我幼稚行爲對你犯下大錯", "structure": {"line_index": 3, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [3, 5, 4, 2, 0, 4, 5, 2, 2, 2, 4], "tone_pattern_cantonese_jyutping": ["co1", "ngo5", "jau3", "zi6", "hang4", "deoi3", "nei5", "faan6", "haa6", "daai6", "co3"]}, "nlp": {"tokens": [{"text": "當初", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "幼稚", "pos": "X"}, {"text": "行爲", "pos": "X"}, {"text": "對", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "犯下", "pos": "X"}, {"text": "大錯", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "春嬌與志明", "artists": ["歐陽耀瑩"], "lyricists": ["抖音"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6370", "prev_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0002", "next_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0004", "paragraph_id": "para_02"}}
{"id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0004", "text": "你話我唔識霖 用錢買無用飾品", "structure": {"line_index": 4, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 2, 5, 0, 3, 0, 2, 0, 5, 0, 2, 3, 9], "tone_pattern_cantonese_jyutping": ["nei5", "waa6", "ngo5", "m4", "sik1", "lam4", "jung6", "cin4", "maai5", "mou4", "jung6", "sik1", "ban2"]}, "nlp": {"tokens": [{"text": "你", "pos": "X"}, {"text": "話", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "唔", "pos": "X"}, {"text": "識霖", "pos": "X"}, {"text": "用錢", "pos": "X"}, {"text": "買", "pos": "X"}, {"text": "無用", "pos": "X"}, {"text": "飾品", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "春嬌與志明", "artists": ["歐陽耀瑩"], "lyricists": ["抖音"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6370", "prev_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0003", "next_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0005", "paragraph_id": "para_02"}}
