{"id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0020", "text": "我愛這少年諷刺嗎 這花開嗎", "structure": {"line_index": 20, "char_count": 12}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 0, 4, 4, 3, 5, 3, 3, 3], "tone_pattern_cantonese_jyutping": ["ngo5", "oi3", "ze5", "nin4", "fung3", "ci3", "maa1", "ze5", "faa1", "hoi1", "maa1"]}, "nlp": {"tokens": [{"text": "我", "pos": "X"}, {"text": "愛", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "少年", "pos": "X"}, {"text": "諷刺", "pos": "X"}, {"text": "嗎", "pos": "X"}, {"text": "這花開", "pos": "X"}, {"text": "嗎", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "春嬌與志明", "artists": ["歐陽耀瑩"], "lyricists": ["抖音"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6370", "prev_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0019", "next_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0021", "paragraph_id": "para_04"}}
{"id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0021", "text": "我愛你 你是唱將我做配合", "structure": {"line_index": 21, "char_count": 11}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [5, 4, 5, 5, 2, 4, 3, 5, 2, 4, 2], "tone_pattern_cantonese_jyutping": ["ngo5", "oi3", "nei5", "nei5", "si6", "coeng3", "zoeng1", "ngo5", "zou6", "pui3", "hap6"]}, "nlp": {"tokens": [{"text": "我愛你", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "是", "pos": "X"}, {"text": "唱", "pos": "X"}, {"text": "將", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "做", "pos": "X"}, {"text": "配合", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "春嬌與志明", "artists": ["歐陽耀瑩"], "lyricists": ["抖音"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6370", "prev_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0020", "next_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0022", "paragraph_id": "para_05"}}
{"id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0022", "text": "但你予我這過程細緻 給我培訓", "structure": {"line_index": 22, "char_count": 13}, "semantics": {"themes": [], "sentiment": "neutral", "keywords": []}, "prosody": {"tone_pattern": [2, 5, 5, 5, 5, 4, 0, 4, 4, 3, 5, 0, 4], "tone_pattern_cantonese_jyutping": ["daan6", "nei5", "jyu5", "ngo5", "ze5", "gwo3", "cing4", "sai3", "zi3", "kap1", "ngo5", "pui4", "fan3"]}, "nlp": {"tokens": [{"text": "但", "pos": "X"}, {"text": "你", "pos": "X"}, {"text": "予", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "這", "pos": "X"}, {"text": "過程", "pos": "X"}, {"text": "細緻", "pos": "X"}, {"text": "給", "pos": "X"}, {"text": "我", "pos": "X"}, {"text": "培訓", "pos": "X"}], "syntax_notes": ""}, "source": {"title": "春嬌與志明", "artists": ["歐陽耀瑩"], "lyricists": ["抖音"], "year": 0, "genre": []}, "context_links": {"doc_id": "feitsui_6370", "prev_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0021", "next_line_id": "lyr_5qyn6Ziz6ICA6I65_NjM3MA_0023", "paragraph_id": "para_05"}}
